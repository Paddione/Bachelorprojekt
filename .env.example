# Domain configuration
# The base domain for the production deployment (e.g. example.com)
PROD_DOMAIN=yourdomain.tld

# The branding name used in the website and emails
BRAND_NAME=yourbrand.tld

# The primary email for contact/notifications
CONTACT_EMAIL=info@yourbrand.tld

# The phone number displayed on the website
CONTACT_PHONE=+49 000 000 00 000

# The city/region displayed on the website
CONTACT_CITY=YourCity

# The person name displayed on the website (e.g. about page, impressum)
CONTACT_NAME=Firstname Lastname

# The Docker image name for the website
WEBSITE_IMAGE=workspace-website

# Infrastructure namespace for Traefik middlewares (e.g. security-headers, compression)
INFRA_NAMESPACE=workspace-infra

# TLS secret name for wildcard certificate
TLS_SECRET_NAME=workspace-wildcard-tls

# SMTP sender address for production
SMTP_FROM=noreply@yourdomain.tld
