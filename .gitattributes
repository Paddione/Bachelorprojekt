# Binary game assets — prevent git from treating as text
brett/public/assets/sfx/*.ogg    binary
brett/public/assets/hud/*.png    binary
brett/public/assets/hud/*.svg    linguist-language=SVG
brett/public/assets/sprites/*.png binary
brett/public/assets/figure-pack/accessories/*.png binary
brett/public/assets/figure_pack_extension/accessories/*.png binary
brett/public/assets/game_assets_mentolder/hud/*.png binary
brett/public/assets/game_assets_mentolder/sprites/*.png binary

# ── Auto-generated artifacts — always resolve conflicts by keeping branch version ──
# These files are regenerated by CI after every merge to main (freshness-regen.yml).
# Using merge=ours prevents line-level conflict noise on local rebase/merge.
# Register the driver once per machine: git config merge.ours.driver true
# (also done by `task secrets:install-hooks`)
docs/generated/**                             merge=ours linguist-generated=true
docs/code-quality/repo-index.json             merge=ours linguist-generated=true
k3d/docs-content-built/**                     merge=ours linguist-generated=true

# ── git-crypt-managed secrets (encrypted at rest in this PUBLIC repo) ──
# NOTE: environments/certs/*.pem are PUBLIC sealing certs — intentionally NOT listed here.
environments/.secrets/**            filter=git-crypt diff=git-crypt
deploy/mcp/claude-code-secrets.yaml filter=git-crypt diff=git-crypt
