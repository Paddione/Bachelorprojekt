#!/usr/bin/env bash
# Reject commits that would store any managed secret in plaintext.
# Installed via: task secrets:install-hooks  (sets core.hooksPath=.githooks)
set -euo pipefail
repo_root="$(git rev-parse --show-toplevel)"

# --- agent-lock: main-checkout mutex (only in the MAIN checkout; fail-open) [T000510] ---
# Skip in linked worktrees, where git-dir (.git/worktrees/<name>) != common-dir (.git).
_al_gd="$(git rev-parse --absolute-git-dir 2>/dev/null || true)"
_al_cd="$(git rev-parse --git-common-dir 2>/dev/null || true)"
case "$_al_cd" in /*) : ;; *) _al_cd="$(cd "$_al_cd" 2>/dev/null && pwd || echo "$_al_cd")";; esac
if [ -n "$_al_gd" ] && [ "$_al_gd" = "$_al_cd" ]; then
  if ! bash "$repo_root/scripts/agent-lock.sh" guard-precommit; then
    exit 1
  fi
fi

if ! bash "$repo_root/scripts/git-crypt-guard.sh" check-staged; then
  echo "ERROR: refusing commit — a managed secret is staged unencrypted." >&2
  echo "Did you run 'git-crypt unlock'? See docs/WSL-BOOTSTRAP.md." >&2
  exit 1
fi
