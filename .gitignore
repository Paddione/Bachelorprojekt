# ── Secrets (niemals committen!) ────────────────
.env
.env.*
!.env.example
# ── Environment secrets (plaintext, never commit) ──
environments/.secrets/
# prod/secrets.yaml and prod-korczewski/secrets.yaml committed as ArgoCD placeholders (Skip=true)
# Real credentials are applied via: task workspace:prod:deploy / task korczewski:deploy
# k3d/secrets.yaml committed intentionally — dev-only placeholder values, not real credentials
deploy/mcp/openclaw-secrets.yaml
deploy/mcp/claude-code-secrets.yaml
vaultwarden-import-*.json
*-bitwarden-export.json
claude-code/*-export.settings.json
k3d/vaultwarden-seed-credentials.yaml
k3d/vaultwarden-seed-job.yaml
# ── Runtime-Daten (Docker-Volumes, DB, Certs) ──
data/
!website/src/data/

# ── Backup-Dumps (Skripte ja, Dumps nein) ──────
backup/*.sql
backup/*.sql.gz
backup/*.tar
backup/*.tar.gz
backup/*.dump

# ── Logs ────────────────────────────────────────
*.log
logs/

# ── OS-Artefakte ────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── WireGuard (generated keys and configs) ──────
wireguard/*.conf
wireguard/*.key
wireguard/*.pub

# ── Docker ──────────────────────────────────────
.docker/
**/target/

# ── Tracking (local SQLite, regenerated from JSON) ──
tracking.db

# ── Website (Astro build output) ───────────────
website/dist/
website/.astro/

# ── Worktrees ───────────────────────────────────
.worktrees/

# ── Claude Code local state (settings + hookify rules) ──
.claude/*.local.md
.claude/settings.local.json
.claude/worktrees/

# ── Misc ────────────────────────────────────────
.git_corrupt/
docs-site/
node_modules/
*.tmp
*.bak
docs/superpowers/*
!docs/superpowers/specs/
!docs/superpowers/plans/
files_chore.txt
files_main.txt
website/node_modules.task/
.task/checksum
# prod-korczewski/realm-workspace-korczewski.json tracked — Keycloak realm config (no credentials)
prod/realm-workspace-prod.json
# prod-korczewski/kustomization.yaml tracked — no secrets in this file
prod/realm-workspace-prod.json
website/.superpowers.superpowers/
.superpowers/
.playwright-mcp/
test-results/
tests/e2e/results/outcomes/
.worktrees/
memory
whisper
environments/Assets
.claude/settings.json
.claude/scheduled_tasks.lock
Systemdesign_Buchhaltung-1.docx
~$stemdesign_Buchhaltung-1.docx
.codex

# Python
__pycache__/
*.pyc
*.pyo

# ── Coaching sources (PDFs/EPUBs, never commit) ──
coaching-sources/*
!coaching-sources/.gitkeep

# ── Coaching scripts (node_modules is symlinked to website/node_modules) ──
scripts/coaching/node_modules

# ── WSL/Windows NTFS alternate data streams ──
*:Zone.Identifier
