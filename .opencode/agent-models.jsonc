            "context": 140000,
            "output": 8192
          }
        },
        "qwen3.5-9b@q4_k_m": {
          "name": "Qwen3.5-9B (3x48k parallel, Q4_K_M weights, Q8_0 KV)",
          "limit": {
            "context": 48000,
            "output": 8192
          }
        },
        "qwen3.5-9b@iq4_xs": {
