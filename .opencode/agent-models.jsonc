{
  "provider": {
    "llamacpp-mtp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp b9553 (Gemma4 QAT 12B + MTP draft, speculative decoding)",
      "options": {
        "baseURL": "http://127.0.0.1:8091/v1"
      },
      "models": {
        "gemma-4-12B-it-qat-UD-Q4_K_XL.gguf": {
          "name": "Gemma4 12B QAT (UD-Q4_K_XL) + MTP-draft Q8_0 (raw llama.cpp b9553+CUDA13.3, speculative decoding via --spec-type draft-mtp --spec-draft-n-max 6, -np 4 parallel slots over -c 16384 total ctx = 4096 ctx/slot, Q8_0 KV cache, -fit auto-VRAM-fit, auto-sleeps GPU after 20min idle and reloads on next request in ~6s) - start via Desktop\\start-gemma4-mtp-server.bat first",
          "limit": {
            "context": 4096,
            "output": 4096
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      // No models pulled yet (`ollama list` is empty). Add an entry here per
      // model after `ollama pull <model>` - opencode has no model auto-discovery
      // for OpenAI-compatible providers yet (github.com/anomalyco/opencode#6231).
      "models": {}
    },
    "llama-bonsai-server": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Ternary-Bonsai-8B)",
      "options": {
        "baseURL": "http://127.0.0.1:8093/v1"
      },
      "models": {
        // 2026-07-22: 27B komplett entladen, KEIN Skript laedt es mehr - Port
        // 8093 bedient jetzt in beiden Modi Ternary-Bonsai-8B: entweder
        // start-bonsai-server.ps1 (2 Slots x 65536 = max Kontext pro Slot,
        // gepaart mit Bonsai-Image) oder start-bonsai-parallel.ps1
        // (VRAM-abhaengig viele Slots, kein Bild-Gen). Modell ist in beiden
        // Faellen identisch, nur -np/-c unterscheiden sich.
        "Ternary-Bonsai-8B-Q2_0.gguf": {
          "name": "Ternary-Bonsai-8B (Q2_0, 65k ctx/Slot)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    },
    // OpenCode Zen/Go: Key aus ~/.config/opencode/secrets.env (chmod 600, nicht
    // in git). "opencode-go" statt "opencode" (Zen) - Subscription-Tier ($10/mo),
    // deepseek-v4-flash ist Teil des Go-Katalogs (verifiziert per curl gegen
    // https://opencode.ai/zen/go/v1/chat/completions, cost:"0" = im Abo enthalten).
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go (Subscription, deepseek-v4-flash)",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (OpenCode Go, 1M ctx, MoE 284B/13B active)",
          "limit": {
            "context": 1000000,
            "output": 8192
          }
        }
      }
    },
    "lmstudio": {
      "models": {
        "qwen3.5-9b@q4_k_xl": {
          "name": "Qwen3.5-9B (1 session, 140k ctx, UD-Q4_K_XL weights, Q8_0 KV)",
          "limit": {
            "context": 140000,
            "output": 8192
          }
        },
        "qwen3.5-9b@q4_k_m": {
          "name": "Qwen3.5-9B (3x48k parallel, Q4_K_M weights, Q8_0 KV)",
          "limit": {
            "context": 48000,
            "output": 8192
          }
        },
        "qwen3.5-9b@iq4_xs": {
          "name": "Qwen3.5-9B (4x65k parallel, IQ4_XS weights, 260k total ctx)",
          "limit": {
            "context": 260000,
            "output": 8192
          }
        },
        "qwen3-14b@q4_k_m": {
          "name": "Qwen3-14B (1 session, Q4_K_M, lmstudio-community/Qwen3-14B-GGUF)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "google/gemma-4-12b-qat": {
          "name": "Gemma 4 12B (QAT)",
          "limit": {
            "context": 180000,
            "output": 8192
          }
        },
        "gemma-4-12b-agentic-fable5-composer2.5-v2-3.5x-tau2@q4_k_m": {
          "name": "Gemma4 v2 12B + 423M MTP-Assistant draft (speculative decoding, yuxinlu1, Q4_K_M weights, Q8_0 KV)",
          "limit": {
            "context": 150000,
            "output": 8192
          }
        },
        "qwen3.6-14b-a3b-fablevibes": {
          "name": "Qwen3.6-14B-A3B FableVibes (14B-A3B MoE, MXFP4_MOE, 32k ctx, 4 parallel slots)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.6-14b-a3b-fablevibes@262k": {
          "name": "Qwen3.6-14B-A3B FableVibes (14B-A3B MoE, MXFP4_MOE, 262k ctx, concurrent/single-session)",
          "limit": {
            "context": 262000,
            "output": 8192
          }
        }
      }
    }
  },
  "agent": {
    "bonsai-8b": {
      "description": "PRIMARY SUBAGENT (Quality-Modus, start-bonsai-server.ps1): Ternary-Bonsai-8B (65k context per slot, up to 2 parallel slots via llama-server on port 8093, paired with Bonsai-Image on the same GPU). 2026-07-22: replaces the former bonsai-27b agent - 27B is no longer loaded by any script.",
      "mode": "subagent",
      "model": "llama-bonsai-server/Ternary-Bonsai-8B-Q2_0.gguf",
      "prompt": "{file:./prompts/local-subagent.md}",
      "color": "#0EA5E9",
      "temperature": 0.2,
      "permission": { "edit": "allow", "write": "allow", "bash": "allow", "webfetch": "deny", "websearch": "deny" }
    },
    // Eskalationsstufe fuer Parallel-Agenten (start-bonsai-parallel.ps1), NACH
    // lokaler Kontext-Kompaktierung/Retry und opencodes eigener Kompaktierung -
    // erst wenn beides nicht reicht, wird hier dispatcht. Laeuft ueber die
    // OpenCode-Go-Subscription (kein Pay-per-Token, s. "opencode-go"-Provider
    // oben), nicht ueber eine direkte DeepSeek-API-Abrechnung.
    "deepseek-helper": {
      "description": "ESCALATION: DeepSeek V4 Flash via OpenCode Go (1M ctx) - dispatch when a local parallel subagent is stuck, needs help, or exhausted its context after local compaction/retry already failed",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./prompts/deepseek-helper.md}",
      "color": "#F97316",
      "temperature": 0.3,
      "permission": { "edit": "allow", "write": "allow", "bash": "allow", "webfetch": "deny", "websearch": "deny" }
    }
  }
}
