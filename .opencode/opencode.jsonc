{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/qwen3.5-9b@iq4_xs",
  "permission": "allow",
  "lsp": true,
  "mcp": {
    // ── Monolith HTTP-Endpunkte (kubectl portforward via Taskfile) ────────
    "factory-mcp": {
      "type": "remote",
      "url": "http://localhost:13003/mcp",
      "enabled": true
    },
    "mcp-kubernetes": {
      "type": "remote",
      "url": "http://localhost:18080/mcp",
      "enabled": true
    },
    "mcp-postgres": {
      "type": "remote",
      "url": "http://localhost:13001/mcp",
      "enabled": true
    },
    // ── Stdio-Server (lokale Prozesse) ────────────────────────────────────
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "/home/patrick/.local/bin/codebase-memory-mcp"
      ],
      "enabled": true
    }
  }
}
