{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio/qwen3.6-14b-a3b-fablevibes",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "doom_loop": "allow",
    "skill": {
      "*": "allow",
      // ── Claude Code stubs (opencode has native equivalents) ──────────
      "dev-flow-plan": "deny",
      "dev-flow-execute": "deny",
      "dev-flow-chore": "deny",
      "dev-flow-e2e": "deny",
      "requesting-code-review": "deny",
      "superpowers:brainstorming": "deny",
      "superpowers:executing-plans": "deny",
      "superpowers:writing-plans": "deny",
      "test-driven-development": "deny",
      "verification-before-completion": "deny",
      // ── ML inference / fine-tuning (not project-relevant) ────────────
      "gguf-quantization": "deny",
      "llama-cpp": "deny",
      "speculative-decoding": "deny",
      "unsloth": "deny",
      "whisper": "deny",
      // ── Generic meta / skill discovery ───────────────────────────────
      "agent-orchestration": "deny",
      "project-overview": "deny",
      "find-skills": "deny",
      "skill-creator": "deny",
      "codebase-memory": "deny",
      // ── Domain specialists (dispatched via agent routing, not skills) ─
      "database-specialist": "deny",
      "incident-response": "deny",
      "infra-ops": "deny",
      "operations-management": "deny",
      "security-specialist": "deny",
      "website-specialist": "deny",
      // ── UI/design (not primary workflow) ─────────────────────────────
      "ui-ux-pro-max": "deny",
      "react-bits": "deny",
      "references": "deny",
      // ── market-cli installed (not project-relevant, avoid context bloat) ─
      "lavish": "deny"
    }
  },
  "lsp": true,
  "provider": {
    "llamacpp-mtp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp MTP (Windows)",
      "options": {
        "baseURL": "http://localhost:8080",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "gemma-4-12B-it-qat-UD-Q4_K_XL.gguf": {
          "name": "Gemma 4 12B QAT (Q4_K_XL) + MTP"
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.6-14b-a3b-fablevibes@262k": {
          "name": "Qwen3.6-14B-A3B FableVibes (14B-A3B MoE, Q4_K_M, 262k ctx, concurrent)",
          "limit": {
            "context": 262000,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    // ── Monolith HTTP-Endpunkte (kubectl portforward via Taskfile) ────────
    "factory-mcp": {
      "type": "remote",
      "url": "http://localhost:13003/mcp",
      "enabled": true
    },
    "mcp-kubernetes": {
      "type": "remote",
      "url": "http://localhost:18080/mcp",
      "enabled": true
    },
    "mcp-postgres": {
      "type": "remote",
      "url": "http://localhost:13001/mcp",
      "enabled": true
    },
    // ── Stdio-Server (lokale Prozesse) ────────────────────────────────────
    "codebase-memory-mcp": {
      "type": "local",
      "command": [
        "/home/patrick/.local/bin/codebase-memory-mcp"
      ],
      "enabled": true
    },
    "mcp-task-runner": {
      "type": "local",
      "command": [
        "mcp-task-runner",
        "--otel-endpoint",
        "localhost:4317",
        "--taskfile",
        "/home/patrick/Bachelorprojekt/Taskfile.yml"
      ],
      "enabled": true
    },
    "ticket-mcp": {
      "type": "local",
      "command": [
        "/home/patrick/Bachelorprojekt/scripts/ticket-mcp/ticket-mcp-go"
      ],
      "enabled": true
    },
    // task-master-ai: per openspec/specs/mcp-skill-integration.md deliberately
    // "optional/available, keine Skill-Logik" — never wired into any skill.
    // Disabled by default to avoid eager tool-schema loading; ticket-mcp is
    // the canonical task/ticket system for this repo. Flip to true to use ad-hoc.
    "task-master-ai": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "task-master-ai"
      ],
      "environment": {
        "OLLAMA_BASE_URL": "http://localhost:11434/api",
        "TASK_MASTER_TOOLS": "all"
      },
      "enabled": false
    },
    // ── GitHub MCP (local) ────────────────────────────────────────────────
    // Disabled: zero references in this repo's skills/scripts/docs; gh-axi
    // (.claude/skills/references/gh-axi.md) is the mandated GitHub path for
    // all agents, with plain `gh` as documented fallback. Flip to true if a
    // future workflow needs native MCP-level GitHub API access gh-axi/gh lack.
    "github-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": false
    },
    // ── Projekt-Override: global aktivierte, projektfremde MCPs abschalten ─
    // Reduziert opencodes initialen Session-Context (Tool-Schemas werden
    // eager geladen, kein Lazy-Loading). Diese Server sind generische
    // Web/Docs/Reasoning-Tools ohne Bezug zum k8s/postgres/Ticket-Workflow
    // dieses Repos. Volle Server-Definition wiederholt (statt nur
    // "enabled": false), damit der Override unabhängig von opencodes
    // Merge-Strategie (shallow/deep) greift. Bei Bedarf lokal wieder auf
    // true setzen.
    "docfork": {
      "type": "local",
      "command": ["npx", "-y", "docfork"],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "webresearch": {
      "type": "local",
      "command": ["npx", "-y", "@mzxrai/mcp-webresearch@latest"],
      "enabled": false
    }
  }
}