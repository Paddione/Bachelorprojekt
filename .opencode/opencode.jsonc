{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/zen",
  "permission": "allow",
  "mcp": {
    "mcp-k8s": {
      "type": "local",
      "command": ["/home/patrick/.config/opencode/node_modules/.bin/kubernetes-mcp-server", "--cluster-provider", "kubeconfig"],
      "enabled": true
    },
    "mcp-browser": {
      "type": "remote",
      "url": "http://localhost:13000/mcp",
      "enabled": true
    },
    "mcp-github": {
      "type": "remote",
      "url": "http://localhost:13002/mcp",
      "enabled": true
    },
    "mcp-postgres": {
      "type": "remote",
      "url": "http://localhost:13001/mcp",
      "enabled": true
    },
    "mcp-factory": {
      "type": "remote",
      "url": "http://localhost:13003/mcp",
      "enabled": true
    }
  },
  "plugin": ["@mailshieldai/opencode-canvas"],
  "experimental": {
    "openTelemetry": true
  },
  "provider": {
    "ollama": {
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      }
    }
  },
  "instructions": ["AGENTS.md"]
}
