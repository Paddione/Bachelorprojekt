{
  "name": "mediavault",
  "engines": { "node": ">=22.13.0" },
  "version": "2.0.0",
  "description": "Personal media library for videos, audiobooks, and ebooks",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "lint": "eslint .",
    "check": "tsc",
    "build": "vite build && node scripts/build-server.mjs",
    "dev": "cross-env NODE_ENV=development DOTENV_CONFIG_PATH=env/.env-app.local NODE_OPTIONS=--preserve-symlinks tsx -r dotenv/config server/index.ts",
    "start": "NODE_OPTIONS=--preserve-symlinks node -r dotenv/config dist/index.js",
    "docker:dev": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:restart": "npm run docker:down && npm run docker:dev",
    "docker:logs": "docker-compose logs -f videovault-dev",
    "docker:shell": "docker exec -it videovault-dev sh",
    "docker:pw:ui": "docker-compose --profile playwright up --build playwright-ui",
    "test": "npm run test:2:unit",
    "test:all": "npm run test:1:types && npm run test:2:unit && npm run test:4:e2e && npm run test:5:build && npm run test:6:health",
    "test:quick": "npm run test:1:types && npm run test:2:unit",
    "test:pre-deploy": "npm run test:all",
    "test:1:types": "echo '\n\u25b6 Step 1/5: Type Checking...\n' && npm run check",
    "test:2:unit": "echo '\n\u25b6 Step 2/5: Unit Tests (Client + Server)...\n' && npm run test:client && npm run test:server",
    "test:4:e2e": "echo '\n\u25b6 Step 3/5: E2E Tests (Playwright)...\n' && npm run docker:pw:all",
    "test:5:build": "echo '\n\u25b6 Step 4/5: Production Build...\n' && npm run build",
    "test:6:health": "echo '\n\u25b6 Step 5/5: Health Check...\n' && echo 'All tests passed!'",
    "test:client": "cross-env FAST_TESTS=1 vitest run --bail=1",
    "test:server": "cross-env FAST_TESTS=1 vitest run --bail=1 -c vitest.server.config.ts",
    "test:e2e": "vitest run -c e2e/vitest.config.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:coverage:full": "vitest run --coverage --bail=1",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "test:pw:report": "playwright show-report",
    "test:pw:install": "playwright install chromium",
    "docker:pw:all": "docker-compose --profile playwright up --build --exit-code-from playwright playwright",
    "db:push": "drizzle-kit push",
    "copy:ffmpeg": "node scripts/copy-ffmpeg-core.mjs",
    "predev": "node scripts/copy-ffmpeg-core.mjs",
    "prebuild": "node scripts/copy-ffmpeg-core.mjs",
    "pretest": "tsc -p tsconfig.test.json --noEmit",
    "predocker:pw:all": "node scripts/ensure-playwright-match.mjs",
    "prepare": "if [ -d .git ]; then husky; fi || true"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.60.5",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "epubjs": "^0.3.93",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.10.1",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.42.2",
    "helmet": "^8.3.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^4.0.0",
    "input-otp": "^1.4.2",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^1.25.0",
    "memorystore": "^1.6.7",
    "nanoid": "^6.0.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "react": "^19.2.8",
    "react-day-picker": "^8.10.2",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "react-i18next": "^17.0.10",
    "react-icons": "^5.7.0",
    "react-resizable-panels": "^2.1.9",
    "react-window": "^1.8.11",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.1",
    "vaul": "^1.1.2",
    "wouter": "^3.10.0",
    "ws": "^8.21.1",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@replit/vite-plugin-cartographer": "^0.6.0",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/flexsearch": "^0.7.6",
    "@types/node": "^26.1.1",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "msw": "^2.6.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "5.6.3",
    "vite": "^8.1.5",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "canvas": "^3.2.3"
  }
}
