{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppManifest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "kustomize": {
      "type": "string"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "host": {
            "type": "string"
          }
        },
        "required": ["key", "host"]
      }
    },
    "oidc": {
      "type": "object",
      "properties": {
        "client_id": {
          "type": "string"
        },
        "redirect_uris": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["client_id", "redirect_uris"]
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  },
  "required": ["name", "title", "description", "kustomize"]
}
