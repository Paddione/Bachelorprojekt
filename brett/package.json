{
  "name": "workspace-brett",
  "version": "0.26.0",
  "private": true,
  "main": "src/server/index.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/server/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json",
    "test": "MOCK_DB=true tsx --test test/*.test.ts test/*.test.js test/*.test.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^1.4.5-lts.1",
    "openid-client": "^6.8.4",
    "pg": "^8.21.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jspdf": "^1.3.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.20",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "jspdf": "^4.2.1",
    "three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
