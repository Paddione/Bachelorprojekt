{
  "name": "workspace-brett",
  "engines": {
    "node": ">=22.13.0"
  },
  "version": "0.40.2",
  "private": true,
  "main": "src/server/index.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/server/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json",
    "test": "MOCK_DB=true tsx --test test/*.test.ts test/*.test.js test/*.test.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jspdf": "^4.2.1",
    "multer": "^2.2.0",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jspdf": "^1.3.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.185.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "three": "^0.185.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.4"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.28.1": true
  }
}
