{
  "$schema": "https://brett.mentolder.de/schemas/figure-pack-v1.json",
  "version": "1.1.0",
  "units": "meters",
  "rotation": "radians",
  "coordinateSystem": "Y-up, right-handed (Three.js default)",
  "headGeometry": {
    "type": "SphereGeometry",
    "radius": 0.16,
    "widthSegments": 16,
    "heightSegments": 12,
    "uvMapping": "default equirectangular: u=0.5,v=0.5 lies at the front of the sphere (positive Z). The texture seam runs along the back."
  },
  "bones": [
    "hips",
    "head",
    "lShoulder",
    "rShoulder",
    "lElbow",
    "rElbow",
    "lWrist",
    "rWrist",
    "lHip",
    "rHip",
    "lKnee",
    "rKnee",
    "lAnkle",
    "rAnkle"
  ],
  "faces": {
    "_usage": "Each face PNG is a 512×512 sRGB texture meant to be applied as the head sphere's `map`. Features are centered at (u=0.5, v=0.5) — the front of the head. Pixels outside the central ~62% wrap to the sides/back of the head; design accommodates this.",
    "_applyTo": {
      "bone": "head",
      "material": "MeshLambertMaterial",
      "settings": {
        "map": "<face PNG>",
        "color": "0xd9c89b",
        "transparent": true,
        "alphaTest": 0.5,
        "map.colorSpace": "SRGBColorSpace",
        "map.anisotropy": 4,
        "map.flipY": true,
        "rotation": {
          "x": 0,
          "y": 0,
          "z": 0
        },
        "uvOffset": [
          0,
          0
        ],
        "uvRepeat": [
          1,
          1
        ]
      }
    },
    "neutral": {
      "file": "faces/neutral.png",
      "stance": "the rest face — present but unreactive"
    },
    "observing": {
      "file": "faces/observing.png",
      "stance": "watching, not yet engaged"
    },
    "distant": {
      "file": "faces/distant.png",
      "stance": "drifting outward, eyes loose"
    },
    "overwhelmed": {
      "file": "faces/overwhelmed.png",
      "stance": "wide-eyed, brows up, too much input"
    },
    "protective": {
      "file": "faces/protective.png",
      "stance": "firm gaze, brow shielded, holding ground"
    },
    "yearning": {
      "file": "faces/yearning.png",
      "stance": "eyes lifted, mouth parted, reaching"
    },
    "resolved": {
      "file": "faces/resolved.png",
      "stance": "soft-closed eyes, brass tilaka — at peace"
    },
    "withdrawn": {
      "file": "faces/withdrawn.png",
      "stance": "shut tight, no mouth, pulled in"
    },
    "present": {
      "file": "faces/present.png",
      "stance": "eyes forward with pupils, brass dot — most here"
    },
    "mourning": {
      "file": "faces/mourning.png",
      "stance": "closed eyes, single brass tear"
    },
    "curious": {
      "file": "faces/curious.png",
      "stance": "asymmetric, brow raised, slight tilt"
    },
    "blocked": {
      "file": "faces/blocked.png",
      "stance": "horizontal slate bar across eyes — cannot see"
    }
  },
