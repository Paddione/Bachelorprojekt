  "accessories": {
    "_usage": "Each accessory is a 256×256 transparent PNG meant to be applied to a `PlaneGeometry` parented to the named bone. Anchor (in PNG pixels) is the point that lands on the bone origin. After scaling, the visible content sits where you want it without further offsetting. Use MeshBasicMaterial with transparent:true, alphaTest:0.5 (no need to fight z-fighting).",
    "_defaultMaterial": {
      "type": "MeshBasicMaterial",
      "settings": {
        "transparent": true,
        "alphaTest": 0.5,
        "side": "DoubleSide",
        "depthWrite": false
      }
    },
