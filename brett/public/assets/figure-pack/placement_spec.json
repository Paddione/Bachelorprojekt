{
  "$schema": "https://brett.mentolder.de/schemas/figure-pack-v1.json",
  "version": "1.0.0",
  "units": "meters",
  "rotation": "radians",
  "coordinateSystem": "Y-up, right-handed (Three.js default)",
  "headGeometry": {
    "type": "SphereGeometry",
    "radius": 0.16,
    "widthSegments": 16,
    "heightSegments": 12,
    "uvMapping": "default equirectangular: u=0.5,v=0.5 lies at the front of the sphere (positive Z). The texture seam runs along the back."
  },
  "bones": [
    "hips", "head",
    "lShoulder", "rShoulder",
    "lElbow", "rElbow",
    "lWrist", "rWrist",
    "lHip", "rHip",
    "lKnee", "rKnee",
    "lAnkle", "rAnkle"
  ],

  "faces": {
    "_usage": "Each face PNG is a 512×512 sRGB texture meant to be applied as the head sphere's `map`. Features are centered at (u=0.5, v=0.5) — the front of the head. Pixels outside the central ~62% wrap to the sides/back of the head; design accommodates this.",
    "_applyTo": {
      "bone": "head",
      "material": "MeshLambertMaterial",
      "settings": {
        "map": "<face PNG>",
        "color": "0xd9c89b",
        "transparent": true,
        "alphaTest": 0.5,
        "map.colorSpace": "SRGBColorSpace",
        "map.anisotropy": 4,
        "map.flipY": true,
        "rotation": { "x": 0, "y": 0, "z": 0 },
        "uvOffset": [0, 0],
        "uvRepeat": [1, 1]
      }
    },
    "neutral":     { "file": "faces/neutral.png",     "stance": "the rest face — present but unreactive" },
    "observing":   { "file": "faces/observing.png",   "stance": "watching, not yet engaged" },
    "distant":     { "file": "faces/distant.png",     "stance": "drifting outward, eyes loose" },
    "overwhelmed": { "file": "faces/overwhelmed.png", "stance": "wide-eyed, brows up, too much input" },
    "protective":  { "file": "faces/protective.png",  "stance": "firm gaze, brow shielded, holding ground" },
    "yearning":    { "file": "faces/yearning.png",    "stance": "eyes lifted, mouth parted, reaching" },
    "resolved":    { "file": "faces/resolved.png",    "stance": "soft-closed eyes, brass tilaka — at peace" },
    "withdrawn":   { "file": "faces/withdrawn.png",   "stance": "shut tight, no mouth, pulled in" },
    "present":     { "file": "faces/present.png",     "stance": "eyes forward with pupils, brass dot — most here" },
    "mourning":    { "file": "faces/mourning.png",    "stance": "closed eyes, single brass tear" },
    "curious":     { "file": "faces/curious.png",     "stance": "asymmetric, brow raised, slight tilt" },
    "blocked":     { "file": "faces/blocked.png",     "stance": "horizontal slate bar across eyes — cannot see"  }
  },

  "bodies": {
    "_usage": "Reference renders only — the 3D mesh remains your existing rig. Use the proportions table below to scale your bone lengths per role. Joint-ball colors (wrist=yellow, ankle=green, knee=blue, elbow=brass, head=blush) MUST be preserved as semantic markers.",
    "adult-tall":    { "file": "bodies/adult-tall.png",    "headsTall": 8.0,
                       "scale": { "torsoH": 2.20, "shoulderW": 1.95, "hipW": 1.50, "upperArm": 1.50, "forearm": 1.40, "thigh": 1.95, "shin": 1.85 },
                       "approxMeters": 1.92 },
    "adult-average": { "file": "bodies/adult-average.png", "headsTall": 7.5,
                       "scale": { "torsoH": 2.10, "shoulderW": 1.75, "hipW": 1.45, "upperArm": 1.40, "forearm": 1.30, "thigh": 1.80, "shin": 1.70 },
                       "approxMeters": 1.70 },
    "adult-short":   { "file": "bodies/adult-short.png",   "headsTall": 7.0,
                       "scale": { "torsoH": 2.00, "shoulderW": 1.70, "hipW": 1.50, "upperArm": 1.30, "forearm": 1.20, "thigh": 1.65, "shin": 1.55 },
                       "approxMeters": 1.55 },
    "adolescent":    { "file": "bodies/adolescent.png",    "headsTall": 6.5,
                       "scale": { "torsoH": 1.90, "shoulderW": 1.45, "hipW": 1.25, "upperArm": 1.25, "forearm": 1.20, "thigh": 1.55, "shin": 1.50 },
                       "approxMeters": 1.45 },
    "child":         { "file": "bodies/child.png",         "headsTall": 4.8,
                       "scale": { "torsoH": 1.55, "shoulderW": 1.30, "hipW": 1.20, "upperArm": 0.95, "forearm": 0.85, "thigh": 1.10, "shin": 1.00 },
                       "approxMeters": 1.05,
                       "notes": "Head ratio is enlarged — keep head radius at 0.16 and the proportional read is correct." },
    "elder":         { "file": "bodies/elder.png",         "headsTall": 7.0,
                       "scale": { "torsoH": 2.00, "shoulderW": 1.55, "hipW": 1.40, "upperArm": 1.35, "forearm": 1.25, "thigh": 1.55, "shin": 1.45 },
                       "approxMeters": 1.58,
                       "notes": "Apply a small forward stoop: rotate the upper spine ~6° around the X-axis at the hips→head segment." }
  },

  "accessories": {
    "_usage": "Each accessory is a 256×256 transparent PNG meant to be applied to a `PlaneGeometry` parented to the named bone. Anchor (in PNG pixels) is the point that lands on the bone origin. After scaling, the visible content sits where you want it without further offsetting. Use MeshBasicMaterial with transparent:true, alphaTest:0.5 (no need to fight z-fighting).",
    "_defaultMaterial": {
      "type": "MeshBasicMaterial",
      "settings": {
        "transparent": true,
        "alphaTest": 0.5,
        "side": "DoubleSide",
        "depthWrite": false
      }
    },
    "cap":       { "file": "accessories/cap.png",       "bone": "head",
                   "anchorPx": [128, 168],
                   "sizeMeters": [0.45, 0.45],
                   "positionOffset": [0, 0.16, 0],
                   "rotation": [0, 0, 0],
                   "billboard": "yAxis",
                   "notes": "Sits on top of head sphere. Y offset puts the plane at the apex; billboarding around Y keeps it facing the camera horizontally." },
    "satchel":   { "file": "accessories/satchel.png",   "bone": "lShoulder",
                   "anchorPx": [88, 24],
                   "sizeMeters": [0.55, 0.55],
                   "positionOffset": [-0.02, 0, 0.06],
                   "rotation": [0, 0, 0.16],
                   "billboard": "yAxis",
                   "notes": "Strap top sits at left shoulder; bag hangs to right hip via Z-axis tilt and rotation around Z." },
    "cane":      { "file": "accessories/cane.png",      "bone": "rWrist",
                   "anchorPx": [152, 96],
                   "sizeMeters": [0.40, 0.85],
                   "positionOffset": [0.02, -0.04, 0.04],
                   "rotation": [0, 0, 0.04],
                   "billboard": "yAxis",
                   "notes": "Anchor is the curl-grip of the hook. Plane is taller than wide; cane shaft extends downward toward the floor." },
    "shawl":     { "file": "accessories/shawl.png",     "bone": "neck",
                   "anchorPx": [128, 80],
                   "sizeMeters": [0.80, 0.80],
                   "positionOffset": [0, -0.02, 0.04],
                   "rotation": [0, 0, 0],
                   "billboard": "yAxis",
                   "notes": "Drapes over both shoulders. Slight Z forward so it doesn't clip the torso." },
    "swaddle":   { "file": "accessories/swaddle.png",   "bone": "hips",
                   "anchorPx": [128, 140],
                   "sizeMeters": [0.65, 0.65],
                   "positionOffset": [0, 0.05, 0.05],
                   "rotation": [0, 0, 0],
                   "billboard": "yAxis",
                   "notes": "Centred on the torso. Primarily for the `child` body (infant role)." },
    "blindfold": { "file": "accessories/blindfold.png", "bone": "head",
                   "anchorPx": [128, 128],
                   "sizeMeters": [0.36, 0.36],
                   "positionOffset": [0, 0.01, 0.155],
                   "rotation": [0, 0, 0],
                   "billboard": false,
                   "notes": "Pin to front of head — Z offset = head radius minus 5mm so the plane is flush with the sphere surface." },
    "crown":     { "file": "accessories/crown.png",     "bone": "head",
                   "anchorPx": [128, 180],
                   "sizeMeters": [0.34, 0.34],
                   "positionOffset": [0, 0.14, 0],
                   "rotation": [0, 0, 0],
                   "billboard": "yAxis",
                   "notes": "Sits on top of head. Anchor near bottom of crown lets the band rest on the head apex." },
    "veil":      { "file": "accessories/veil.png",      "bone": "head",
                   "anchorPx": [128, 56],
                   "sizeMeters": [0.55, 0.55],
                   "positionOffset": [0, 0.10, 0],
                   "rotation": [0, 0, 0],
                   "billboard": "yAxis",
                   "notes": "Drapes from the head crown downward. The PNG uses SVG opacity gradient — Three.js renders alpha correctly with transparent:true." }
  },

  "selectionRing": {
    "file": null,
    "geometry": "RingGeometry(0.28, 0.30, 64)",
    "material": "MeshBasicMaterial({ color: 0xc8a96e, transparent: true, opacity: 0.9 })",
    "positionOffset": [0, 0.001, 0],
    "rotation": [-1.5707963267948966, 0, 0],
    "notes": "Lies flat on the floor (rotated -π/2 around X). Sits 1mm above the floor plane to avoid z-fighting."
  }
}
