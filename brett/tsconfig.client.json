{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "composite": true,
    "noEmit": false,
    "outDir": "dist/.tsbuild-client",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["three"],
    "baseUrl": ".",
    "paths": { "@types/*": ["src/types/*"] }
  },
  "include": ["src/client/**/*", "src/types/**/*"]
}
