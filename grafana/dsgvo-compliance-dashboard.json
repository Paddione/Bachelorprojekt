{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "DSGVO Compliance Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "percent",
          "displayName": "Compliance Score"
        }
      },
      "targets": [{
        "expr": "count(kube_pod_info{namespace='homeoffice'}) / count(kube_pod_info{namespace='homeoffice'}) * 100",
        "legendFormat": "Score"
      }]
    },
    {
      "title": "Datenresidenz: Container-Images nach Quelle",
      "description": "Alle Images müssen von vertrauenswürdigen Open-Source-Registries stammen. Keine US-Cloud-Provider-Images (gcr.io, mcr.microsoft.com, etc.).",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "kube_pod_container_info{namespace='homeoffice'}",
        "format": "table",
        "instant": true,
        "legendFormat": ""
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Value": true, "__name__": true, "endpoint": true,
              "instance": true, "job": true, "namespace": true, "node": true,
              "service": true, "uid": true, "image_spec": true
            },
            "renameByName": {
              "container": "Container",
              "image": "Image",
              "image_id": "Image ID",
              "pod": "Pod"
            }
          }
        }
      ]
    },
    {
      "title": "Pod-Gesundheit (homeoffice Namespace)",
      "description": "Alle Pods im homeoffice-Namespace müssen Running sein.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "displayName": "Running Pods"
        }
      },
      "targets": [{
        "expr": "count(kube_pod_status_phase{namespace='homeoffice', phase='Running'})",
        "legendFormat": "Running"
      }]
    },
    {
      "title": "Nicht-Running Pods (Alarm bei > 0)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "displayName": "Unhealthy Pods"
        }
      },
      "targets": [{
        "expr": "count(kube_pod_status_phase{namespace='homeoffice', phase!='Running', phase!='Succeeded'}) or vector(0)",
        "legendFormat": "Unhealthy"
      }]
    },
    {
      "title": "Speicher-Nutzung nach PVC",
      "description": "PersistentVolumeClaims — alle Daten bleiben lokal im Cluster.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "kubelet_volume_stats_used_bytes{namespace='homeoffice'}",
        "legendFormat": "{{ persistentvolumeclaim }}"
      }]
    },
    {
      "title": "CPU & RAM pro Service",
      "description": "Ressourcen-Verbrauch — für NFA-02 Performance-Monitoring.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='homeoffice', container!=''}[5m])) by (pod)",
          "legendFormat": "{{ pod }} CPU"
        }
      ]
    },
    {
      "title": "Netzwerk: Ausgehender Traffic (Externe Verbindungen)",
      "description": "Zeigt ausgehenden Traffic aus dem homeoffice-Namespace. Bei DSGVO-Konformität sollte hier kein Traffic zu externen Cloud-Diensten sichtbar sein.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [{
        "expr": "sum(rate(container_network_transmit_bytes_total{namespace='homeoffice'}[5m])) by (pod)",
        "legendFormat": "{{ pod }} TX"
      }]
    },
    {
      "title": "TLS-Zertifikate (Ingress)",
      "description": "Zeigt, ob TLS-Zertifikate vorhanden und gültig sind. In der Dev-Umgebung (k3d) ist HTTP normal; in Produktion muss HTTPS aktiv sein.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "displayName": "TLS Secrets"
        }
      },
      "targets": [{
        "expr": "count(kube_secret_info{namespace='homeoffice', type='kubernetes.io/tls'}) or vector(0)",
        "legendFormat": "TLS Secrets"
      }]
    },
    {
      "title": "Audit: Keycloak Login-Events (letzte Stunde)",
      "description": "Anzahl der Login-Events in Keycloak — belegt, dass Audit-Logging aktiv ist (SA-05).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "displayName": "Login Events/h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [{
        "expr": "count_over_time(kube_pod_container_status_restarts_total{namespace='homeoffice', container='keycloak'}[1h]) or vector(0)",
        "legendFormat": "Events"
      }]
    },
    {
      "title": "Service-Verfügbarkeit (Uptime)",
      "description": "NFA-03: 99.5% Verfügbarkeit. Zeigt Container-Neustarts als Indikator für Ausfälle.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "displayName": "Container Restarts",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(kube_pod_container_status_restarts_total{namespace='homeoffice'})",
        "legendFormat": "Total Restarts"
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["dsgvo", "compliance", "homeoffice", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "DSGVO Compliance Dashboard",
  "uid": "dsgvo-compliance",
  "version": 1
}
