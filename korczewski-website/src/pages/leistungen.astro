---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.svelte';

const categories = [
  {
    id: 'ki-beratung',
    title: 'KI-Beratung',
    icon: '\uD83E\uDDE0',
    description: 'KI ist kein Hexenwerk. Aber es gibt einen grossen Unterschied zwischen "mal ChatGPT ausprobiert" und "KI systematisch und sicher einsetzen". Ich zeige Ihnen den Unterschied.',
    services: [
      { name: 'Kennenlerngesprach', price: '20 \u20AC', unit: '/ 45 Min', desc: 'Wir sprechen uber Ihre Situation und finden heraus, wo KI Ihnen wirklich helfen kann. Keine Verkaufsshow.' },
      { name: 'KI-Einfuhrung Privat', price: '50 \u20AC', unit: '/ Stunde', desc: 'ChatGPT, Claude, lokale Modelle \u2013 was gibt es, was kostet es, was ist sicher? Praxisnahe Einfuhrung fur den Alltag.' },
      { name: 'KI-Strategie Geschaftlich', price: '50 \u20AC', unit: '/ Stunde', desc: 'Welche Prozesse lassen sich automatisieren? Wo lohnt sich KI, wo nicht? Datenschutzkonformer Einsatz im Unternehmen.' },
      { name: 'Prompt Engineering Workshop', price: '50 \u20AC', unit: '/ Stunde', desc: 'Die Kunst, KI die richtigen Fragen zu stellen. Fur Teams oder Einzelpersonen.' },
    ],
  },
  {
    id: 'software-dev',
    title: 'Software-Entwicklung mit KI',
    icon: '\uD83D\uDCBB',
    description: 'Sie mussen kein Informatiker sein, um mit KI Software zu bauen. Aber es hilft, jemanden an der Seite zu haben, der die Fallstricke kennt.',
    services: [
      { name: 'Einstieg in KI-gestutzte Entwicklung', price: '50 \u20AC', unit: '/ Stunde', desc: 'Wie man mit Claude Code, Cursor oder Copilot von der Idee zum funktionierenden Prototyp kommt.' },
      { name: 'Architektur-Beratung', price: '50 \u20AC', unit: '/ Stunde', desc: 'Die richtigen Entscheidungen treffen, bevor man Code schreibt. Technologie-Stack, Struktur, Skalierbarkeit.' },
      { name: 'Code-Review & Qualitat', price: '50 \u20AC', unit: '/ Stunde', desc: 'Bestehenden Code gemeinsam durchgehen. Testing, Security, Performance \u2013 die Dinge, die KI gerne ubersieht.' },
      { name: 'Pair Programming mit KI', price: '50 \u20AC', unit: '/ Stunde', desc: 'Wir entwickeln gemeinsam. Sie lernen dabei, wie man KI als Co-Pilot effektiv einsetzt.' },
    ],
  },
  {
    id: 'deployment',
    title: 'Deployment & Infrastruktur',
    icon: '\u2601\uFE0F',
    description: 'Code schreiben ist die halbe Miete. Ihn zuverlassig in Produktion zu bringen und dort zu halten \u2013 das ist die andere Halfte.',
    services: [
      { name: 'Kubernetes-Deployment', price: '50 \u20AC', unit: '/ Stunde', desc: 'Von Docker-Compose zu Kubernetes. Manifeste, Ingress, TLS, Monitoring \u2013 der ganze Stack.' },
      { name: 'Open-Source-Setup', price: '50 \u20AC', unit: '/ Stunde', desc: 'Nextcloud, Mattermost, Vaultwarden, Keycloak & mehr. Self-hosted, DSGVO-konform, unter Ihrer Kontrolle.' },
      { name: 'Wartung & Monitoring', price: '50 \u20AC', unit: '/ Stunde', desc: 'Updates, Backups, Alerting. Damit Sie ruhig schlafen konnen, wahrend Ihre Infrastruktur lauft.' },
      { name: 'Migration & Umzug', price: '50 \u20AC', unit: '/ Stunde', desc: 'Von der Cloud zum eigenen Server oder umgekehrt. Daten sicher migrieren, Downtime minimieren.' },
    ],
  },
];
---

<Layout title="Leistungen & Preise" description="KI-Beratung, Software-Entwicklung, Kubernetes-Deployment. Alle Leistungen und Preise auf einen Blick.">
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h1 class="text-4xl md:text-5xl font-bold text-light mb-4 font-serif">Leistungen & Preise</h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Klare Preise, kein Kleingedrucktes. 50 Euro die Stunde, fur alles. Kennenlerngesprach: 45 Minuten fur 20 Euro.
        </p>
      </div>

      <!-- Pricing highlight -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        <div class="bg-dark-light rounded-2xl p-8 border border-dark-lighter text-center">
          <p class="text-muted text-lg mb-2">Kennenlerngesprach</p>
          <p class="text-4xl font-bold text-gold mb-2">20 &euro;</p>
          <p class="text-muted">45 Minuten &middot; Bedarf erfassen & eingrenzen</p>
        </div>
        <div class="bg-dark-light rounded-2xl p-8 border-2 border-gold text-center">
          <p class="text-muted text-lg mb-2">Stundensatz</p>
          <p class="text-4xl font-bold text-gold mb-2">50 &euro;</p>
          <p class="text-muted">Alle Leistungen &middot; Fair & transparent</p>
        </div>
      </div>

      {categories.map((cat) => (
        <div id={cat.id} class="mb-16">
          <h2 class="text-2xl md:text-3xl font-bold text-light mb-3 font-serif">
            <span class="mr-3">{cat.icon}</span>{cat.title}
          </h2>
          <p class="text-lg text-muted mb-8 max-w-3xl">{cat.description}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {cat.services.map((svc) => (
              <div class="bg-dark-light rounded-xl p-6 border border-dark-lighter flex flex-col">
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-light mb-1">{svc.name}</h3>
                  <div class="mb-3">
                    <span class="text-2xl font-bold text-gold">{svc.price}</span>
                    <span class="text-muted-dark ml-2">{svc.unit}</span>
                  </div>
                  <p class="text-muted mb-4">{svc.desc}</p>
                </div>
                <a
                  href="/kontakt"
                  class="block text-center bg-gold hover:bg-gold-light text-dark px-6 py-3 rounded-full font-bold transition-colors uppercase tracking-wide text-sm"
                >
                  Anfragen
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="bg-dark-light rounded-2xl p-8 border border-dark-lighter">
        <h3 class="text-xl font-bold text-light mb-3 font-serif">Hinweis zur Umsatzsteuer</h3>
        <p class="text-muted">
          Alle Preise sind Endpreise. Gemass &sect; 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet (Kleinunternehmerregelung).
        </p>
      </div>
    </div>
  </section>

  <CallToAction client:visible />
</Layout>
