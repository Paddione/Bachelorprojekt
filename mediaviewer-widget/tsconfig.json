{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@videovault-player": ["../packages/videovault-player/src"],
      "@videovault-player/*": ["../packages/videovault-player/src/*"]
    }
  },
  "include": ["src/**/*"]
}
