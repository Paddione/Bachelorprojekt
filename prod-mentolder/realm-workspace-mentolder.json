      "username": "paddione",
      "enabled": true,
      "emailVerified": true,
      "email": "${KC_USER1_EMAIL}",
      "firstName": "Patrick",
      "lastName": "Korczewski",
      "realmRoles": [
        "default-roles-workspace"
      ],
      "clientRoles": {
        "realm-management": [
          "realm-admin"
        ]
