#!/usr/bin/env python3
import sys, json, re

data = json.load(sys.stdin)
args = sys.argv[1:]

# Process args to extract filter and flags
filters = []
flags = {'raw': False, 'compact': False, 'null_input': False, 'arg': {}, 'argjson': {}}
i = 0
while i < len(args):
    a = args[i]
    if a == '-r':
        flags['raw'] = True
        i += 1
    elif a == '-c':
        flags['compact'] = True
        i += 1
    elif a == '-n':
        flags['null_input'] = True
        i += 1
    elif a == '--arg' and i + 2 < len(args):
        flags['arg'][args[i+1]] = args[i+2]
        i += 3
    elif a == '--argjson' and i + 2 < len(args):
        flags['argjson'][args[i+1]] = json.loads(args[i+2])
        i += 3
    else:
        filters.append(a)
        i += 1

filter_str = ' '.join(filters)

if flags['null_input']:
    data = {}

# Substitute $name with arg values in filter
def subst(m):
    name = m.group(1)
    if name in flags['arg']:
        return json.dumps(flags['arg'][name])
    if name in flags['argjson']:
        return json.dumps(flags['argjson'][name])
    return m.group(0)

filter_str = re.sub(r'\$(\w+)', subst, filter_str)

def eval_filter(d, f):
    """Simple jq filter evaluation."""
    # Remove outer quotes
    f = f.strip().strip("'")

    # .[] iterates arrays
    if f == '[]' or f == '.[]':
        if isinstance(d, list):
            return d
        return []

    # .[0], .[1] etc
    m = re.match(r'^\.\[(\d+)\]$', f)
    if m:
        idx = int(m.group(1))
        if isinstance(d, list) and idx < len(d):
            return d[idx]
        return None

    # .key or .key1.key2
    parts = f.split('.')
    result = d
    for part in parts:
        if not part:
            continue
        # handle [idx] in path
        arr_match = re.match(r'^(\w+)\[(\d+)\]$', part)
        if arr_match:
            result = result.get(arr_match.group(1), None)
            if result and isinstance(result, list) and int(arr_match.group(2)) < len(result):
                result = result[int(arr_match.group(2))]
            else:
                result = None
            continue
        if isinstance(result, dict):
            result = result.get(part, None)
        else:
            return None

    return result

def do_filter(d, f_expr):
    """Apply a filter expression and return result."""
    # Handle // default operator
    if '//' in f_expr:
        parts = f_expr.split('//')
        for p in parts:
            p = p.strip()
            if p == 'null' or not p:
                continue
            result = eval_filter(d, p)
            if result is not None:
                return result
        return parts[-1].strip().strip("'").strip('"') if parts else None

    # Handle . + [{"key":$var}] construction
    if '+ [' in f_expr:
        # This constructs a new array. Extract the object parts.
        # Simple case: just return d (the caller builds the output)
        return d

    return eval_filter(d, f_expr)

if filter_str.startswith('{') or filter_str.startswith('['):
    # Complex construction, try simple eval
    try:
        result = eval(filter_str, {"__builtins__": {}}, {"data": data, **flags['arg'], **flags['argjson']})
    except:
        # Fallback: try to see if there's a simpler pattern
        if flags['null_input']:
            # Construct JSON
            result = data
            # Simple heuristics for known patterns
            if 'launch' in filter_str and 'skipped' in filter_str:
                result = {"launch": data.get("launch", []), "skipped": data.get("skipped", [])}
        else:
            result = data
else:
    result = do_filter(data, filter_str)

def iter_items(d):
    if isinstance(d, list):
        for item in d:
            if isinstance(item, dict) and item:
                out = {}
                for k, v in item.items():
                    if isinstance(v, str):
                        out[k] = v
                    else:
                        out[k] = v
                yield json.dumps(out, ensure_ascii=False)
            else:
                yield json.dumps(item, ensure_ascii=False)

if filter_str == '[]' or filter_str == '.[]':
    for item in iter_items(data):
        print(item)
elif isinstance(result, list):
    for item in result:
        if flags['raw'] and isinstance(item, str):
            print(item)
        else:
            print(json.dumps(item, ensure_ascii=False))
elif result is None:
    sys.exit(4)  # jq exit code for null
else:
    if flags['raw'] and isinstance(result, str):
        print(result, end='')
        if not flags['compact']:
            print()
    else:
        print(json.dumps(result, ensure_ascii=False))
