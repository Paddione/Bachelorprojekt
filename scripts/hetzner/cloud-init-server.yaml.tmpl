#cloud-config
# Hetzner k3s SERVER (control-plane) bootstrap
# Rendered by: scripts/hetzner/render-cloud-init.sh --template scripts/hetzner/cloud-init-server.yaml.tmpl
#
# First CP node (cluster-init):   omit --k3s-url (or pass empty) → triggers --cluster-init
# Additional CP nodes (HA join):  --k3s-url https://<first-cp-ip>:6443
#
# Variables: NODE_IP, NODE_WG_IP, K3S_VERSION, K3S_URL, K3S_TOKEN,
#            SSH_PUBLIC_KEY, WG_CONF_B64, WG_LISTEN_PORT

package_update: true
package_upgrade: false
package_reboot_if_required: false

packages:
  - open-iscsi
  - wireguard
  - ufw
  - curl
  - jq
  - apt-transport-https

ssh_authorized_keys:
  - ${SSH_PUBLIC_KEY}

write_files:
  # WireGuard mesh config (base64-encoded; generated by scripts/hetzner/generate-wg-conf.sh)
  - path: /etc/wireguard/wg0.conf
    encoding: b64
    permissions: "0600"
    content: ${WG_CONF_B64}

  # k3s server config — flannel over WireGuard; public IP + WG IP in TLS SAN
  - path: /etc/rancher/k3s/config.yaml
    content: |
      node-ip: "${NODE_IP}"
      flannel-iface: "wg0"
      tls-san:
        - "${NODE_IP}"
        - "${NODE_WG_IP}"

runcmd:
  # iscsid — required by Longhorn for iSCSI volume attach
  - systemctl enable iscsid
  - systemctl start iscsid

  # Firewall — default deny; allow management + cluster + WireGuard + etcd
  - ufw default deny incoming
  - ufw default allow outgoing
  - ufw allow 22/tcp comment 'SSH'
  - ufw allow 80/tcp comment 'HTTP'
  - ufw allow 443/tcp comment 'HTTPS'
  - ufw allow 6443/tcp comment 'k3s API'
  - ufw allow 10250/tcp comment 'kubelet'
  - ufw allow ${WG_LISTEN_PORT}/udp comment 'WireGuard mesh'
  - ufw allow 8472/udp comment 'Flannel VXLAN'
  - ufw allow 2379:2380/tcp comment 'etcd client+peer'
  - ufw allow 50000:60000/udp comment 'LiveKit ICE'
  - ufw allow 30000:40000/udp comment 'LiveKit TURN'
  - ufw allow 21115/tcp comment 'RustDesk hbbs NAT test'
  - ufw allow 21116/tcp comment 'RustDesk hbbs ID/punch (TCP)'
  - ufw allow 21116/udp comment 'RustDesk hbbs ID/heartbeat (UDP)'
  - ufw allow 21117/tcp comment 'RustDesk hbbr relay'
  - ufw --force enable

  # WireGuard — bring up mesh interface
  - systemctl enable wg-quick@wg0
  - systemctl start wg-quick@wg0

  # k3s server install — cluster-init when K3S_URL is empty, join when set
  - |
    K3S_URL="${K3S_URL}"
    if [ -n "$K3S_URL" ]; then
      INSTALL_K3S_VERSION="${K3S_VERSION}" K3S_URL="$K3S_URL" K3S_TOKEN="${K3S_TOKEN}" \
        curl -sfL https://get.k3s.io | sh -s - server
    else
      INSTALL_K3S_VERSION="${K3S_VERSION}" K3S_TOKEN="${K3S_TOKEN}" \
        curl -sfL https://get.k3s.io | sh -s - server --cluster-init
    fi

final_message: |
  k3s server ${NODE_IP} (wg: ${NODE_WG_IP}) bootstrapped.
