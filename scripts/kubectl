#!/usr/bin/env bash
# Stub for kubectl that returns mock data for factory-prep dry-run
# Put scripts/ on PATH first to use this instead of the real kubectl
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Handle get pod -l 'app in (shared-db, shared-db-dev)' -o name
if [[ "$*" == *"get pod"* && "$*" == *"shared-db"* ]]; then
  echo "pod/shared-db-0"
  exit 0
fi

# Handle psql queries - return empty results
if [[ "$*" == *"psql"* ]]; then
  # Return empty output (no rows) which means:
  # - killswitch: no rows → OFF
  # - daily deploy count: no rows → 0 → not reached
  # - stale tickets: no rows → nothing to escalate
  # - queue: empty array
  exit 0
fi

# For unsupported commands, exit 0 to avoid errors
exit 0
