# ── Mattermost ──────────────────────────────────────────
# Incoming webhook for simple posts (contact form fallback)
MATTERMOST_WEBHOOK_URL=http://mattermost.workspace.svc.cluster.local:8065/hooks/your-webhook-id
MATTERMOST_CHANNEL=anfragen

# Mattermost API URL + bot token (for interactive messages)
MATTERMOST_URL=http://mattermost.workspace.svc.cluster.local:8065
MATTERMOST_BOT_TOKEN=your-bot-token

# ── Keycloak ────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak.workspace.svc.cluster.local:8080
KEYCLOAK_REALM=workspace
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=devadmin

# ── SMTP (Mailpit in dev, real SMTP in prod) ────────────
SMTP_HOST=mailpit.workspace.svc.cluster.local
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=info@mentolder.de
FROM_NAME=mentolder.de

# ── OIDC (Keycloak client for login) ────────────────────
WEBSITE_OIDC_SECRET=devwebsiteoidcsecret12345

# ── Site ────────────────────────────────────────────────
SITE_URL=http://web.localhost
