# ── Keycloak ────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak.workspace.svc.cluster.local:8080
KEYCLOAK_REALM=workspace
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=devadmin

# ── SMTP (Mailpit in dev, real SMTP in prod) ────────────
SMTP_HOST=mailpit.workspace.svc.cluster.local
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=info@yourdomain.tld
FROM_NAME=yourbrand.tld

# ── OIDC (Pocket ID client for login) ───────────────────
# Required — the server refuses to boot without it (T001593).
# Dev value matches k3d/website-dev-secrets.yaml.
POCKET_ID_WEBSITE_SECRET=devwebsitepocketidsecret123456

# ── External services (portal Dienste section) ──────────
NEXTCLOUD_EXTERNAL_URL=http://files.localhost
VAULT_EXTERNAL_URL=http://vault.localhost
WHITEBOARD_EXTERNAL_URL=http://board.localhost
AUTH_EXTERNAL_URL=http://auth.localhost
KEYCLOAK_FRONTEND_URL=http://auth.localhost

# ── Site ────────────────────────────────────────────────
SITE_URL=http://web.localhost
