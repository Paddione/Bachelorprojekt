---
import type { DaySlots } from '../lib/caldav';

interface Props {
  day: DaySlots;
}

const { day } = Astro.props;

const dateFormatted = new Date(day.date + 'T12:00:00').toLocaleDateString('de-DE', {
  weekday: 'short', day: '2-digit', month: 'long',
});
---

<div class="availability" data-testid="slot-widget">
  <div class="avail-row">
    <span class="pulse" aria-hidden="true"></span>
    <div>
      <p class="avail-title">Nächste freie Termine</p>
      <p class="avail-sub" data-testid="slot-widget-heading">
        {dateFormatted} · kostenloses Erstgespräch (30 Min.)
      </p>
    </div>
  </div>
  <div class="avail-slots">
    {day.slots.slice(0, 4).map((slot) => {
      const parts = slot.display.split(' - ');
      const [startHH, startMM] = (parts[0] ?? '').split(':');
      const [endHH, endMM] = (parts[1] ?? '').split(':');
      const href = `/termin?date=${day.date}&start=${startHH ?? '00'}:${startMM ?? '00'}&end=${endHH ?? '00'}:${endMM ?? '00'}`;
      const timeOnly = parts[0] ?? slot.display;
      return (
        <a
          href={href}
          data-testid="slot-pill"
          class="slot-pill"
          aria-label={`Termin um ${slot.display} buchen`}
        >
          {timeOnly}
        </a>
      );
    })}
    <a href="/termin" class="slot-pill slot-pill-all" aria-label="Alle Termine anzeigen">
      → alle Termine
    </a>
  </div>
</div>

<style>
  .availability {
    padding: 32px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
  }

  .avail-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .pulse {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--sage);
    box-shadow: 0 0 0 0 oklch(0.80 0.06 160 / .6);
    animation: pulse 2.2s infinite;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .avail-title {
    font-weight: 600;
    color: var(--fg);
    font-size: 15px;
    margin: 0 0 2px;
  }

  .avail-sub {
    color: var(--mute);
    font-size: 14px;
    margin: 0;
  }

  .avail-slots {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .slot-pill {
    font-family: var(--mono);
    font-size: 12px;
    padding: 7px 12px;
    border: 1px solid var(--line-2);
    border-radius: 999px;
    color: var(--fg-soft);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .slot-pill:hover {
    border-color: var(--brass);
    color: var(--brass);
  }

  .slot-pill-all {
    color: var(--mute);
  }

  @media (max-width: 640px) {
    .availability {
      padding: 24px 22px;
    }
  }
</style>
