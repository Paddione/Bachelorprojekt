---
import { icons } from '../../layouts/admin-icons';

interface Props {
  brandWord: string;
  isKore: boolean;
  inboxPending: number;
  brettUrl: string;
  path: string;
}

const { inboxPending, brettUrl, path } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: string;
  matches?: string[];
  badge?: number;
  external?: boolean;
}

const werkstattItems: NavItem[] = [
  { href: '/admin/inhalte',                       label: 'Content Hub',  icon: 'layout', matches: ['/admin/inhalte', '/admin/startseite', '/admin/uebermich', '/admin/angebote', '/admin/faq', '/admin/kontakt', '/admin/referenzen', '/admin/rechtliches', '/admin/dokumente'] },
  { href: '/admin/wissen',                        label: 'Wissensbasis', icon: 'book',  matches: ['/admin/wissen', '/admin/wissensquellen', '/admin/knowledge', '/admin/knowledge/drafts', '/admin/knowledge/templates'] },
  { href: '/admin/assets',                        label: 'Assets',       icon: 'palette' },
  { href: '/admin/asset-generation',              label: '3D Generator', icon: 'edit' },
  { href: '/admin/app-catalog',                   label: 'App-Katalog',  icon: 'plus' },
  { href: '/admin/ki-konfiguration',              label: 'KI-Konfig.',   icon: 'cpu', matches: ['/admin/ki-konfiguration'] },
  { href: '/admin/prompts',                       label: 'Prompts',      icon: 'book' },
  { href: '/admin/systemtest/board',              label: 'Systemtest',   icon: 'bug' },
  { href: '/admin/content-db',                    label: 'Content-DB',   icon: 'layout' },
];

const navSections: { label?: string; items: NavItem[]; accordion?: boolean }[] = [
  {
    items: [
      { href: '/admin',          label: 'Dashboard',  icon: 'dashboard' },
      { href: '/admin/cockpit',  label: 'Cockpit',    icon: 'tag', matches: ['/admin/cockpit', '/admin/tickets', '/admin/bugs'] },
      { href: '/admin/inbox',    label: 'Postfach',   icon: 'inbox', badge: inboxPending },
    ],
  },
  {
    label: 'Geschäft',
    items: [
      { href: '/admin/clients',             label: 'Klienten',    icon: 'users' },
      { href: '/admin/coaching/studio',     label: 'Studio',     icon: 'clipboard', matches: ['/admin/coaching/studio', '/admin/fragebogen'] },
      { href: '/admin/coaching/sessions', label: 'Sessions',   icon: 'clipboard', matches: ['/admin/coaching/sessions'] },
      { href: '/admin/rechnungen',          label: 'Fakturierung', icon: 'receipt', matches: ['/admin/rechnungen', '/admin/billing'] },
    ],
  },
  {
    label: 'Werkstatt',
    accordion: true,
    items: werkstattItems,
  },
  {
    label: 'Infrastruktur',
    items: [
      { href: '/admin/pipeline', label: 'Pipeline', icon: 'activity', matches: ['/admin/pipeline', '/dev-status'] },
      { href: '/admin/einstellungen/benachrichtigungen', label: 'Einstellungen', icon: 'settings', matches: ['/admin/einstellungen/'] },
      { href: brettUrl,                               label: 'Systembrett',  icon: 'brett', external: true },
      { href: '/admin/live',                          label: 'Live-Stream',  icon: 'broadcast', matches: ['/admin/live', '/admin/stream'] },
    ],
  },
];

function isActive(href: string, matches?: string[]): boolean {
  if (matches) return matches.some(m => path === m || path.startsWith(m));
  return path.startsWith(href);
}

const werkstattActive = werkstattItems.some(i => isActive(i.href, i.matches));
---

<nav style="flex:1; overflow-y:auto; padding:16px 0; display:flex; flex-direction:column;">
  {navSections.map((section, si) => (
    <div class="sidebar-group">
      {section.label ? (
        section.accordion ? (
          <>
            <button
              class="sidebar-group-btn"
              id="werkstatt-toggle"
              aria-expanded={werkstattActive}
              aria-controls="werkstatt-items"
            >
              <span>{section.label}</span>
              <span class="accordion-arrow" aria-hidden="true">{werkstattActive ? '▼' : '▶'}</span>
            </button>
            <div
              class="werkstatt-items"
              id="werkstatt-items"
              class:list={{ 'is-collapsed': !werkstattActive }}
            >
              {section.items.map(item => (
                <a
                  href={item.href}
                  class:list={[
                    'sidebar-nav-item',
                    { 'is-active': isActive(item.href, item.matches) }
                  ]}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  title={item.label}
                >
                  <span class="nav-icon" set:html={icons[item.icon]} />
                  <span class="sidebar-label" style="margin-left:12px; flex:1;">{item.label}</span>
                  {item.badge ? (
                    <span class="sidebar-label" style="padding:2px 6px; border-radius:6px; background:var(--admin-primary); color:var(--admin-bg); font-size:10px; font-weight:800;">{item.badge}</span>
                  ) : null}
                </a>
              ))}
            </div>
          </>
        ) : (
          <p class="sidebar-group-label">{section.label}</p>
        )
      ) : null}
      {!section.accordion ? section.items.map(item => (
        <a
          href={item.href}
          class:list={[
            'sidebar-nav-item',
            { 'is-active': isActive(item.href, item.matches) }
          ]}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener noreferrer' : undefined}
          title={item.label}
        >
          <span class="nav-icon" set:html={icons[item.icon]} />
          <span class="sidebar-label" style="margin-left:12px; flex:1;">{item.label}</span>
          {item.badge ? (
            <span class="sidebar-label" style="padding:2px 6px; border-radius:6px; background:var(--admin-primary); color:var(--admin-bg); font-size:10px; font-weight:800;">{item.badge}</span>
          ) : null}
        </a>
      )) : null}
      {si < navSections.length - 1 ? (
        <div style="height:1px; background:var(--admin-border); margin:8px 16px;" aria-hidden="true"></div>
      ) : null}
    </div>
  ))}
</nav>

<script>
  const toggle = document.getElementById('werkstatt-toggle');
  const container = document.getElementById('werkstatt-items');
  if (toggle && container) {
    toggle.addEventListener('click', () => {
      const collapsed = container.classList.toggle('is-collapsed');
      toggle.setAttribute('aria-expanded', String(!collapsed));
      const arrow = toggle.querySelector('.accordion-arrow');
      if (arrow) arrow.textContent = collapsed ? '▶' : '▼';
    });
  }
</script>

<style>
  .werkstatt-items.is-collapsed { display: none; }
  .sidebar-group-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 8px 16px;
    background: none;
    border: none;
    color: var(--admin-text-mute, #888);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
  }
  .sidebar-group-btn:hover {
    color: var(--admin-text, #eee);
  }
  .accordion-arrow {
    font-size: 0.5rem;
    transition: transform 0.2s;
  }
</style>