---
import { getSession } from '../../lib/auth';

const { active = 'work', subpage = false } = Astro.props as { active?: string; subpage?: boolean };
const session = await getSession(Astro.request.headers.get('cookie'));
const links = [
  { id: 'work',     label: 'Cluster' },
  { id: 'services', label: 'Leistungen' },
  { id: 'team',     label: 'Über mich' },
  { id: 'timeline', label: 'Notizen' },
  { id: 'contact',  label: 'Kontakt' },
];
---

<nav class="web-nav" aria-label="Hauptnavigation">
  <a class="shell-brand" href="/">
    <img src="/brand/korczewski/kore-assets/logo-mark.svg" width="28" height="28" alt="Kore" />
    <span style="font-family:var(--serif); font-size:22px;">
      Kore<span style="color:var(--copper)">.</span>
    </span>
  </a>
  <div class="links">
    {links.map(({id, label}) => (
      <a href={id === 'contact' ? '/kontakt' : subpage ? `/#${id}` : `#${id}`} class={active === id ? 'active' : ''}>{label}</a>
    ))}
  </div>
  <div class="actions">
    {session ? (
      <a class="btn primary sm" href="/portal">Portal →</a>
    ) : (
      <a class="btn primary sm" href="/api/auth/login?returnTo=/portal">Anmelden →</a>
    )}
  </div>
</nav>
