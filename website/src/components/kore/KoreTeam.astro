---
import { config } from '../../config/index';

const { contact, legal } = config;

const contactName = contact.name || 'Patrick Korczewski';
const contactCity = contact.city || 'Lüneburg';
const legalWebsite = legal.website || 'korczewski.de';
---

<section class="w-section" id="team">
  <div class="head">
    <span class="num">04 / 04</span>
    <h2>Eine Person <em class="em">macht die Arbeit.</em></h2>
    <span class="hint">Solo · seit 2021 · {contactCity}</span>
  </div>

  <div class="w-team">
    <div class="who">
      <figure class="portrait">
        <img
          src="/brand/korczewski/kore-assets/portrait-placeholder.svg"
          alt={`Portrait-Platzhalter — ${contactName}. Aufnahme folgt.`}
          loading="lazy"
          decoding="async"
          width="400"
          height="500"
        />
        <figcaption class="id"><b>{contactName}</b><br/>Operator · {contactCity}</figcaption>
      </figure>
    </div>
    <div class="bio-col">
      <span class="role">Operator · founder</span>
      <h3>Patrick <em class="em">Korczewski</em></h3>
      <p class="bio">
        Bachelor in IT-Sicherheit, 10+ Jahre IT-Management — Server, Netze, Helpdesk, Strategie.
        Und seit dem ersten Tag von ChatGPT KI in produktivem Einsatz, nicht im Demo-Modus.
      </p>
      <p class="bio">
        Baut Systeme, die laufen. Self-Hosted Open-Source, DSGVO-konform, multi-cluster Kubernetes.
        Zeigt es lieber, als darüber zu schreiben.
      </p>
      <dl class="credits">
        <dt>Studium</dt><dd>B.Sc. <em class="em">IT-Sicherheit</em></dd>
        <dt>Jetzt</dt><dd>Betreibt <em class="em">mentolder.de</em>, <em class="em">korczewski.de</em>, diverse Self-Hosted-Stacks</dd>
        <dt>Spricht</dt><dd>Deutsch, Englisch</dd>
        <dt>Findet man</dt><dd><a href={`https://${legalWebsite}`} target="_blank" rel="noopener">{legalWebsite}</a></dd>
      </dl>
    </div>
  </div>
</section>

<style>
  .w-team {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    align-items: start;
    margin-top: 48px;
  }

  .portrait {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
    padding: 0;
    max-width: 320px;
  }

  .portrait img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 30px 80px -30px rgba(15, 8, 28, 0.7);
  }

  .id {
    font-size: 14px;
    color: var(--mute);
    line-height: 1.6;
    font-family: var(--sans);
  }

  .id b {
    color: var(--fg);
    font-weight: 500;
  }

  .bio-col {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .role {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper, #b87333);
    margin-bottom: 10px;
    display: block;
  }

  .bio-col h3 {
    font-family: var(--serif);
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px;
    color: var(--fg);
  }

  .bio {
    font-size: 15px;
    line-height: 1.75;
    color: var(--fg-soft, var(--mute));
    margin: 0 0 14px;
  }

  .credits {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 20px;
    margin-top: 28px;
    font-size: 14px;
  }

  .credits dt {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--mute);
    padding-top: 2px;
  }

  .credits dd {
    color: var(--fg);
    margin: 0;
    line-height: 1.6;
  }

  .credits a {
    color: var(--copper, #b87333);
    text-decoration: none;
  }

  .credits a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .w-team {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .portrait {
      max-width: 240px;
    }
  }
</style>
