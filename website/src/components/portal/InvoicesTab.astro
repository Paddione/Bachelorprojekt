---
import { getCustomerInvoices, SERVICES } from '../../lib/stripe-billing';
import type { BillingInvoice } from '../../lib/stripe-billing';
import CreateInvoiceModal from '../admin/CreateInvoiceModal.svelte';

interface Props {
  clientEmail: string;
}
const { clientEmail } = Astro.props;

const serviceOptions = Object.entries(SERVICES).map(([key, val]) => ({
  key,
  name: val.name,
  cents: val.cents,
}));

let invoices: BillingInvoice[] = [];
try {
  invoices = await getCustomerInvoices(clientEmail);
} catch {
  // Stripe unavailable
}

function formatCurrency(amount: number): string {
  return new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR' }).format(amount);
}

function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

function statusColor(status: string): string {
  switch (status) {
    case 'paid':          return 'bg-green-500/20 text-green-400';
    case 'open':          return 'bg-accent/20 text-accent';
    case 'uncollectible': return 'bg-red-500/20 text-red-400';
    case 'void':          return 'bg-dark-lighter text-muted';
    default:              return 'bg-dark-lighter text-muted';
  }
}
---

<div data-testid="invoices-tab">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-light">Ihre Rechnungen</h3>
    <CreateInvoiceModal
      {serviceOptions}
      prefillEmail={clientEmail}
      buttonLabel="+ Rechnung stellen"
      buttonVariant="ghost"
      client:load
    />
  </div>

  {invoices.length === 0 ? (
    <p class="text-muted">Keine Rechnungen vorhanden.</p>
  ) : (
    <ul class="space-y-2">
      {invoices.map(inv => (
        <li class="flex items-center gap-3 p-3 bg-dark rounded-lg border border-dark-lighter" data-testid="invoice-item">
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <span class="text-light font-medium">#{inv.number}</span>
              <span class={`text-xs px-2 py-0.5 rounded-full ${statusColor(inv.status)}`}>
                {inv.statusLabel}
              </span>
            </div>
            <div class="text-sm text-muted mt-1">
              {formatDate(inv.date)}
              {inv.dueDate && inv.status !== 'paid' && (
                <span> &middot; Faellig: {formatDate(inv.dueDate)}</span>
              )}
            </div>
          </div>
          <div class="text-right">
            <div class="text-light font-medium">{formatCurrency(inv.amountDue)}</div>
            {inv.amountRemaining > 0 && inv.amountRemaining !== inv.amountDue && (
              <div class="text-xs text-muted">Offen: {formatCurrency(inv.amountRemaining)}</div>
            )}
            {inv.hostedUrl && inv.status !== 'paid' && (
              <a href={inv.hostedUrl} target="_blank" rel="noopener"
                 class="mt-1 inline-block text-xs text-blue-400 hover:underline">
                Jetzt zahlen ↗
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
  )}
</div>

<script>
  document.addEventListener('invoice-created', () => window.location.reload());
</script>
