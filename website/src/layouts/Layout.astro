---
import Navigation from '../components/Navigation.svelte';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Digital Coach & Fuhrungskrafte-Mentor - Ihr Partner fur digitale Kompetenz und personliche Entwicklung' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title} | mentolder.de</title>
  </head>
  <body class="min-h-screen flex flex-col bg-dark text-light">
    <Navigation client:load />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="bg-dark border-t border-dark-lighter py-12">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <h3 class="text-lg font-semibold text-gold mb-4">Kontakt</h3>
            <p class="text-muted mb-2">+49 151 508 32 601</p>
            <p class="text-muted mb-2">info@mentolder.de</p>
            <p class="text-muted">Luneburg und Umgebung</p>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gold mb-4">Angebote</h3>
            <ul class="space-y-2 text-muted">
              <li><a href="/digital-cafe" class="hover:text-gold transition-colors">Digital Cafe 50+</a></li>
              <li><a href="/coaching" class="hover:text-gold transition-colors">Fuhrungskrafte-Coaching</a></li>
              <li><a href="/beratung" class="hover:text-gold transition-colors">Unternehmensberatung</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-gold mb-4">Rechtliches</h3>
            <ul class="space-y-2 text-muted">
              <li><a href="/impressum" class="hover:text-gold transition-colors">Impressum</a></li>
              <li><a href="/datenschutz" class="hover:text-gold transition-colors">Datenschutz</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-dark-lighter pt-8 text-center text-muted-dark text-sm">
          <p>&copy; {new Date().getFullYear()} mentolder.de - Alle Rechte vorbehalten</p>
        </div>
      </div>
    </footer>
  </body>
</html>
