---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wartungsarbeiten">
  <section class="pt-28 pb-24">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p style="font-family:var(--mono); font-size:12px; letter-spacing:0.22em; text-transform:uppercase; color:var(--brass); margin:0 0 24px;">
        Wartung
      </p>
      <h1 style="font-family:var(--serif); font-size:clamp(2.75rem, 8vw, 5rem); color:var(--fg); line-height:1.08; letter-spacing:-0.01em; margin:0 0 24px;">
        Wir befinden uns derzeit in Wartungsarbeiten.
      </h1>
      <p style="font-size:18px; color:var(--fg-soft); line-height:1.65; margin:0 0 24px;">
        Dienste werden in Kürze wieder erreichbar sein.
      </p>
      <p style="font-size:14px; color:var(--fg-muted, var(--fg-soft)); line-height:1.65;">
        In dringenden Fällen wenden Sie sich bitte an die Telefonnummer im <a href="/impressum" style="color:var(--brass); text-decoration:none;">Impressum</a>.
      </p>
    </div>
  </section>
</Layout>
