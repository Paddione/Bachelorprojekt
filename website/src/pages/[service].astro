---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.svelte';
import FAQ from '../components/FAQ.svelte';
import { getEffectiveServices } from '../lib/content';
import { config } from '../config/index';

const BRAND_ID = process.env.BRAND_ID ?? process.env.BRAND ?? 'mentolder';
const layoutBrand = BRAND_ID === 'korczewski' ? 'korczewski-kore' : undefined;

const { service } = Astro.params;
const { contact } = config;
const allServices = await getEffectiveServices();
const visibleServices = allServices.filter((s) => !s.hidden);
const svcIndex = visibleServices.findIndex((s) => s.slug === service);
const svc = svcIndex !== -1 ? visibleServices[svcIndex] : null;

if (!svc) {
  return Astro.redirect('/404');
}

const pc = svc.pageContent;
const prevSvc = svcIndex > 0 ? visibleServices[svcIndex - 1] : null;
const nextSvc = svcIndex < visibleServices.length - 1 ? visibleServices[svcIndex + 1] : null;
---

<Layout title={svc.title} description={svc.description} brand={layoutBrand}>
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-4xl mx-auto px-6">
      <nav class="mb-6" aria-label="Breadcrumb">
        <a href="/leistungen" class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-gold transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Leistungen
        </a>
      </nav>
      <p class="text-gold font-semibold text-lg mb-4 tracking-widest uppercase">{svc.title}</p>
      <h1 class="text-4xl md:text-5xl font-bold text-light leading-tight mb-6 font-serif">{pc.headline}</h1>
      <p class="text-xl text-muted leading-relaxed max-w-3xl">{pc.intro}</p>
    </div>
  </section>

  <section class="py-16 bg-dark-light">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-8 font-serif">Für wen ist das?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {pc.forWhom.map((item) => (
          <div class="flex items-start gap-4 p-5 bg-dark rounded-xl border border-dark-lighter">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <p class="text-lg text-muted">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {pc.sections.length > 0 && (
    <section class="py-16 bg-dark">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-light mb-10 font-serif">Leistungsumfang</h2>
        <div class={`grid grid-cols-1 ${pc.sections.length >= 3 ? 'md:grid-cols-3' : 'md:grid-cols-2'} gap-8`}>
          {pc.sections.map((sec) => (
            <div class="bg-dark-light rounded-xl p-6 border border-dark-lighter">
              <h3 class="text-xl font-bold text-gold mb-4">{sec.title}</h3>
              <ul class="space-y-2 text-muted">{sec.items.map((i) => <li>{i}</li>)}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-16 bg-dark-light">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-10 text-center font-serif">Investition</h2>
      <div class={`grid grid-cols-1 ${pc.pricing.length <= 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'} gap-6 max-w-3xl mx-auto`}>
        {pc.pricing.map((p) => (
          <div class={`bg-dark-light rounded-xl p-6 text-center ${p.highlight ? 'border-2 border-gold' : 'border border-dark-lighter'}`}>
            <p class="text-muted mb-2">{p.label}</p>
            <p class="text-3xl font-bold text-gold">{p.price}</p>
            {p.unit && <p class="text-muted">{p.unit}</p>}
          </div>
        ))}
      </div>
      <p class="text-center text-muted mt-8 text-lg">Kostenloses Erstgespräch zum Kennenlernen!</p>
    </div>
  </section>

  {pc.faq && pc.faq.length > 0 && (
    <FAQ items={pc.faq} title={`Häufige Fragen zu ${svc.title}`} client:visible />
  )}

  {(prevSvc || nextSvc) && (
    <section class="py-10 bg-dark border-t border-dark-lighter">
      <div class="max-w-4xl mx-auto px-6 flex items-center justify-between gap-4">
        {prevSvc ? (
          <a href={`/${prevSvc.slug}`} class="flex items-center gap-2 text-muted hover:text-gold transition-colors group">
            <svg class="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span class="text-sm font-medium">{prevSvc.title}</span>
          </a>
        ) : <span />}
        <a href="/leistungen" class="text-xs font-semibold text-muted uppercase tracking-widest hover:text-gold transition-colors">
          Alle Leistungen
        </a>
        {nextSvc ? (
          <a href={`/${nextSvc.slug}`} class="flex items-center gap-2 text-muted hover:text-gold transition-colors group">
            <span class="text-sm font-medium">{nextSvc.title}</span>
            <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <span />}
      </div>
    </section>
  )}

  <CallToAction client:visible secondaryText={contact.email} secondaryHref={`mailto:${contact.email}`} />
</Layout>
