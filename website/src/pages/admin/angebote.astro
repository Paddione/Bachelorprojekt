---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../lib/auth';
import { getServiceConfig, getLeistungenConfig, getSiteSetting } from '../../lib/website-db';
import { mentolderConfig } from '../../config/brands/mentolder';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');

const BRAND = process.env.BRAND || 'mentolder';
const saved = Astro.url.searchParams.get('saved') === '1';

const [dbOverrides, dbLeistungen, priceListUrl] = await Promise.all([
  getServiceConfig(BRAND).catch(() => null),
  getLeistungenConfig(BRAND).catch(() => null),
  getSiteSetting(BRAND, 'price_list_url').catch(() => null),
]);

// Merge service card + pageContent overrides
const services = mentolderConfig.services.map(s => {
  const o = dbOverrides?.find(x => x.slug === s.slug);
  const pc = o?.pageContent;
  return {
    slug: s.slug,
    title: o?.title ?? s.title,
    description: o?.description ?? s.description,
    icon: o?.icon ?? s.icon,
    price: o?.price ?? s.price,
    features: o?.features ?? s.features,
    hidden: o?.hidden ?? false,
    pageContent: {
      headline: pc?.headline ?? s.pageContent.headline,
      intro: pc?.intro ?? s.pageContent.intro,
      forWhom: pc?.forWhom ?? s.pageContent.forWhom,
      sections: pc?.sections ?? s.pageContent.sections,
      pricing: pc?.pricing ?? s.pageContent.pricing,
      faq: pc?.faq ?? s.pageContent.faq,
    },
  };
});

// Merge leistungen overrides
const leistungen = mentolderConfig.leistungen.map(cat => {
  const o = dbLeistungen?.find(x => x.id === cat.id);
  return {
    id: cat.id,
    title: o?.title ?? cat.title,
    icon: o?.icon ?? cat.icon,
    services: cat.services.map(svc => {
      const so = o?.services?.find(x => x.key === svc.key);
      return {
        key: svc.key,
        name: so?.name ?? svc.name,
        price: so?.price ?? svc.price,
        unit: so?.unit ?? svc.unit,
        desc: so?.desc ?? svc.desc,
        highlight: so?.highlight ?? svc.highlight,
      };
    }),
  };
});

const inputCls = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:outline-none focus:border-gold/50';
const labelCls = 'block text-xs text-muted mb-1';
const sectionCls = 'p-6 bg-dark-light rounded-xl border border-dark-lighter space-y-4';
---

<AdminLayout title="Admin — Angebote">
  <section class="pt-10 pb-20 bg-dark min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

      <div class="mb-8">
        <div>
          <h1 class="text-3xl font-bold text-light font-serif">Angebote</h1>
          <p class="text-muted mt-1">Angebotszeilen, Detailseiten und Preistabelle anpassen</p>
        </div>
      </div>

      {saved && (
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-xl text-green-400 text-sm">
          Änderungen gespeichert.
        </div>
      )}

      <form method="POST" action="/api/admin/angebote/save" class="space-y-12">

        <!-- ── Services (Karten + Detailseiten) ── -->
        <div>
          <h2 class="text-xl font-bold text-light mb-4 font-serif">Angebotszeilen & Detailseiten</h2>
          <div class="space-y-10">
            {services.map(s => (
              <div class={sectionCls}>
                <!-- Header -->
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-2xl">{s.icon}</span>
                  <h3 class="text-light font-semibold text-lg">{s.slug}</h3>
                  <label class="ml-auto flex items-center gap-2 text-sm text-muted cursor-pointer">
                    <input type="checkbox" name={`${s.slug}_hidden`} value="1" checked={s.hidden}
                      class="rounded border-dark-lighter bg-dark accent-gold" />
                    Ausblenden
                  </label>
                </div>

                <!-- Card fields -->
                <p class="text-xs font-semibold text-gold uppercase tracking-widest mt-4 mb-3">Servicekarte</p>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class={labelCls}>Titel</label>
                    <input type="text" name={`${s.slug}_title`} value={s.title} class={inputCls} />
                  </div>
                  <div>
                    <label class={labelCls}>Icon (Emoji)</label>
                    <input type="text" name={`${s.slug}_icon`} value={s.icon} class={inputCls} />
                  </div>
                </div>
                <div>
                  <label class={labelCls}>Kurzbeschreibung</label>
                  <textarea name={`${s.slug}_description`} rows={2} class={`${inputCls} resize-none`}>{s.description}</textarea>
                </div>
                <div>
                  <label class={labelCls}>Preis</label>
                  <input type="text" name={`${s.slug}_price`} value={s.price} class={inputCls} />
                </div>
                <div>
                  <label class={labelCls}>Features (eine pro Zeile)</label>
                  <textarea name={`${s.slug}_features`} rows={4} class={`${inputCls} resize-none font-mono`}>{s.features.join('\n')}</textarea>
                </div>

                <!-- pageContent fields -->
                <p class="text-xs font-semibold text-gold uppercase tracking-widest mt-6 mb-3">Detailseite</p>
                <div>
                  <label class={labelCls}>Haupt-Headline</label>
                  <input type="text" name={`${s.slug}_pc_headline`} value={s.pageContent.headline} class={inputCls} />
                </div>
                <div>
                  <label class={labelCls}>Einleitungstext</label>
                  <textarea name={`${s.slug}_pc_intro`} rows={3} class={`${inputCls} resize-none`}>{s.pageContent.intro}</textarea>
                </div>
                <div>
                  <label class={labelCls}>Für wen? (eine Zeile pro Eintrag)</label>
                  <textarea name={`${s.slug}_pc_forWhom`} rows={4} class={`${inputCls} resize-none font-mono`}>{s.pageContent.forWhom.join('\n')}</textarea>
                </div>
                <div>
                  <label class={labelCls}>Leistungsabschnitte (JSON: Array von {"{"}"title":"…","items":["…"]{"}"}")</label>
                  <textarea name={`${s.slug}_pc_sections`} rows={8} class={`${inputCls} resize-y font-mono text-xs`}>{JSON.stringify(s.pageContent.sections, null, 2)}</textarea>
                </div>
                <div>
                  <label class={labelCls}>Preise auf Detailseite (JSON: Array von {"{"}"label":"…","price":"…","unit":"…","highlight":false{"}"}")</label>
                  <textarea name={`${s.slug}_pc_pricing`} rows={6} class={`${inputCls} resize-y font-mono text-xs`}>{JSON.stringify(s.pageContent.pricing, null, 2)}</textarea>
                </div>
                <div>
                  <label class={labelCls}>FAQ (JSON: Array von {"{"}"question":"…","answer":"…"{"}"}")</label>
                  <textarea name={`${s.slug}_pc_faq`} rows={8} class={`${inputCls} resize-y font-mono text-xs`}>{JSON.stringify(s.pageContent.faq ?? [], null, 2)}</textarea>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- ── Preislisten-Download ── -->
        <div>
          <h2 class="text-xl font-bold text-light mb-4 font-serif">Preislisten-Download</h2>
          <div class={sectionCls}>
            <p class="text-sm text-muted mb-3">URL zu einer downloadbaren Preisliste (z.B. PDF in Nextcloud). Wird als Download-Button auf der Leistungen-Seite angezeigt.</p>
            <label class={labelCls}>URL zur Preisliste (leer lassen um Button zu verstecken)</label>
            <input type="text" name="price_list_url" value={priceListUrl ?? ''} placeholder="https://files.mentolder.de/s/..." class={inputCls} />
          </div>
        </div>

        <!-- ── Leistungen / Preistabelle ── -->
        <div>
          <h2 class="text-xl font-bold text-light mb-4 font-serif">Preistabelle (Leistungen)</h2>
          <div class="space-y-8">
            {leistungen.map(cat => (
              <div class={sectionCls}>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-2xl">{cat.icon}</span>
                  <h3 class="text-light font-semibold text-lg">{cat.id}</h3>
                </div>

                <p class="text-xs font-semibold text-gold uppercase tracking-widest mb-3">Kategorie</p>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class={labelCls}>Titel</label>
                    <input type="text" name={`lk_${cat.id}_title`} value={cat.title} class={inputCls} />
                  </div>
                  <div>
                    <label class={labelCls}>Icon (Emoji)</label>
                    <input type="text" name={`lk_${cat.id}_icon`} value={cat.icon} class={inputCls} />
                  </div>
                </div>

                <p class="text-xs font-semibold text-gold uppercase tracking-widest mt-5 mb-3">Einzelleistungen</p>
                <div class="space-y-4">
                  {cat.services.map(svc => (
                    <div class="p-4 bg-dark rounded-lg border border-dark-lighter space-y-3">
                      <p class="text-xs text-muted font-mono">{svc.key}</p>
                      <div class="grid grid-cols-2 gap-3">
                        <div>
                          <label class={labelCls}>Name</label>
                          <input type="text" name={`lk_${cat.id}_${svc.key}_name`} value={svc.name} class={inputCls} />
                        </div>
                        <div>
                          <label class={labelCls}>Preis</label>
                          <input type="text" name={`lk_${cat.id}_${svc.key}_price`} value={svc.price} class={inputCls} />
                        </div>
                        <div>
                          <label class={labelCls}>Einheit</label>
                          <input type="text" name={`lk_${cat.id}_${svc.key}_unit`} value={svc.unit} class={inputCls} />
                        </div>
                        <div class="flex items-end pb-1">
                          <label class="flex items-center gap-2 text-sm text-muted cursor-pointer">
                            <input type="checkbox" name={`lk_${cat.id}_${svc.key}_highlight`} value="1"
                              checked={svc.highlight} class="rounded border-dark-lighter bg-dark accent-gold" />
                            Hervorheben
                          </label>
                        </div>
                      </div>
                      <div>
                        <label class={labelCls}>Beschreibung</label>
                        <textarea name={`lk_${cat.id}_${svc.key}_desc`} rows={2} class={`${inputCls} resize-none`}>{svc.desc}</textarea>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="flex justify-end">
          <button type="submit" class="px-6 py-3 bg-gold text-dark font-semibold rounded-lg hover:bg-gold/90 transition-colors">
            Speichern
          </button>
        </div>

      </form>
    </div>
  </section>
</AdminLayout>
