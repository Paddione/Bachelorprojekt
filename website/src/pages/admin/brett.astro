---
// website/src/pages/admin/brett.astro
// Systemisches Brett v2 – nur für Admins.
// Das Brett wird DIREKT aus dem internen Cluster-Dienst geladen
// (keine Cross-Domain-Iframe-Probleme, kein externer Zugriff möglich).
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession, isAdmin, getLoginUrl } from '../../lib/auth';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');

const room = Astro.url.searchParams.get('room') || 'admin-standalone';

// Interner Service-URL (Kubernetes-intern, nicht von außen erreichbar)
// brett.mentolder.de läuft hinter oauth2-proxy – der Admin-Bereich
// liefert das Brett direkt aus dem internen Netz aus.
const BRETT_INTERNAL = process.env.BRETT_INTERNAL_URL || 'http://brett.workspace.svc.cluster.local:3000';

// Brett HTML laden und als Server-Side-Render ausliefern
// So bleibt alles unter web.mentolder.de/admin/brett – keine Cross-Domain.
let brettHtml = '';
let loadError = '';
try {
  const res = await fetch(`${BRETT_INTERNAL}/brett-v2.html`, {
    signal: AbortSignal.timeout(5000),
  });
  if (res.ok) {
    brettHtml = await res.text();
    // WebSocket-URL und API-Pfade auf brett-proxy-Endpunkt umschreiben
    // damit WS und API-Calls über den Admin-Proxy laufen
    brettHtml = brettHtml
      .replace(/src="\/three\.min\.js"/g, `src="${BRETT_INTERNAL}/three.min.js"`)
      .replace('location.host + \'/sync\'',
               `'${(BRETT_INTERNAL).replace('http://','').replace('https://','')}' + '/sync'`)
      .replace("const API = '/api'", "const API = '/admin/brett/api'");
  } else {
    loadError = `Brett-Dienst nicht erreichbar (HTTP ${res.status})`;
  }
} catch (e: any) {
  loadError = `Brett-Dienst nicht erreichbar: ${e.message}`;
}
---

<AdminLayout title="Systemisches Brett v2">
  {loadError ? (
    <div style="padding: 40px; color: #e06060; font-family: monospace;">
      <p>❌ {loadError}</p>
      <p style="color: #6a6a88; margin-top: 12px; font-size: 13px;">
        Prüfe ob der Brett-Dienst läuft: <code>task workspace:status ENV=mentolder | grep brett</code>
      </p>
    </div>
  ) : (
    <Fragment set:html={brettHtml} />
  )}
</AdminLayout>
