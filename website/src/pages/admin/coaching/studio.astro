---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../../lib/auth';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');
---

<AdminLayout title="Coaching Sessions">
  <section class="studio-disabled">
    <h1>Coaching Studio</h1>
    <p>
      Dieses Werkzeug ist derzeit <strong>nicht verfügbar</strong>. Die frühere Fassung lud
      React und einen Transpiler zur Laufzeit von einem externen CDN nach und transpilierte den
      Quellcode im Browser — das wurde aus Datenschutzgründen (DSGVO / On-Premises) entfernt
      (T001784). Die zugehörigen Quelldateien waren zudem beschädigt, sodass die Oberfläche schon
      zuvor nicht lief.
    </p>
    <p>
      Über eine gebündelte Neufassung oder das Entfernen des Werkzeugs wird separat entschieden
      (T001792). Die Sessions-Liste ist davon unberührt.
    </p>
    <p>
      <a class="btn" href="/admin/coaching/sessions">Zur Sessions-Liste</a>
    </p>
  </section>
</AdminLayout>

<style>
  .studio-disabled { max-width: 62ch; margin: 3rem auto; padding: 0 1rem; }
  .studio-disabled h1 { margin-bottom: 1rem; }
  .studio-disabled p { color: var(--admin-text-mute, #8c96a3); line-height: 1.6; margin-bottom: 1rem; }
  .studio-disabled .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--admin-border, rgba(255, 255, 255, 0.1));
    border-radius: 8px;
    color: var(--admin-text, #eef1f3);
    text-decoration: none;
  }
  .studio-disabled .btn:hover { border-color: var(--admin-border-bright, rgba(255, 255, 255, 0.2)); }
</style>
