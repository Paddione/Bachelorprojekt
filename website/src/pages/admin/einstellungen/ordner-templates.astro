---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminPageHeader from '../../../components/admin/ui/AdminPageHeader.svelte';
import AdminEinstellungenTabs from '../../../components/AdminEinstellungenTabs.astro';
import { getSession, getLoginUrl, isAdmin } from '../../../lib/auth';
import { listTemplates } from '../../../lib/folder-templates-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');

const BRAND = process.env.BRAND || 'mentolder';
const saved = Astro.url.searchParams.get('saved') === '1';
const error = Astro.url.searchParams.get('error') ?? '';
const editId = Astro.url.searchParams.get('edit') ?? '';

const templates = await listTemplates(BRAND);
const editTemplate = editId ? templates.find(t => t.id === editId) : null;
---

<AdminLayout title="Ordner-Templates">
  <AdminEinstellungenTabs current={Astro.url.pathname} />
  <div class="admin-form-wide" style="padding: 2rem; max-width: 800px;">
    <AdminPageHeader title="Ordner-Templates" />
    <p style="color: var(--fg-soft); margin-bottom: 1.5rem;">
      Vordefinierte Ordnerstrukturen, die bei der Projektanlage automatisch im Nextcloud angelegt werden.
    </p>

    {saved && (
      <div style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; color: #86efac; font-size: 0.875rem;">
        Gespeichert.
      </div>
    )}
    {error && (
      <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; color: #fca5a5; font-size: 0.875rem;">
        {decodeURIComponent(error.replace(/\+/g, ' '))}
      </div>
    )}

    <div style="margin-bottom: 2rem;">
      {editTemplate ? (
        <form method="POST" action="/api/admin/folder-templates/update" style="background: var(--ink-900); border: 1px solid var(--line); border-radius: 12px; padding: 1.5rem;">
          <h3 style="color: var(--fg); font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Template bearbeiten</h3>
          <input type="hidden" name="id" value={editTemplate.id} />
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
            <div>
              <label style="display:block;font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);margin-bottom:0.5rem;">Name</label>
              <input type="text" name="name" required maxlength="100" value={editTemplate.name}
                style="width:100%;background:var(--ink-800);border:1px solid var(--line);border-radius:8px;padding:0.625rem 0.875rem;color:var(--fg);font-family:var(--font-mono);font-size:0.875rem;outline:none;" />
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:0.25rem;">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="checkbox" name="isDefault" checked={editTemplate.is_default}
                  style="accent-color: var(--brass);" />
                <span style="font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);">Als Standard setzen</span>
              </label>
            </div>
          </div>
          <div style="margin-bottom:1.25rem;">
            <label style="display:block;font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);margin-bottom:0.5rem;">
              Ordner (eine Zeile pro Ordner, ggf. mit / für Unterordner)
            </label>
            <textarea name="folders" rows="8" required
              style="width:100%;background:var(--ink-800);border:1px solid var(--line);border-radius:8px;padding:0.625rem 0.875rem;color:var(--fg);font-family:var(--font-mono);font-size:0.875rem;outline:none;resize:vertical;">
{editTemplate.structure.folders.join('\n')}</textarea>
          </div>
          <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
            <a href="/admin/einstellungen/ordner-templates"
              style="padding:0.5rem 1rem;font-size:0.8125rem;color:var(--mute);border:1px solid var(--line);border-radius:8px;text-decoration:none;">Abbrechen</a>
            <button type="submit"
              style="padding:0.5rem 1rem;font-size:0.8125rem;background:var(--brass);color:var(--bg);border:none;border-radius:8px;font-weight:600;cursor:pointer;">Speichern</button>
          </div>
        </form>
      ) : (
        <form method="POST" action="/api/admin/folder-templates/create" style="background: var(--ink-900); border: 1px solid var(--line); border-radius: 12px; padding: 1.5rem;">
          <h3 style="color: var(--fg); font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Neues Template</h3>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.25rem;">
            <div>
              <label style="display:block;font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);margin-bottom:0.5rem;">Name</label>
              <input type="text" name="name" required maxlength="100" placeholder="z. B. Agentur-Projekt"
                style="width:100%;background:var(--ink-800);border:1px solid var(--line);border-radius:8px;padding:0.625rem 0.875rem;color:var(--fg);font-family:var(--font-mono);font-size:0.875rem;outline:none;" />
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:0.25rem;">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="checkbox" name="isDefault"
                  style="accent-color: var(--brass);" />
                <span style="font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);">Als Standard setzen</span>
              </label>
            </div>
          </div>
          <div style="margin-bottom:1.25rem;">
            <label style="display:block;font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--mute-2);margin-bottom:0.5rem;">
              Ordner (eine Zeile pro Ordner, ggf. mit / für Unterordner)
            </label>
            <textarea name="folders" rows="8" required
              placeholder="01_Vertrag&#10;02_Rechnungen&#10;03_Dokumente&#10;04_Assets&#10;05_Kommunikation"
              style="width:100%;background:var(--ink-800);border:1px solid var(--line);border-radius:8px;padding:0.625rem 0.875rem;color:var(--fg);font-family:var(--font-mono);font-size:0.875rem;outline:none;resize:vertical;"></textarea>
          </div>
          <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
            <button type="submit"
              style="padding:0.5rem 1rem;font-size:0.8125rem;background:var(--brass);color:var(--bg);border:none;border-radius:8px;font-weight:600;cursor:pointer;">Erstellen</button>
          </div>
        </form>
      )}
    </div>

    <div style="display:flex;flex-direction:column;gap:0.75rem;">
      {templates.length === 0 && (
        <p style="color: var(--mute); font-size: 0.875rem;">Keine Templates vorhanden.</p>
      )}
      {templates.map(t => (
        <div style="display:flex;align-items:center;justify-content:space-between;background:var(--ink-900);border:1px solid var(--line);border-radius:12px;padding:1rem 1.25rem;gap:1rem;">
          <div style="display:flex;align-items:center;gap:0.75rem;min-width:0;">
            <span style="color:var(--fg);font-size:0.9375rem;font-weight:500;">{t.name}</span>
            {t.is_default && (
              <span style="background:var(--brass);color:var(--bg);font-size:0.6875rem;font-weight:600;padding:0.125rem 0.5rem;border-radius:10px;">Standard</span>
            )}
            <span style="color:var(--mute);font-size:0.8125rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              {t.structure.folders.join(', ')}
            </span>
          </div>
          <div style="display:flex;gap:0.5rem;flex-shrink:0;">
            <a href={`/admin/einstellungen/ordner-templates?edit=${t.id}`}
              style="padding:0.375rem 0.75rem;font-size:0.75rem;color:var(--fg-soft);border:1px solid var(--line);border-radius:6px;text-decoration:none;">Bearbeiten</a>
            <form method="POST" action="/api/admin/folder-templates/delete" style="display:inline;">
              <input type="hidden" name="id" value={t.id} />
              <button type="submit"
                style="padding:0.375rem 0.75rem;font-size:0.75rem;color:#fca5a5;border:1px solid rgba(239,68,68,0.3);background:transparent;border-radius:6px;cursor:pointer;">Löschen</button>
            </form>
          </div>
        </div>
      ))}
    </div>
  </div>
</AdminLayout>
