---
import Layout from '../../layouts/Layout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../lib/auth';
import MattermostManager from '../../components/admin/MattermostManager.svelte';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) {
  return Astro.redirect(getLoginUrl());
}
if (!isAdmin(session)) {
  return Astro.redirect('/portal');
}
---

<Layout title="Admin — Mattermost">
  <section class="pt-28 pb-20 bg-dark min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-2">
        <a href="/admin" class="text-muted hover:text-gold text-sm">&larr; Zurück zur Übersicht</a>
      </div>
      <div class="mb-8 flex items-center gap-4">
        <div>
          <h1 class="text-3xl font-bold text-light font-serif">Mattermost</h1>
          <p class="text-muted mt-1">Benutzer, Kanäle und Gruppen verwalten</p>
        </div>
      </div>

      <MattermostManager client:load />
    </div>
  </section>
</Layout>
