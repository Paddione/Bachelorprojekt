---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../../lib/auth';
import { getMeetingDetail, assignMeeting, listProjects } from '../../../lib/website-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl());
if (!isAdmin(session)) return Astro.redirect('/admin');

const { id } = Astro.params;

// Handle PATCH via form POST (Astro SSR)
let saveError = '';
let saveOk = false;
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action')?.toString();
  if (action === 'assign') {
    const customerName  = form.get('customerName')?.toString().trim() ?? '';
    const customerEmail = form.get('customerEmail')?.toString().trim() ?? '';
    const meetingType   = form.get('meetingType')?.toString().trim() ?? '';
    const projectId     = form.get('projectId')?.toString() || null;
    try {
      await assignMeeting(id!, { customerName, customerEmail, meetingType, projectId });
      saveOk = true;
    } catch (e) {
      saveError = e instanceof Error ? e.message : String(e);
    }
  }
}

const meeting = await getMeetingDetail(id!);
if (!meeting) return Astro.redirect('/admin/meetings');

const projects = await listProjects({ brand: 'mentolder' }).catch(() => []);

const isUnassigned = meeting.customerEmail.endsWith('@unknown.local');

function fmtDT(d: Date | string | null) {
  if (!d) return '—';
  return new Date(d).toLocaleString('de-DE');
}
function artifactIcon(type: string) {
  const map: Record<string, string> = { whiteboard: '🎨', document: '📄', screenshot: '🖼', file: '📎' };
  return map[type] ?? '📎';
}
---

<AdminLayout title={`Meeting — ${meeting.meetingType}`}>
  <section class="pt-10 pb-20 bg-dark min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

      <!-- Breadcrumb -->
      <div class="mb-6 text-sm text-muted">
        <a href="/admin/meetings" class="hover:text-light transition-colors">← Meetings</a>
      </div>

      <!-- Titel -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-1">
          {isUnassigned && (
            <span class="px-2 py-0.5 text-xs rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-400/30">
              Nicht zugeordnet
            </span>
          )}
          <span class={`text-xs font-mono px-2 py-0.5 rounded border ${
            meeting.status === 'finalized' ? 'text-green-400 border-green-400/30' :
            meeting.status === 'transcribed' ? 'text-blue-400 border-blue-400/30' :
            'text-yellow-400 border-yellow-400/30'
          }`}>{meeting.status}</span>
        </div>
        <h1 class="text-2xl font-bold text-light font-serif">{meeting.meetingType}</h1>
        <p class="text-muted mt-1">{fmtDT(meeting.startedAt ?? meeting.createdAt)}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Linke Spalte: Metadaten + Formular -->
        <div class="space-y-6">

          <!-- Metadaten -->
          <div class="bg-dark-light rounded-xl p-5 border border-dark-lighter">
            <h2 class="text-sm font-semibold text-light mb-4">Details</h2>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-muted text-xs">Kunde</dt>
                <dd class="text-light mt-0.5">{isUnassigned ? '—' : meeting.customerName}</dd>
                {!isUnassigned && <dd class="text-muted text-xs">{meeting.customerEmail}</dd>}
              </div>
              <div>
                <dt class="text-muted text-xs">Projekt</dt>
                <dd class="text-light mt-0.5">{meeting.projectName ?? '—'}</dd>
              </div>
              <div>
                <dt class="text-muted text-xs">Beginn</dt>
                <dd class="text-light mt-0.5">{fmtDT(meeting.startedAt)}</dd>
              </div>
              <div>
                <dt class="text-muted text-xs">Ende</dt>
                <dd class="text-light mt-0.5">{fmtDT(meeting.endedAt)}</dd>
              </div>
              <div>
                <dt class="text-muted text-xs">Talk-Raum</dt>
                <dd class="text-light mt-0.5 font-mono text-xs break-all">{meeting.talkRoomToken ?? '—'}</dd>
              </div>
            </dl>
          </div>

          <!-- Zuordnungs-Formular -->
          <div class="bg-dark-light rounded-xl p-5 border border-gold/20">
            <h2 class="text-sm font-semibold text-gold mb-4">Zuordnen / Bearbeiten</h2>

            {saveError && (
              <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-xs">
                {saveError}
              </div>
            )}
            {saveOk && (
              <div class="mb-4 p-3 bg-green-500/10 border border-green-500/30 rounded-lg text-green-400 text-xs">
                Gespeichert.
              </div>
            )}

            <form method="POST" class="space-y-3">
              <input type="hidden" name="_action" value="assign" />
              <div>
                <label class="block text-xs text-muted mb-1">Kundenname</label>
                <input
                  type="text" name="customerName"
                  value={isUnassigned ? '' : meeting.customerName}
                  class="w-full bg-dark border border-dark-lighter rounded-lg px-3 py-2 text-light text-sm focus:border-gold outline-none"
                />
              </div>
              <div>
                <label class="block text-xs text-muted mb-1">E-Mail</label>
                <input
                  type="email" name="customerEmail"
                  value={isUnassigned ? '' : meeting.customerEmail}
                  class="w-full bg-dark border border-dark-lighter rounded-lg px-3 py-2 text-light text-sm focus:border-gold outline-none"
                />
              </div>
              <div>
                <label class="block text-xs text-muted mb-1">Meeting-Typ</label>
                <input
                  type="text" name="meetingType"
                  value={meeting.meetingType}
                  class="w-full bg-dark border border-dark-lighter rounded-lg px-3 py-2 text-light text-sm focus:border-gold outline-none"
                />
              </div>
              <div>
                <label class="block text-xs text-muted mb-1">Projekt (optional)</label>
                <select
                  name="projectId"
                  class="w-full bg-dark border border-dark-lighter rounded-lg px-3 py-2 text-light text-sm focus:border-gold outline-none"
                >
                  <option value="">— kein Projekt —</option>
                  {projects.map(p => (
                    <option value={p.id} selected={p.id === meeting.projectId}>{p.name}</option>
                  ))}
                </select>
              </div>
              <button
                type="submit"
                class="w-full py-2 bg-gold text-dark rounded-lg text-sm font-semibold hover:bg-gold/80 transition-colors"
              >
                Speichern
              </button>
            </form>
          </div>
        </div>

        <!-- Rechte Spalte: Transkript + Ressourcen -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Transkript -->
          <div class="bg-dark-light rounded-xl p-5 border border-dark-lighter">
            <h2 class="text-sm font-semibold text-light mb-4">
              Transkript
              {meeting.transcript && (
                <span class="ml-2 text-xs text-muted font-normal">
                  ({meeting.transcript.fullText.length} Zeichen)
                </span>
              )}
            </h2>
            {meeting.transcript ? (
              <div class="text-sm text-muted leading-relaxed max-h-96 overflow-y-auto whitespace-pre-wrap bg-dark rounded-lg p-4">
                {meeting.transcript.fullText}
              </div>
            ) : (
              <p class="text-muted text-sm">Kein Transkript vorhanden.</p>
            )}
          </div>

          <!-- Ressourcen -->
          <div class="bg-dark-light rounded-xl p-5 border border-dark-lighter">
            <h2 class="text-sm font-semibold text-light mb-4">
              Ressourcen
              <span class="ml-2 text-xs text-muted font-normal">({meeting.artifacts.length})</span>
            </h2>
            {meeting.artifacts.length === 0 ? (
              <p class="text-muted text-sm">Keine Ressourcen gefunden.</p>
            ) : (
              <ul class="space-y-2">
                {meeting.artifacts.map(a => (
                  <li class="flex items-center gap-3 px-4 py-3 bg-dark rounded-lg">
                    <span class="text-xl shrink-0">{artifactIcon(a.artifactType)}</span>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm text-light truncate">{a.name}</div>
                      {a.storagePath && (
                        <div class="text-xs text-muted truncate">{a.storagePath}</div>
                      )}
                    </div>
                    {a.storagePath && (
                      <a
                        href={`https://files.mentolder.de/remote.php/dav/files/admin/${a.storagePath}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs px-2 py-1 rounded border border-gold/30 text-gold hover:bg-gold/10 transition-colors shrink-0"
                      >
                        Öffnen →
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </div>

        </div>
      </div>
    </div>
  </section>
</AdminLayout>
