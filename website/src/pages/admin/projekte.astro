---
import Layout from '../../layouts/Layout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../lib/auth';
import { listProjects, listAllCustomers } from '../../lib/website-db';
import type { Project, Customer } from '../../lib/website-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl());
if (!isAdmin(session)) return Astro.redirect('/admin');

const BRAND = process.env.BRAND || 'mentolder';

const statusFilter   = Astro.url.searchParams.get('status')   ?? '';
const priorityFilter = Astro.url.searchParams.get('priority') ?? '';
const qFilter        = Astro.url.searchParams.get('q')        ?? '';
const errorMsg       = Astro.url.searchParams.get('error')    ?? '';
const saved          = Astro.url.searchParams.get('saved')    ?? '';

let projects: Project[] = [];
let customers: Customer[] = [];
let dbError = '';
try {
  [projects, customers] = await Promise.all([
    listProjects({ brand: BRAND, status: statusFilter || undefined, priority: priorityFilter || undefined, q: qFilter || undefined }),
    listAllCustomers(),
  ]);
} catch (err) {
  console.error('[admin/projekte] DB error:', err);
  dbError = 'Datenbankfehler beim Laden der Projekte.';
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const stats = {
  total:     projects.length,
  aktiv:     projects.filter(p => p.status === 'aktiv').length,
  ueberfaellig: projects.filter(p => p.dueDate && new Date(p.dueDate) < today && !['erledigt','archiviert'].includes(p.status)).length,
  erledigt:  projects.filter(p => p.status === 'erledigt').length,
};

// Gantt: date window (projects with start or due date)
const datedProjects = projects.filter(p => p.startDate || p.dueDate);
const allDates = datedProjects.flatMap(p => [p.startDate, p.dueDate].filter(Boolean) as Date[]);
const ganttMin = allDates.length ? new Date(Math.min(...allDates.map(d => new Date(d).getTime()))) : new Date();
const ganttMax = allDates.length ? new Date(Math.max(...allDates.map(d => new Date(d).getTime()))) : new Date(today.getTime() + 90 * 86400000);
// Pad by 5 days on each side
ganttMin.setDate(ganttMin.getDate() - 5);
ganttMax.setDate(ganttMax.getDate() + 5);
const ganttTotalDays = Math.max(1, (ganttMax.getTime() - ganttMin.getTime()) / 86400000);

function ganttBar(p: Project): { left: number; width: number } | null {
  if (!p.dueDate) return null;
  const start = p.startDate ? new Date(p.startDate) : new Date(p.createdAt);
  const end   = new Date(p.dueDate);
  const left  = Math.max(0, (start.getTime() - ganttMin.getTime()) / 86400000 / ganttTotalDays * 100);
  const width = Math.max(0.5, (end.getTime() - start.getTime()) / 86400000 / ganttTotalDays * 100);
  return { left: Math.min(left, 99), width: Math.min(width, 100 - left) };
}

const todayPct = Math.max(0, Math.min(100,
  (today.getTime() - ganttMin.getTime()) / 86400000 / ganttTotalDays * 100
));

const STATUS_LABELS: Record<string, string> = {
  entwurf: 'Entwurf', wartend: 'Wartend', geplant: 'Geplant',
  aktiv: 'Aktiv', erledigt: 'Erledigt', archiviert: 'Archiviert',
};
const STATUS_CLS: Record<string, string> = {
  entwurf:    'bg-slate-900/40 text-slate-300 border-slate-700',
  wartend:    'bg-blue-900/40 text-blue-300 border-blue-800',
  geplant:    'bg-purple-900/40 text-purple-300 border-purple-800',
  aktiv:      'bg-yellow-900/40 text-yellow-300 border-yellow-800',
  erledigt:   'bg-green-900/40 text-green-300 border-green-800',
  archiviert: 'bg-dark border border-dark-lighter text-muted',
};
const STATUS_BAR_CLS: Record<string, string> = {
  entwurf: 'bg-slate-500', wartend: 'bg-blue-500', geplant: 'bg-purple-500',
  aktiv: 'bg-yellow-500', erledigt: 'bg-green-500', archiviert: 'bg-dark-lighter',
};
const PRIO_CLS: Record<string, string> = {
  hoch: 'text-red-400', mittel: 'text-yellow-400', niedrig: 'text-green-400',
};
const PRIO_ICON: Record<string, string> = { hoch: '▲', mittel: '●', niedrig: '▼' };

function formatDate(d: Date | null): string {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

function filterLink(ov: Partial<{status: string; priority: string; q: string}>): string {
  const p = new URLSearchParams();
  const s = ov.status   !== undefined ? ov.status   : statusFilter;
  const r = ov.priority !== undefined ? ov.priority : priorityFilter;
  const q = ov.q        !== undefined ? ov.q        : qFilter;
  if (s) p.set('status', s);
  if (r) p.set('priority', r);
  if (q) p.set('q', q);
  const qs = p.toString();
  return `/admin/projekte${qs ? '?' + qs : ''}`;
}

const inputCls  = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none';
const selectCls = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none cursor-pointer';
const labelCls  = 'block text-xs text-muted mb-1';
---

<Layout title="Admin — Projekte">
  <section class="pt-28 pb-20 bg-dark min-h-screen">
    <div class="max-w-7xl mx-auto px-6">

      <div class="mb-2">
        <a href="/admin" class="text-muted hover:text-gold text-sm">← Zurück zur Übersicht</a>
      </div>

      <div class="mb-8 flex items-center justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-3xl font-bold text-light font-serif">Projekte</h1>
          <p class="text-muted mt-1">{stats.total} gesamt · {stats.aktiv} aktiv · {stats.ueberfaellig > 0 ? `${stats.ueberfaellig} überfällig` : 'keine überfällig'}</p>
        </div>
        <div class="flex gap-3">
          <a href={`/api/admin/projekte/export?brand=${BRAND}`}
            class="px-4 py-2 bg-dark-light border border-dark-lighter text-muted text-sm rounded-lg hover:text-light hover:border-gold/40 transition-colors">
            ↓ CSV Export
          </a>
          <button type="button" id="create-btn"
            class="px-4 py-2 bg-gold hover:bg-gold-light text-dark text-sm font-semibold rounded-lg transition-colors">
            + Neues Projekt
          </button>
        </div>
      </div>

      {/* Stat chips */}
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        {[
          { label: 'Gesamt',     value: stats.total,        cls: 'border-dark-lighter' },
          { label: 'Aktiv',      value: stats.aktiv,        cls: 'border-yellow-800' },
          { label: 'Überfällig', value: stats.ueberfaellig, cls: stats.ueberfaellig > 0 ? 'border-red-800' : 'border-dark-lighter' },
          { label: 'Erledigt',   value: stats.erledigt,     cls: 'border-green-800' },
        ].map(s => (
          <div class={`p-4 bg-dark-light rounded-xl border ${s.cls}`}>
            <div class="text-2xl font-bold text-light">{s.value}</div>
            <div class="text-xs text-muted mt-0.5">{s.label}</div>
          </div>
        ))}
      </div>

      {/* Error / success banners */}
      {(errorMsg || dbError) && (
        <div id="error-banner" class="mb-6 p-4 bg-red-900/30 border border-red-800 rounded-xl text-red-300 text-sm flex items-start justify-between gap-4">
          <span>{decodeURIComponent((errorMsg || dbError).replace(/\+/g, ' '))}</span>
          <button type="button" onclick="document.getElementById('error-banner').remove()" class="text-red-400 hover:text-red-200 shrink-0">✕</button>
        </div>
      )}
      {saved && (
        <div id="saved-banner" class="mb-6 p-4 bg-green-900/30 border border-green-800 rounded-xl text-green-300 text-sm flex items-start justify-between gap-4">
          <span>Projekt erfolgreich gespeichert.</span>
          <button type="button" onclick="document.getElementById('saved-banner').remove()" class="text-green-400 hover:text-green-200 shrink-0">✕</button>
        </div>
      )}

      {/* Filters */}
      <div class="flex flex-wrap gap-3 mb-6 items-center">
        <div class="flex gap-1 p-1 bg-dark-light rounded-lg border border-dark-lighter">
          {([
            { value: '',           label: 'Alle' },
            { value: 'aktiv',      label: 'Aktiv' },
            { value: 'geplant',    label: 'Geplant' },
            { value: 'wartend',    label: 'Wartend' },
            { value: 'entwurf',    label: 'Entwurf' },
            { value: 'erledigt',   label: 'Erledigt' },
            { value: 'archiviert', label: 'Archiviert' },
          ] as const).map(opt => (
            <a href={filterLink({ status: opt.value })}
              class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${statusFilter === opt.value ? 'bg-gold text-dark' : 'text-muted hover:text-light'}`}>
              {opt.label}
            </a>
          ))}
        </div>

        <form method="get" action="/admin/projekte" class="contents">
          {statusFilter && <input type="hidden" name="status"   value={statusFilter} />}
          {qFilter      && <input type="hidden" name="q"        value={qFilter} />}
          <select name="priority" onchange="this.form.submit()"
            class="px-3 py-1.5 bg-dark-light border border-dark-lighter text-sm text-light rounded-lg cursor-pointer">
            <option value="" selected={!priorityFilter}>Alle Prioritäten</option>
            <option value="hoch"    selected={priorityFilter === 'hoch'}>▲ Hoch</option>
            <option value="mittel"  selected={priorityFilter === 'mittel'}>● Mittel</option>
            <option value="niedrig" selected={priorityFilter === 'niedrig'}>▼ Niedrig</option>
          </select>
        </form>

        <form method="get" action="/admin/projekte" class="flex gap-2 ml-auto">
          {statusFilter   && <input type="hidden" name="status"   value={statusFilter} />}
          {priorityFilter && <input type="hidden" name="priority" value={priorityFilter} />}
          <input type="text" name="q" value={qFilter} placeholder="Projektname suchen"
            class="px-3 py-1.5 bg-dark-light border border-dark-lighter text-sm text-light rounded-lg w-52 focus:border-gold focus:ring-2 focus:ring-gold/20" />
          <button type="submit" class="px-3 py-1.5 bg-gold/20 text-gold rounded-lg text-sm hover:bg-gold/30 transition-colors">Suchen</button>
        </form>
      </div>

      {/* Table */}
      <div class="bg-dark-light rounded-2xl border border-dark-lighter overflow-hidden mb-10">
        <table class="w-full">
          <thead>
            <tr class="border-b border-dark-lighter">
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Projekt</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Kunde</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Status</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Prio</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Erfasst</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Start</th>
              <th class="text-left px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Fälligkeit</th>
              <th class="text-center px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">TP</th>
              <th class="text-center px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Aufg.</th>
              <th class="text-right px-4 py-3 text-xs text-muted uppercase tracking-wide font-medium">Aktionen</th>
            </tr>
          </thead>
          <tbody>
            {projects.length === 0 ? (
              <tr>
                <td colspan="10" class="px-4 py-10 text-center text-muted text-sm">
                  Keine Projekte für diese Filterauswahl.
                </td>
              </tr>
            ) : projects.map(p => {
              const isOverdue = p.dueDate && new Date(p.dueDate) < today && !['erledigt','archiviert'].includes(p.status);
              return (
                <tr class={`border-b border-dark-lighter/50 hover:bg-dark/30 transition-colors ${p.status === 'archiviert' ? 'opacity-40' : ''}`}>
                  <td class="px-4 py-3">
                    <a href={`/admin/projekte/${p.id}`} class="text-light hover:text-gold font-medium text-sm transition-colors">
                      {p.name}
                    </a>
                    {p.description && <p class="text-xs text-muted mt-0.5 max-w-[220px] truncate">{p.description}</p>}
                  </td>
                  <td class="px-4 py-3 text-sm text-muted whitespace-nowrap">{p.customerName ?? '—'}</td>
                  <td class="px-4 py-3">
                    <span class={`text-xs px-2 py-0.5 rounded-full border whitespace-nowrap ${STATUS_CLS[p.status] ?? ''}`}>
                      {STATUS_LABELS[p.status] ?? p.status}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm whitespace-nowrap">
                    <span class={PRIO_CLS[p.priority] ?? ''}>{PRIO_ICON[p.priority]} {p.priority.charAt(0).toUpperCase() + p.priority.slice(1)}</span>
                  </td>
                  <td class="px-4 py-3 text-xs text-muted whitespace-nowrap">{formatDate(p.createdAt)}</td>
                  <td class="px-4 py-3 text-xs text-muted whitespace-nowrap">{formatDate(p.startDate)}</td>
                  <td class={`px-4 py-3 text-xs whitespace-nowrap font-medium ${isOverdue ? 'text-red-400' : 'text-muted'}`}>
                    {formatDate(p.dueDate)}{isOverdue ? ' ⚠' : ''}
                  </td>
                  <td class="px-4 py-3 text-center text-sm text-muted">{p.subProjectCount}</td>
                  <td class="px-4 py-3 text-center text-sm text-muted">{p.taskCount}</td>
                  <td class="px-4 py-3">
                    <div class="flex gap-2 justify-end">
                      <a href={`/admin/projekte/${p.id}`}
                        class="px-3 py-1 text-xs bg-gold/20 text-gold border border-gold/30 rounded hover:bg-gold/30 transition-colors">
                        Öffnen
                      </a>
                      {p.status !== 'archiviert' && (
                        <form method="post" action="/api/admin/projekte/update">
                          <input type="hidden" name="id"     value={p.id} />
                          <input type="hidden" name="name"   value={p.name} />
                          <input type="hidden" name="status" value="archiviert" />
                          <input type="hidden" name="priority" value={p.priority} />
                          <input type="hidden" name="_back"  value={Astro.url.pathname + Astro.url.search} />
                          <button type="submit" class="px-3 py-1 text-xs bg-dark border border-dark-lighter text-muted rounded hover:text-light hover:border-gold/40 transition-colors">
                            Archivieren
                          </button>
                        </form>
                      )}
                      <form method="post" action="/api/admin/projekte/delete" class="delete-form">
                        <input type="hidden" name="id"    value={p.id} />
                        <input type="hidden" name="_back" value={filterLink({})} />
                        <button type="submit" class="px-3 py-1 text-xs bg-red-900/20 border border-red-900/40 text-red-400 rounded hover:bg-red-900/40 transition-colors">
                          Löschen
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Gantt / Timeline */}
      {datedProjects.length > 0 && (
        <div class="mb-10">
          <button type="button" id="gantt-toggle"
            class="flex items-center gap-2 text-sm text-muted hover:text-light transition-colors mb-4">
            <span id="gantt-icon">▶</span> Timeline-Ansicht
          </button>
          <div id="gantt-section" class="hidden">
            <div class="bg-dark-light rounded-2xl border border-dark-lighter p-6 overflow-x-auto">
              <h3 class="text-sm font-semibold text-light mb-4">Projektzeitraum</h3>
              {/* Header: date labels */}
              <div class="relative mb-2 h-5" style="min-width:600px">
                {[0, 25, 50, 75, 100].map(pct => {
                  const d = new Date(ganttMin.getTime() + pct / 100 * ganttTotalDays * 86400000);
                  return (
                    <span class="absolute text-xs text-muted transform -translate-x-1/2"
                      style={`left:${pct}%`}>
                      {d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' })}
                    </span>
                  );
                })}
              </div>
              {/* Bars */}
              <div class="space-y-2" style="min-width:600px">
                {datedProjects.map(p => {
                  const bar = ganttBar(p);
                  return (
                    <div class="flex items-center gap-3">
                      <a href={`/admin/projekte/${p.id}`}
                        class="text-xs text-muted hover:text-gold transition-colors shrink-0 w-40 truncate text-right">
                        {p.name}
                      </a>
                      <div class="relative flex-1 h-6 bg-dark rounded">
                        {/* Today marker */}
                        <div class="absolute top-0 bottom-0 w-px bg-red-500/60 z-10"
                          style={`left:${todayPct}%`} title="Heute"></div>
                        {bar && (
                          <div
                            class={`absolute top-1 bottom-1 rounded ${STATUS_BAR_CLS[p.status] ?? 'bg-dark-lighter'} opacity-80`}
                            style={`left:${bar.left}%; width:${bar.width}%`}
                            title={`${p.name}: ${formatDate(p.startDate)} – ${formatDate(p.dueDate)}`}>
                          </div>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
              <p class="text-xs text-muted mt-3">
                <span class="inline-block w-3 h-3 bg-red-500/60 rounded-sm mr-1"></span>Heute
              </p>
            </div>
          </div>
        </div>
      )}

    </div>
  </section>

  {/* Create project dialog */}
  <dialog id="create-dialog"
    class="bg-dark-light border border-dark-lighter rounded-2xl p-6 w-full max-w-xl backdrop:bg-black/60">
    <h2 class="text-lg font-semibold text-light mb-4 font-serif">Neues Projekt</h2>
    <form method="post" action="/api/admin/projekte/create" class="space-y-4">
      <input type="hidden" name="brand" value={BRAND} />
      <div>
        <label class={labelCls}>Name <span class="text-red-400">*</span></label>
        <input type="text" name="name" required maxlength="200" class={inputCls} />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class={labelCls}>Status</label>
          <select name="status" class={selectCls}>
            {(['entwurf','wartend','geplant','aktiv','erledigt','archiviert'] as const).map(s => (
              <option value={s} selected={s === 'entwurf'}>{STATUS_LABELS[s]}</option>
            ))}
          </select>
        </div>
        <div>
          <label class={labelCls}>Priorität</label>
          <select name="priority" class={selectCls}>
            <option value="hoch">▲ Hoch</option>
            <option value="mittel" selected>● Mittel</option>
            <option value="niedrig">▼ Niedrig</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class={labelCls}>Startdatum</label>
          <input type="date" name="startDate" class={inputCls} />
        </div>
        <div>
          <label class={labelCls}>Fälligkeitsdatum</label>
          <input type="date" name="dueDate" class={inputCls} />
        </div>
      </div>
      <div>
        <label class={labelCls}>Verantwortlicher (Kunde)</label>
        <select name="customerId" class={selectCls}>
          <option value="">— kein Kunde —</option>
          {customers.map(c => <option value={c.id}>{c.name} ({c.email})</option>)}
        </select>
      </div>
      <div>
        <label class={labelCls}>Beschreibung</label>
        <textarea name="description" rows="2" maxlength="2000" class={`${inputCls} resize-none`}></textarea>
      </div>
      <div class="flex gap-3 justify-end pt-2">
        <button type="button" id="create-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
        <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Erstellen</button>
      </div>
    </form>
  </dialog>
</Layout>

<script>
  const dialog = document.getElementById('create-dialog') as HTMLDialogElement;
  document.getElementById('create-btn')?.addEventListener('click', () => dialog.showModal());
  document.getElementById('create-cancel')?.addEventListener('click', () => dialog.close());

  // Confirm before delete
  document.querySelectorAll<HTMLFormElement>('.delete-form').forEach(form => {
    form.addEventListener('submit', e => {
      if (!confirm('Projekt wirklich löschen? Alle Teilprojekte und Aufgaben werden ebenfalls gelöscht.')) {
        e.preventDefault();
      }
    });
  });

  // Gantt toggle
  const ganttSection = document.getElementById('gantt-section');
  const ganttIcon    = document.getElementById('gantt-icon');
  document.getElementById('gantt-toggle')?.addEventListener('click', () => {
    ganttSection?.classList.toggle('hidden');
    if (ganttIcon) ganttIcon.textContent = ganttSection?.classList.contains('hidden') ? '▶' : '▼';
  });
</script>
