---
import Layout from '../../../layouts/Layout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../../lib/auth';
import {
  getProject, listSubProjects, listDirectTasks, listSubProjectTasks, listAllCustomers,
  listTimeEntries, getProjectTotalMinutes,
} from '../../../lib/website-db';
import type { Project, SubProject, ProjectTask, Customer, TimeEntry } from '../../../lib/website-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl());
if (!isAdmin(session)) return Astro.redirect('/admin');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/projekte');

let project: Project | null = null;
let subProjects: SubProject[] = [];
let directTasks: ProjectTask[] = [];
let customers: Customer[] = [];
let timeEntries: TimeEntry[] = [];
let timeStats: { total: number; billable: number } = { total: 0, billable: 0 };
let dbError = '';

try {
  [project, customers] = await Promise.all([getProject(id), listAllCustomers()]);
  if (project) {
    [subProjects, directTasks, timeEntries, timeStats] = await Promise.all([
      listSubProjects(id),
      listDirectTasks(id),
      listTimeEntries(id),
      getProjectTotalMinutes(id),
    ]);
  }
} catch (err) {
  console.error('[admin/projekte/[id]] DB error:', err);
  dbError = 'Datenbankfehler beim Laden des Projekts.';
}

if (!project && !dbError) return Astro.redirect('/admin/projekte');

// Load tasks per sub-project
const spTasks: Record<string, ProjectTask[]> = {};
for (const sp of subProjects) {
  try { spTasks[sp.id] = await listSubProjectTasks(sp.id); }
  catch { spTasks[sp.id] = []; }
}

const errorMsg = Astro.url.searchParams.get('error') ?? '';
const saved    = Astro.url.searchParams.get('saved') ?? '';
const today    = new Date(); today.setHours(0,0,0,0);

const STATUS_LABELS: Record<string, string> = {
  entwurf: 'Entwurf', wartend: 'Wartend', geplant: 'Geplant',
  aktiv: 'Aktiv', erledigt: 'Erledigt', archiviert: 'Archiviert',
};
const STATUS_CLS: Record<string, string> = {
  entwurf:    'bg-slate-900/40 text-slate-300 border-slate-700',
  wartend:    'bg-blue-900/40 text-blue-300 border-blue-800',
  geplant:    'bg-purple-900/40 text-purple-300 border-purple-800',
  aktiv:      'bg-yellow-900/40 text-yellow-300 border-yellow-800',
  erledigt:   'bg-green-900/40 text-green-300 border-green-800',
  archiviert: 'bg-dark border-dark-lighter text-muted',
};
const PRIO_CLS:  Record<string, string> = { hoch: 'text-red-400', mittel: 'text-yellow-400', niedrig: 'text-green-400' };
const PRIO_ICON: Record<string, string> = { hoch: '▲', mittel: '●', niedrig: '▼' };

function fmtDate(d: Date | null | string): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
function isoDate(d: Date | null | string): string {
  if (!d) return '';
  return new Date(d).toISOString().slice(0, 10);
}
function isOverdue(dueDate: Date | null, status: string): boolean {
  return !!dueDate && new Date(dueDate) < today && !['erledigt','archiviert'].includes(status);
}
function fmtMin(m: number): string {
  return `${Math.floor(m / 60)}h ${(m % 60).toString().padStart(2, '0')}m`;
}

const inputCls    = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none';
const selectCls   = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none cursor-pointer';
const labelCls    = 'block text-xs text-muted mb-1';
const sectionCls  = 'bg-dark-light rounded-2xl border border-dark-lighter p-6';

// Serialize sub-project and task data for edit dialogs (JSON-safe)
const spJson = JSON.stringify(subProjects.map(sp => ({
  id: sp.id, name: sp.name, description: sp.description ?? '',
  notes: sp.notes ?? '', startDate: isoDate(sp.startDate), dueDate: isoDate(sp.dueDate),
  status: sp.status, priority: sp.priority, customerId: sp.customerId ?? '',
})));

const allTasksFlat = [...directTasks, ...Object.values(spTasks).flat()];
const tasksJson = JSON.stringify(allTasksFlat.map(t => ({
  id: t.id, name: t.name, description: t.description ?? '',
  notes: t.notes ?? '', startDate: isoDate(t.startDate), dueDate: isoDate(t.dueDate),
  status: t.status, priority: t.priority, customerId: t.customerId ?? '',
  subProjectId: t.subProjectId ?? '',
})));
---

<Layout title={`Admin — ${project?.name ?? 'Projekt'}`}>
  <section class="pt-28 pb-20 bg-dark min-h-screen">
    <div class="max-w-5xl mx-auto px-6">

      <div class="mb-2">
        <a href="/admin/projekte" class="text-muted hover:text-gold text-sm">← Zurück zur Projektübersicht</a>
      </div>

      {/* Banners */}
      {(errorMsg || dbError) && (
        <div id="error-banner" class="mb-6 p-4 bg-red-900/30 border border-red-800 rounded-xl text-red-300 text-sm flex items-start justify-between gap-4">
          <span>{decodeURIComponent((errorMsg || dbError).replace(/\+/g, ' '))}</span>
          <button type="button" onclick="document.getElementById('error-banner').remove()" class="text-red-400 hover:text-red-200">✕</button>
        </div>
      )}
      {saved && (
        <div id="saved-banner" class="mb-6 p-4 bg-green-900/30 border border-green-800 rounded-xl text-green-300 text-sm flex items-start justify-between gap-4">
          <span>Gespeichert.</span>
          <button type="button" onclick="document.getElementById('saved-banner').remove()" class="text-green-400 hover:text-green-200">✕</button>
        </div>
      )}

      {project && (
        <>
          {/* ── Project header ── */}
          <div class="mb-8 flex items-start gap-4 flex-wrap">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap mb-1">
                <h1 class="text-3xl font-bold text-light font-serif">{project.name}</h1>
                <span class={`text-xs px-2 py-0.5 rounded-full border ${STATUS_CLS[project.status] ?? ''}`}>
                  {STATUS_LABELS[project.status]}
                </span>
                <span class={`text-sm font-semibold ${PRIO_CLS[project.priority] ?? ''}`}>
                  {PRIO_ICON[project.priority]} {project.priority.charAt(0).toUpperCase() + project.priority.slice(1)}
                </span>
              </div>
              <p class="text-muted text-sm">
                {project.customerName
                  ? <><span class="text-light">{project.customerName}</span> · {project.customerEmail} · </>
                  : ''}
                Erfasst {fmtDate(project.createdAt)}
                {project.startDate ? ` · Start ${fmtDate(project.startDate)}` : ''}
                {project.dueDate ? ` · Fällig ${fmtDate(project.dueDate)}` : ''}
              </p>
            </div>
            <button type="button" id="edit-project-btn"
              class="px-4 py-2 bg-gold/20 text-gold border border-gold/30 text-sm rounded-lg hover:bg-gold/30 transition-colors shrink-0">
              Bearbeiten
            </button>
          </div>

          {/* ── Edit project form (collapsible) ── */}
          <div id="edit-project-section" class="hidden mb-8">
            <div class={sectionCls}>
              <h2 class="text-lg font-semibold text-light mb-4 font-serif">Projekt bearbeiten</h2>
              <form method="post" action="/api/admin/projekte/update" class="space-y-4">
                <input type="hidden" name="id"    value={project.id} />
                <input type="hidden" name="_back" value={`/admin/projekte/${project.id}?saved=1`} />
                <div>
                  <label class={labelCls}>Name <span class="text-red-400">*</span></label>
                  <input type="text" name="name" required maxlength="200" value={project.name} class={inputCls} />
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class={labelCls}>Status</label>
                    <select name="status" class={selectCls}>
                      {(['entwurf','wartend','geplant','aktiv','erledigt','archiviert'] as const).map(s => (
                        <option value={s} selected={s === project!.status}>{STATUS_LABELS[s]}</option>
                      ))}
                    </select>
                  </div>
                  <div>
                    <label class={labelCls}>Priorität</label>
                    <select name="priority" class={selectCls}>
                      {(['hoch','mittel','niedrig'] as const).map(pr => (
                        <option value={pr} selected={pr === project!.priority}>{PRIO_ICON[pr]} {pr.charAt(0).toUpperCase() + pr.slice(1)}</option>
                      ))}
                    </select>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class={labelCls}>Startdatum</label>
                    <input type="date" name="startDate" value={isoDate(project.startDate)} class={inputCls} />
                  </div>
                  <div>
                    <label class={labelCls}>Fälligkeitsdatum</label>
                    <input type="date" name="dueDate" value={isoDate(project.dueDate)} class={inputCls} />
                  </div>
                </div>
                <div>
                  <label class={labelCls}>Verantwortlicher (Kunde)</label>
                  <select name="customerId" class={selectCls}>
                    <option value="">— kein Kunde —</option>
                    {customers.map(c => (
                      <option value={c.id} selected={c.id === project!.customerId}>{c.name} ({c.email})</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label class={labelCls}>Beschreibung</label>
                  <textarea name="description" rows="3" maxlength="2000" class={`${inputCls} resize-none`}>{project.description ?? ''}</textarea>
                </div>
                <div>
                  <label class={labelCls}>Notizen</label>
                  <textarea name="notes" rows="3" maxlength="4000" class={`${inputCls} resize-none`}>{project.notes ?? ''}</textarea>
                </div>
                <div class="flex gap-3 justify-end">
                  <button type="button" id="edit-project-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
                  <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Speichern</button>
                </div>
              </form>
            </div>
          </div>

          {/* ── Sub-projects ── */}
          <div class={`${sectionCls} mb-6`}>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-light font-serif">
                Teilprojekte <span class="text-muted font-normal text-sm">({subProjects.length})</span>
              </h2>
              <button type="button" id="new-sp-btn"
                class="px-3 py-1.5 text-sm bg-gold/20 text-gold border border-gold/30 rounded-lg hover:bg-gold/30 transition-colors">
                + Neues Teilprojekt
              </button>
            </div>

            {subProjects.length === 0 ? (
              <p class="text-muted text-sm">Noch keine Teilprojekte.</p>
            ) : subProjects.map(sp => (
              <div class="mb-3 border border-dark-lighter rounded-xl overflow-hidden">
                {/* Sub-project header */}
                <div class="flex items-center gap-3 px-4 py-3 bg-dark cursor-pointer sp-toggle" data-sp={sp.id}>
                  <span class="text-muted text-xs">▶</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-light text-sm font-medium">{sp.name}</span>
                      <span class={`text-xs px-2 py-0.5 rounded-full border ${STATUS_CLS[sp.status] ?? ''}`}>
                        {STATUS_LABELS[sp.status]}
                      </span>
                      <span class={`text-xs ${PRIO_CLS[sp.priority] ?? ''}`}>{PRIO_ICON[sp.priority]} {sp.priority}</span>
                    </div>
                    <p class="text-xs text-muted mt-0.5">
                      {sp.customerName ? `${sp.customerName} · ` : ''}
                      {sp.dueDate ? `Fällig ${fmtDate(sp.dueDate)} · ` : ''}
                      {sp.taskCount} Aufgabe{sp.taskCount !== 1 ? 'n' : ''}
                      {isOverdue(sp.dueDate, sp.status) ? ' · ⚠ überfällig' : ''}
                    </p>
                  </div>
                  <div class="flex gap-2 shrink-0">
                    <button type="button"
                      class="edit-sp-btn px-2 py-1 text-xs text-muted hover:text-gold transition-colors"
                      data-sp={sp.id}>Bearbeiten</button>
                    <form method="post" action="/api/admin/subprojekte/delete" class="delete-sp-form">
                      <input type="hidden" name="id"    value={sp.id} />
                      <input type="hidden" name="_back" value={`/admin/projekte/${project.id}`} />
                      <button type="submit" class="px-2 py-1 text-xs text-red-400/60 hover:text-red-400 transition-colors">Löschen</button>
                    </form>
                  </div>
                </div>
                {/* Sub-project tasks (collapsed by default) */}
                <div class="sp-tasks hidden border-t border-dark-lighter" id={`sp-tasks-${sp.id}`}>
                  <div class="p-4">
                    {(spTasks[sp.id] ?? []).length === 0 ? (
                      <p class="text-muted text-xs mb-3">Noch keine Aufgaben.</p>
                    ) : (
                      <table class="w-full mb-3 text-sm">
                        <thead>
                          <tr class="border-b border-dark-lighter/50">
                            <th class="text-left py-2 text-xs text-muted font-medium">Aufgabe</th>
                            <th class="text-left py-2 text-xs text-muted font-medium">Status</th>
                            <th class="text-left py-2 text-xs text-muted font-medium">Prio</th>
                            <th class="text-left py-2 text-xs text-muted font-medium">Fälligkeit</th>
                            <th class="text-right py-2 text-xs text-muted font-medium">Aktionen</th>
                          </tr>
                        </thead>
                        <tbody>
                          {(spTasks[sp.id] ?? []).map(t => (
                            <tr class="border-b border-dark-lighter/30">
                              <td class="py-2 pr-3">
                                <span class="text-light text-xs">{t.name}</span>
                                {t.description && <p class="text-xs text-muted truncate max-w-[200px]">{t.description}</p>}
                              </td>
                              <td class="py-2 pr-3">
                                <span class={`text-xs px-2 py-0.5 rounded-full border ${STATUS_CLS[t.status] ?? ''}`}>
                                  {STATUS_LABELS[t.status]}
                                </span>
                              </td>
                              <td class={`py-2 pr-3 text-xs ${PRIO_CLS[t.priority] ?? ''}`}>{PRIO_ICON[t.priority]}</td>
                              <td class={`py-2 pr-3 text-xs ${isOverdue(t.dueDate, t.status) ? 'text-red-400' : 'text-muted'}`}>
                                {fmtDate(t.dueDate) || '—'}
                              </td>
                              <td class="py-2 text-right">
                                <div class="flex gap-2 justify-end">
                                  <button type="button" class="edit-task-btn text-xs text-muted hover:text-gold transition-colors" data-task={t.id}>Bearb.</button>
                                  <form method="post" action="/api/admin/projekttasks/delete" class="delete-task-form">
                                    <input type="hidden" name="id"    value={t.id} />
                                    <input type="hidden" name="_back" value={`/admin/projekte/${project.id}`} />
                                    <button type="submit" class="text-xs text-red-400/60 hover:text-red-400 transition-colors">Löschen</button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    )}
                    <button type="button"
                      class="new-task-btn text-xs px-3 py-1.5 bg-dark border border-dark-lighter text-muted rounded hover:text-light hover:border-gold/40 transition-colors"
                      data-project={project.id} data-sp={sp.id}>
                      + Aufgabe hinzufügen
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>

          {/* ── Direct tasks ── */}
          <div class={sectionCls}>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-light font-serif">
                Direkte Aufgaben <span class="text-muted font-normal text-sm">({directTasks.length})</span>
              </h2>
              <button type="button"
                class="new-task-btn px-3 py-1.5 text-sm bg-gold/20 text-gold border border-gold/30 rounded-lg hover:bg-gold/30 transition-colors"
                data-project={project.id} data-sp="">
                + Neue Aufgabe
              </button>
            </div>

            {directTasks.length === 0 ? (
              <p class="text-muted text-sm">Noch keine direkten Aufgaben.</p>
            ) : (
              <table class="w-full">
                <thead>
                  <tr class="border-b border-dark-lighter">
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Aufgabe</th>
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Status</th>
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Prio</th>
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Kunde</th>
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Start</th>
                    <th class="text-left px-2 py-2 text-xs text-muted font-medium">Fälligkeit</th>
                    <th class="text-right px-2 py-2 text-xs text-muted font-medium">Aktionen</th>
                  </tr>
                </thead>
                <tbody>
                  {directTasks.map(t => (
                    <tr class="border-b border-dark-lighter/50">
                      <td class="px-2 py-3">
                        <span class="text-light text-sm">{t.name}</span>
                        {t.description && <p class="text-xs text-muted truncate max-w-[220px]">{t.description}</p>}
                      </td>
                      <td class="px-2 py-3">
                        <span class={`text-xs px-2 py-0.5 rounded-full border ${STATUS_CLS[t.status] ?? ''}`}>
                          {STATUS_LABELS[t.status]}
                        </span>
                      </td>
                      <td class={`px-2 py-3 text-sm ${PRIO_CLS[t.priority] ?? ''}`}>{PRIO_ICON[t.priority]}</td>
                      <td class="px-2 py-3 text-xs text-muted">{t.customerName ?? '—'}</td>
                      <td class="px-2 py-3 text-xs text-muted whitespace-nowrap">{fmtDate(t.startDate) || '—'}</td>
                      <td class={`px-2 py-3 text-xs whitespace-nowrap ${isOverdue(t.dueDate, t.status) ? 'text-red-400' : 'text-muted'}`}>
                        {fmtDate(t.dueDate) || '—'}
                      </td>
                      <td class="px-2 py-3">
                        <div class="flex gap-2 justify-end">
                          <button type="button" class="edit-task-btn text-xs text-muted hover:text-gold transition-colors" data-task={t.id}>Bearb.</button>
                          <form method="post" action="/api/admin/projekttasks/delete" class="delete-task-form">
                            <input type="hidden" name="id"    value={t.id} />
                            <input type="hidden" name="_back" value={`/admin/projekte/${project.id}`} />
                            <button type="submit" class="text-xs text-red-400/60 hover:text-red-400 transition-colors">Löschen</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>

          {/* ── Zeiterfassung ── */}
          <section class="mt-10">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h2 class="text-xl font-semibold text-light font-serif">Zeiterfassung</h2>
                <p class="text-muted text-sm mt-0.5">
                  {fmtMin(timeStats.total)} gesamt · {fmtMin(timeStats.billable)} abrechenbar
                </p>
              </div>
              <button type="button" id="time-create-btn"
                class="px-3 py-1.5 bg-gold hover:bg-gold-light text-dark text-sm font-semibold rounded-lg transition-colors">
                + Zeit buchen
              </button>
            </div>

            {timeEntries.length === 0 ? (
              <p class="text-muted text-sm">Noch keine Einträge.</p>
            ) : (
              <div class="bg-dark-light rounded-xl border border-dark-lighter overflow-hidden">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-dark-lighter">
                      <th class="text-left px-3 py-2 text-xs text-muted uppercase tracking-wide font-medium">Datum</th>
                      <th class="text-left px-3 py-2 text-xs text-muted uppercase tracking-wide font-medium">Aufgabe</th>
                      <th class="text-left px-3 py-2 text-xs text-muted uppercase tracking-wide font-medium">Beschreibung</th>
                      <th class="text-right px-3 py-2 text-xs text-muted uppercase tracking-wide font-medium">Min.</th>
                      <th class="text-center px-3 py-2 text-xs text-muted uppercase tracking-wide font-medium">Abr.</th>
                      <th class="px-3 py-2"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {timeEntries.map(e => (
                      <tr class="border-b border-dark-lighter/50 hover:bg-dark/30 transition-colors">
                        <td class="px-3 py-2 text-xs text-muted whitespace-nowrap">
                          {new Date(e.entryDate).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' })}
                        </td>
                        <td class="px-3 py-2 text-xs text-muted">{e.taskName ?? '—'}</td>
                        <td class="px-3 py-2 text-xs text-muted max-w-[160px] truncate">{e.description ?? '—'}</td>
                        <td class="px-3 py-2 text-xs text-light text-right font-mono">{e.minutes}</td>
                        <td class="px-3 py-2 text-center text-xs">
                          {e.billable ? <span class="text-green-400">✓</span> : <span class="text-muted">—</span>}
                        </td>
                        <td class="px-3 py-2 text-right">
                          <form method="post" action="/api/admin/zeiterfassung/delete">
                            <input type="hidden" name="id" value={e.id} />
                            <input type="hidden" name="_back" value={`/admin/projekte/${id}`} />
                            <button type="submit"
                              class="text-muted hover:text-red-400 transition-colors text-sm"
                              onclick="return confirm('Eintrag löschen?')">✕</button>
                          </form>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        </>
      )}

    </div>
  </section>

  {/* ── New sub-project dialog ── */}
  <dialog id="new-sp-dialog" class="bg-dark-light border border-dark-lighter rounded-2xl p-6 w-full max-w-xl backdrop:bg-black/60">
    <h2 class="text-lg font-semibold text-light mb-4 font-serif">Neues Teilprojekt</h2>
    <form method="post" action="/api/admin/subprojekte/create" class="space-y-4">
      <input type="hidden" name="projectId" value={project?.id ?? ''} />
      <input type="hidden" name="_back" value={`/admin/projekte/${project?.id ?? ''}`} />
      <div>
        <label class={labelCls}>Name <span class="text-red-400">*</span></label>
        <input type="text" name="name" required maxlength="200" class={inputCls} />
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class={labelCls}>Status</label>
          <select name="status" class={selectCls}>
            {(['entwurf','wartend','geplant','aktiv','erledigt','archiviert'] as const).map(s => (
              <option value={s} selected={s === 'entwurf'}>{STATUS_LABELS[s]}</option>
            ))}
          </select>
        </div>
        <div>
          <label class={labelCls}>Priorität</label>
          <select name="priority" class={selectCls}>
            <option value="hoch">▲ Hoch</option>
            <option value="mittel" selected>● Mittel</option>
            <option value="niedrig">▼ Niedrig</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class={labelCls}>Startdatum</label><input type="date" name="startDate" class={inputCls} /></div>
        <div><label class={labelCls}>Fälligkeitsdatum</label><input type="date" name="dueDate" class={inputCls} /></div>
      </div>
      <div>
        <label class={labelCls}>Verantwortlicher (Kunde)</label>
        <select name="customerId" class={selectCls}>
          <option value="">— kein Kunde —</option>
          {customers.map(c => <option value={c.id}>{c.name} ({c.email})</option>)}
        </select>
      </div>
      <div><label class={labelCls}>Beschreibung</label><textarea name="description" rows="2" maxlength="2000" class={`${inputCls} resize-none`}></textarea></div>
      <div><label class={labelCls}>Notizen</label><textarea name="notes" rows="2" maxlength="4000" class={`${inputCls} resize-none`}></textarea></div>
      <div class="flex gap-3 justify-end pt-2">
        <button type="button" id="new-sp-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
        <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Erstellen</button>
      </div>
    </form>
  </dialog>

  {/* ── Edit sub-project dialog ── */}
  <dialog id="edit-sp-dialog" class="bg-dark-light border border-dark-lighter rounded-2xl p-6 w-full max-w-xl backdrop:bg-black/60">
    <h2 class="text-lg font-semibold text-light mb-4 font-serif">Teilprojekt bearbeiten</h2>
    <form method="post" action="/api/admin/subprojekte/update" class="space-y-4">
      <input type="hidden" name="id"    id="edit-sp-id" />
      <input type="hidden" name="_back" value={`/admin/projekte/${project?.id ?? ''}`} />
      <div><label class={labelCls}>Name <span class="text-red-400">*</span></label><input type="text" name="name" id="edit-sp-name" required maxlength="200" class={inputCls} /></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class={labelCls}>Status</label>
          <select name="status" id="edit-sp-status" class={selectCls}>
            {(['entwurf','wartend','geplant','aktiv','erledigt','archiviert'] as const).map(s => <option value={s}>{STATUS_LABELS[s]}</option>)}
          </select>
        </div>
        <div><label class={labelCls}>Priorität</label>
          <select name="priority" id="edit-sp-priority" class={selectCls}>
            <option value="hoch">▲ Hoch</option><option value="mittel">● Mittel</option><option value="niedrig">▼ Niedrig</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class={labelCls}>Startdatum</label><input type="date" name="startDate" id="edit-sp-startDate" class={inputCls} /></div>
        <div><label class={labelCls}>Fälligkeitsdatum</label><input type="date" name="dueDate" id="edit-sp-dueDate" class={inputCls} /></div>
      </div>
      <div><label class={labelCls}>Verantwortlicher (Kunde)</label>
        <select name="customerId" id="edit-sp-customerId" class={selectCls}>
          <option value="">— kein Kunde —</option>
          {customers.map(c => <option value={c.id}>{c.name} ({c.email})</option>)}
        </select>
      </div>
      <div><label class={labelCls}>Beschreibung</label><textarea name="description" id="edit-sp-description" rows="2" maxlength="2000" class={`${inputCls} resize-none`}></textarea></div>
      <div><label class={labelCls}>Notizen</label><textarea name="notes" id="edit-sp-notes" rows="2" maxlength="4000" class={`${inputCls} resize-none`}></textarea></div>
      <div class="flex gap-3 justify-end pt-2">
        <button type="button" id="edit-sp-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
        <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Speichern</button>
      </div>
    </form>
  </dialog>

  {/* ── Zeit-buchen Dialog ── */}
  <dialog id="time-create-dialog"
    class="bg-dark-light border border-dark-lighter rounded-2xl p-6 w-full max-w-md backdrop:bg-black/60">
    <h2 class="text-lg font-semibold text-light mb-4 font-serif">Zeit buchen</h2>
    <form method="post" action="/api/admin/zeiterfassung/create" class="space-y-4">
      <input type="hidden" name="projectId" value={project?.id ?? ''} />
      <input type="hidden" name="_back" value={`/admin/projekte/${project?.id ?? ''}`} />
      <div>
        <label class="block text-sm text-muted mb-1">Aufgabe (optional)</label>
        <select name="taskId" class="w-full bg-dark border border-dark-lighter rounded-lg px-3 py-2 text-light text-sm focus:outline-none focus:border-gold/50">
          <option value="">— keine Aufgabe —</option>
          {directTasks.map(t => (
            <option value={t.id}>{t.name}</option>
          ))}
        </select>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-muted mb-1">Minuten <span class="text-red-400">*</span></label>
          <input type="number" name="minutes" min="1" max="1440" required
            class="w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none"
            placeholder="z.B. 90" />
        </div>
        <div>
          <label class="block text-xs text-muted mb-1">Datum</label>
          <input type="date" name="entryDate"
            class="w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none"
            value={new Date().toISOString().slice(0, 10)} />
        </div>
      </div>
      <div>
        <label class="block text-xs text-muted mb-1">Beschreibung</label>
        <input type="text" name="description" maxlength="500"
          class="w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none" />
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="billable" value="true" id="time-billable-cb" checked class="accent-gold w-4 h-4" />
        <label for="time-billable-cb" class="text-sm text-light cursor-pointer">Abrechenbar</label>
      </div>
      <div class="flex gap-3 justify-end pt-2">
        <button type="button" id="time-create-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
        <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Speichern</button>
      </div>
    </form>
  </dialog>

  {/* ── New / edit task dialog ── */}
  <dialog id="task-dialog" class="bg-dark-light border border-dark-lighter rounded-2xl p-6 w-full max-w-xl backdrop:bg-black/60">
    <h2 class="text-lg font-semibold text-light mb-4 font-serif" id="task-dialog-title">Aufgabe</h2>
    <form method="post" id="task-form" class="space-y-4">
      <input type="hidden" name="id"           id="task-id" />
      <input type="hidden" name="projectId"    id="task-projectId" value={project?.id ?? ''} />
      <input type="hidden" name="subProjectId" id="task-subProjectId" />
      <input type="hidden" name="_back"        value={`/admin/projekte/${project?.id ?? ''}`} />
      <div><label class={labelCls}>Name <span class="text-red-400">*</span></label><input type="text" name="name" id="task-name" required maxlength="200" class={inputCls} /></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class={labelCls}>Status</label>
          <select name="status" id="task-status" class={selectCls}>
            {(['entwurf','wartend','geplant','aktiv','erledigt','archiviert'] as const).map(s => <option value={s}>{STATUS_LABELS[s]}</option>)}
          </select>
        </div>
        <div><label class={labelCls}>Priorität</label>
          <select name="priority" id="task-priority" class={selectCls}>
            <option value="hoch">▲ Hoch</option><option value="mittel">● Mittel</option><option value="niedrig">▼ Niedrig</option>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class={labelCls}>Startdatum</label><input type="date" name="startDate" id="task-startDate" class={inputCls} /></div>
        <div><label class={labelCls}>Fälligkeitsdatum</label><input type="date" name="dueDate" id="task-dueDate" class={inputCls} /></div>
      </div>
      <div><label class={labelCls}>Verantwortlicher (Kunde)</label>
        <select name="customerId" id="task-customerId" class={selectCls}>
          <option value="">— kein Kunde —</option>
          {customers.map(c => <option value={c.id}>{c.name} ({c.email})</option>)}
        </select>
      </div>
      <div><label class={labelCls}>Beschreibung</label><textarea name="description" id="task-description" rows="2" maxlength="2000" class={`${inputCls} resize-none`}></textarea></div>
      <div><label class={labelCls}>Notizen</label><textarea name="notes" id="task-notes" rows="2" maxlength="4000" class={`${inputCls} resize-none`}></textarea></div>
      <div class="flex gap-3 justify-end pt-2">
        <button type="button" id="task-cancel" class="px-4 py-2 text-sm text-muted hover:text-light transition-colors">Abbrechen</button>
        <button type="submit" class="px-4 py-2 text-sm bg-gold hover:bg-gold-light text-dark font-semibold rounded-lg transition-colors">Speichern</button>
      </div>
    </form>
  </dialog>
</Layout>

<script define:vars={{ spJson, tasksJson }}>
  const subProjects = JSON.parse(spJson);
  const allTasks    = JSON.parse(tasksJson);

  // ── Project edit toggle ──
  const editSection = document.getElementById('edit-project-section');
  document.getElementById('edit-project-btn')?.addEventListener('click', () => {
    editSection?.classList.toggle('hidden');
  });
  document.getElementById('edit-project-cancel')?.addEventListener('click', () => {
    editSection?.classList.add('hidden');
  });

  // ── Sub-project accordion toggle ──
  document.querySelectorAll('.sp-toggle').forEach(el => {
    el.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('button, form')) return;
      const spId   = (el as HTMLElement).dataset.sp;
      const panel  = document.getElementById(`sp-tasks-${spId}`);
      const icon   = el.querySelector('span');
      panel?.classList.toggle('hidden');
      if (icon) icon.textContent = panel?.classList.contains('hidden') ? '▶' : '▼';
    });
  });

  // ── New sub-project dialog ──
  const newSpDialog = document.getElementById('new-sp-dialog') as HTMLDialogElement;
  document.getElementById('new-sp-btn')?.addEventListener('click', () => newSpDialog.showModal());
  document.getElementById('new-sp-cancel')?.addEventListener('click', () => newSpDialog.close());

  // ── Edit sub-project dialog ──
  const editSpDialog = document.getElementById('edit-sp-dialog') as HTMLDialogElement;
  document.getElementById('edit-sp-cancel')?.addEventListener('click', () => editSpDialog.close());
  document.querySelectorAll('.edit-sp-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const spId = (btn as HTMLElement).dataset.sp;
      const sp   = subProjects.find((s: any) => s.id === spId);
      if (!sp) return;
      (document.getElementById('edit-sp-id')          as HTMLInputElement).value    = sp.id;
      (document.getElementById('edit-sp-name')        as HTMLInputElement).value    = sp.name;
      (document.getElementById('edit-sp-description') as HTMLTextAreaElement).value = sp.description;
      (document.getElementById('edit-sp-notes')       as HTMLTextAreaElement).value = sp.notes;
      (document.getElementById('edit-sp-startDate')   as HTMLInputElement).value    = sp.startDate;
      (document.getElementById('edit-sp-dueDate')     as HTMLInputElement).value    = sp.dueDate;
      (document.getElementById('edit-sp-status')      as HTMLSelectElement).value   = sp.status;
      (document.getElementById('edit-sp-priority')    as HTMLSelectElement).value   = sp.priority;
      (document.getElementById('edit-sp-customerId')  as HTMLSelectElement).value   = sp.customerId;
      editSpDialog.showModal();
    });
  });

  // ── Delete sub-project confirm ──
  document.querySelectorAll('.delete-sp-form').forEach(form => {
    form.addEventListener('submit', e => {
      if (!confirm('Teilprojekt löschen? Alle zugehörigen Aufgaben werden ebenfalls gelöscht.')) e.preventDefault();
    });
  });

  // ── Task dialog (create + edit) ──
  const taskDialog = document.getElementById('task-dialog') as HTMLDialogElement;
  const taskForm   = document.getElementById('task-form')   as HTMLFormElement;
  document.getElementById('task-cancel')?.addEventListener('click', () => taskDialog.close());

  function openTaskDialog(mode: 'create' | 'edit', data?: any) {
    const title = document.getElementById('task-dialog-title') as HTMLElement;
    title.textContent = mode === 'create' ? 'Neue Aufgabe' : 'Aufgabe bearbeiten';
    taskForm.action = mode === 'create'
      ? '/api/admin/projekttasks/create'
      : '/api/admin/projekttasks/update';

    const fields = ['id','name','description','notes','startDate','dueDate','status','priority','customerId','subProjectId','projectId'];
    fields.forEach(f => {
      const el = document.getElementById(`task-${f}`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
      if (el) el.value = data?.[f] ?? (f === 'status' ? 'entwurf' : f === 'priority' ? 'mittel' : '');
    });
    taskDialog.showModal();
  }

  document.querySelectorAll('.new-task-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const spId     = (btn as HTMLElement).dataset.sp ?? '';
      const projId   = (btn as HTMLElement).dataset.project ?? '';
      openTaskDialog('create', { projectId: projId, subProjectId: spId });
    });
  });

  document.querySelectorAll('.edit-task-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tid  = (btn as HTMLElement).dataset.task;
      const task = allTasks.find((t: any) => t.id === tid);
      if (!task) return;
      openTaskDialog('edit', task);
    });
  });

  // ── Delete task confirm ──
  document.querySelectorAll('.delete-task-form').forEach(form => {
    form.addEventListener('submit', e => {
      if (!confirm('Aufgabe löschen?')) e.preventDefault();
    });
  });

  // ── Zeit buchen dialog ──
  const timeDialog = document.getElementById('time-create-dialog') as HTMLDialogElement;
  document.getElementById('time-create-btn')?.addEventListener('click', () => timeDialog.showModal());
  document.getElementById('time-create-cancel')?.addEventListener('click', () => timeDialog.close());
</script>
