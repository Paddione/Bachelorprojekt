---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminPageHeader from '../../components/admin/ui/AdminPageHeader.svelte';
import ChatRoomPanel from '../../components/ChatRoomPanel.svelte';
import { getSession, isAdmin, getLoginUrl } from '../../lib/auth';
import { listRoomsForAdmin } from '../../lib/messaging-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');

let rooms: Awaited<ReturnType<typeof listRoomsForAdmin>> = [];
try {
  rooms = await listRoomsForAdmin();
} catch (err) {
  console.error('[admin/raeume] DB error:', err);
}
---

<AdminLayout title="Räume">
  <div style="max-width:72rem; margin:0 auto; padding:1.5rem 1.5rem 0;">
    <AdminPageHeader title="Räume" />
  </div>
  <div style="height: calc(100vh - 220px)">
    <ChatRoomPanel rooms={rooms} role="admin" messagesBaseUrl="/api/admin/rooms" client:load />
  </div>
</AdminLayout>
