---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminWebsiteTabs from '../../components/AdminWebsiteTabs.astro';
import { getSession, getLoginUrl, isAdmin } from '../../lib/auth';
import { getLegalPage } from '../../lib/website-db';
import { config } from '../../config/index';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));
if (!isAdmin(session)) return Astro.redirect('/admin');

const BRAND = process.env.BRAND || 'mentolder';
const saved = Astro.url.searchParams.get('saved') === '1';

const pageKeys = ['impressum-zusatz', 'datenschutz', 'agb', 'barrierefreiheit'];
const [impressumZusatz, datenschutz, agb, barrierefreiheit] = await Promise.all(
  pageKeys.map(k => getLegalPage(BRAND, k).catch(() => null))
);

const inputCls = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:outline-none focus:border-gold/50';
const labelCls = 'block text-xs text-muted mb-1';
const sectionCls = 'p-6 bg-dark-light rounded-xl border border-dark-lighter space-y-4';

// Default-Inhalte als Vorlage wenn DB noch leer ist
const defaultDatenschutz = `<h2>Hinweis</h2>
<p>Diese Datenschutzerklärung gilt für alle auf dieser Website angebotenen Dienste.</p>`;

const defaultAgb = `<h2>Weitere Bestimmungen</h2>
<p>Ergänzende Regelungen nach Absprache mit dem Auftraggeber.</p>`;

const defaultBarrierefreiheit = `<h2>Kontakt und Feedback</h2>
<p>Wenn Sie Mängel in Bezug auf die barrierefreie Gestaltung dieser Website bemerken,
wenden Sie sich bitte direkt an uns.</p>`;
---

<AdminLayout title="Admin — Rechtliches">
  <AdminWebsiteTabs current={Astro.url.pathname} />
  <section class="pt-10 pb-20 bg-dark min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

      <div class="mb-8">
        <div>
          <h1 class="text-3xl font-bold text-light font-serif">Rechtliches</h1>
          <p class="text-muted mt-1">Impressum, Datenschutz, AGB und Barrierefreiheit bearbeiten</p>
        </div>
      </div>

      {saved && (
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-xl text-green-400 text-sm">
          Änderungen gespeichert.
        </div>
      )}

      <div class="mb-6 p-4 bg-gold/5 border border-gold/20 rounded-xl text-sm text-muted">
        Die Felder enthalten HTML. Strukturdaten wie Name, Adresse und E-Mail werden automatisch
        aus dem Systemprofil eingefügt. Das Impressum ist vollständig dynamisch — dort können Sie
        nur einen optionalen Zusatz-Block ergänzen.
        <br/>Links auf den Seiten: <a href="/impressum" target="_blank" class="text-gold hover:underline">/impressum</a> ·
        <a href="/datenschutz" target="_blank" class="text-gold hover:underline">/datenschutz</a> ·
        <a href="/agb" target="_blank" class="text-gold hover:underline">/agb</a> ·
        <a href="/barrierefreiheit" target="_blank" class="text-gold hover:underline">/barrierefreiheit</a>
      </div>

      <form method="POST" action="/api/admin/rechtliches/save" class="space-y-8">

        <!-- Impressum Zusatz -->
        <div class={sectionCls}>
          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl">⚖️</span>
            <h2 class="text-light font-semibold text-lg">Impressum — Zusatz-Abschnitt</h2>
            <a href="/impressum" target="_blank" class="ml-auto text-xs text-gold hover:underline">Vorschau →</a>
          </div>
          <p class="text-xs text-muted">Wird am Ende des automatisch generierten Impressums angezeigt. Leer lassen um nichts anzuzeigen.</p>
          <div>
            <label class={labelCls}>Zusatz-HTML (optional)</label>
            <textarea name="impressum-zusatz" rows={5}
              class={`${inputCls} resize-y font-mono text-xs`}
            >{impressumZusatz ?? ''}</textarea>
          </div>
        </div>

        <!-- Datenschutz -->
        <div class={sectionCls}>
          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl">🔒</span>
            <h2 class="text-light font-semibold text-lg">Datenschutzerklärung</h2>
            <a href="/datenschutz" target="_blank" class="ml-auto text-xs text-gold hover:underline">Vorschau →</a>
          </div>
          <p class="text-xs text-muted">Vollständiger HTML-Inhalt der Datenschutzseite. Der Verantwortlichen-Block wird automatisch eingefügt.</p>
          <div>
            <label class={labelCls}>Inhalt (HTML)</label>
            <textarea name="datenschutz" rows={20}
              class={`${inputCls} resize-y font-mono text-xs`}
            >{datenschutz ?? defaultDatenschutz}</textarea>
          </div>
        </div>

        <!-- AGB -->
        <div class={sectionCls}>
          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl">📋</span>
            <h2 class="text-light font-semibold text-lg">AGB</h2>
            <a href="/agb" target="_blank" class="ml-auto text-xs text-gold hover:underline">Vorschau →</a>
          </div>
          <p class="text-xs text-muted">Vollständiger HTML-Inhalt der AGB. Grundlegende Paragraphen mit Leistungsliste werden automatisch vorne gestellt.</p>
          <div>
            <label class={labelCls}>Inhalt (HTML)</label>
            <textarea name="agb" rows={20}
              class={`${inputCls} resize-y font-mono text-xs`}
            >{agb ?? defaultAgb}</textarea>
          </div>
        </div>

        <!-- Barrierefreiheit -->
        <div class={sectionCls}>
          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl">♿</span>
            <h2 class="text-light font-semibold text-lg">Barrierefreiheitserklärung</h2>
            <a href="/barrierefreiheit" target="_blank" class="ml-auto text-xs text-gold hover:underline">Vorschau →</a>
          </div>
          <p class="text-xs text-muted">Vollständiger HTML-Inhalt. Einleitungssatz mit Name und Website wird automatisch eingefügt.</p>
          <div>
            <label class={labelCls}>Inhalt (HTML)</label>
            <textarea name="barrierefreiheit" rows={15}
              class={`${inputCls} resize-y font-mono text-xs`}
            >{barrierefreiheit ?? defaultBarrierefreiheit}</textarea>
          </div>
        </div>

        <div class="flex items-center justify-between">
          <p class="text-xs text-muted">Tipp: Auf jeder Rechtseite gibt es einen "Drucken / PDF"-Button.</p>
          <button type="submit" class="px-6 py-3 bg-gold text-dark font-semibold rounded-lg hover:bg-gold/90 transition-colors">
            Speichern
          </button>
        </div>

      </form>
    </div>
  </section>
</AdminLayout>
