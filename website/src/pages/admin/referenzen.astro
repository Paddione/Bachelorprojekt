---
import Layout from '../../layouts/Layout.astro';
import { getSession, getLoginUrl, isAdmin } from '../../lib/auth';
import { getReferenzen } from '../../lib/website-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl());
if (!isAdmin(session)) return Astro.redirect('/admin');

const BRAND = process.env.BRAND || 'mentolder';
const saved = Astro.url.searchParams.get('saved') === '1';

const referenzen = await getReferenzen(BRAND).catch(() => null) ?? [];

const inputCls = 'w-full px-3 py-2 bg-dark border border-dark-lighter rounded-lg text-light text-sm focus:outline-none focus:border-gold/50';
const labelCls = 'block text-xs text-muted mb-1';
---

<Layout title="Admin — Referenzen">
  <section class="pt-28 pb-20 bg-dark min-h-screen">
    <div class="max-w-4xl mx-auto px-6">

      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-light font-serif">Referenzen</h1>
          <p class="text-muted mt-1">Referenzkunden und Projekte verwalten</p>
        </div>
        <a href="/admin" class="px-4 py-2 bg-dark-light text-muted rounded-lg text-sm font-medium hover:text-light transition-colors">
          ← Zurück
        </a>
      </div>

      {saved && (
        <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-xl text-green-400 text-sm">
          Referenzen gespeichert.
        </div>
      )}

      <div class="mb-6 p-4 bg-gold/5 border border-gold/20 rounded-xl text-sm text-muted">
        Jede Referenz wird als Karte auf der <a href="/referenzen" target="_blank" class="text-gold hover:underline">/referenzen</a>-Seite angezeigt.
        Einträge ohne Logo zeigen nur Name und Beschreibung.
      </div>

      <form method="POST" action="/api/admin/referenzen/save">
        <div id="referenzen-list" class="space-y-4 mb-6">
          {referenzen.map((ref, i) => (
            <div class="ref-item p-5 bg-dark-light rounded-xl border border-dark-lighter space-y-3">
              <input type="hidden" name={`ref_${i}_id`} value={ref.id} />
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs text-muted font-mono">{ref.id}</span>
                <label class="flex items-center gap-2 text-xs text-red-400 cursor-pointer">
                  <input type="checkbox" name={`ref_${i}_delete`} value="1" class="accent-red-400" />
                  Löschen
                </label>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class={labelCls}>Name *</label>
                  <input type="text" name={`ref_${i}_name`} value={ref.name} required class={inputCls} />
                </div>
                <div>
                  <label class={labelCls}>Website-URL (optional)</label>
                  <input type="url" name={`ref_${i}_url`} value={ref.url ?? ''} class={inputCls} />
                </div>
              </div>
              <div>
                <label class={labelCls}>Logo-URL (optional)</label>
                <input type="url" name={`ref_${i}_logoUrl`} value={ref.logoUrl ?? ''} class={inputCls} />
              </div>
              <div>
                <label class={labelCls}>Kurzbeschreibung (optional)</label>
                <textarea name={`ref_${i}_description`} rows={2} class={`${inputCls} resize-none`}>{ref.description ?? ''}</textarea>
              </div>
            </div>
          ))}
        </div>

        <!-- New entry template -->
        <div class="p-5 bg-dark-light rounded-xl border border-dashed border-dark-lighter space-y-3 mb-8">
          <p class="text-xs font-semibold text-gold uppercase tracking-widest">Neue Referenz hinzufügen</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class={labelCls}>Name *</label>
              <input type="text" name="new_name" class={inputCls} placeholder="z.B. Muster GmbH" />
            </div>
            <div>
              <label class={labelCls}>Website-URL (optional)</label>
              <input type="url" name="new_url" class={inputCls} placeholder="https://..." />
            </div>
          </div>
          <div>
            <label class={labelCls}>Logo-URL (optional)</label>
            <input type="url" name="new_logoUrl" class={inputCls} placeholder="https://..." />
          </div>
          <div>
            <label class={labelCls}>Kurzbeschreibung (optional)</label>
            <textarea name="new_description" rows={2} class={`${inputCls} resize-none`} placeholder="Kurzer Hinweis zum Projekt oder zur Zusammenarbeit"></textarea>
          </div>
        </div>

        <div class="flex items-center justify-between">
          <a href="/referenzen" target="_blank" class="text-sm text-gold hover:underline">Vorschau →</a>
          <button type="submit" class="px-6 py-3 bg-gold text-dark font-semibold rounded-lg hover:bg-gold/90 transition-colors">
            Speichern
          </button>
        </div>
      </form>

    </div>
  </section>
</Layout>
