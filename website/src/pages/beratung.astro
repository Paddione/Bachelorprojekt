---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.svelte';

const phases = [
  { num: '1', title: 'Analyse', desc: 'Wo stehen Sie heute? Was sind die konkreten Bedarfe? Welche Ziele verfolgen Sie?' },
  { num: '2', title: 'Strategie', desc: 'Entwicklung einer klaren Roadmap mit Prioritaten, Ressourcenplanung und Meilensteinen.' },
  { num: '3', title: 'Change Management', desc: 'Ihr Team mitnehmen: Schulungen, Kommunikation, Motivation \u2013 damit Veranderung gelebt wird.' },
  { num: '4', title: 'Umsetzungsbegleitung', desc: 'Implementation begleiten, Prozesse optimieren, Nachhaltigkeit sichern.' },
];

const results = [
  'Digitale Transformations-Strategie \u2013 dokumentiert, umsetzbar, nachvollziehbar',
  'Optimierte Prozesse \u2013 digital, effizient, praxiserprobt',
  'Team mitgenommen \u2013 geschult, motiviert, handlungsfahig',
  'Technologie implementiert \u2013 lauft stabil, wird genutzt',
  'Nachhaltigkeit gesichert \u2013 interne Kompetenz aufgebaut',
];
---

<Layout title="Unternehmensberatung Digitale Transformation" description="Digitale Transformation fur Mittelstand, Verwaltung und kritische Infrastrukturen. 40 Jahre Praxis.">
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-gold font-semibold text-lg mb-4 tracking-widest uppercase">Unternehmensberatung</p>
      <h1 class="text-4xl md:text-5xl font-bold text-light leading-tight mb-6 font-serif">Digitale Transformation mit Erfahrung</h1>
      <p class="text-xl text-muted leading-relaxed max-w-3xl">Ich begleite Organisationen bei der digitalen Transformation &ndash; nicht mit theoretischen Konzepten, sondern mit 40 Jahren Praxis aus komplexen IT- und Sicherheitsstrukturen.</p>
    </div>
  </section>

  <section class="py-16 bg-dark-light">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-8 font-serif">Fur wen ist das?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: '\uD83C\uDFE2', title: 'Mittelstandische Unternehmen', desc: '50-500 Mitarbeiter' },
          { icon: '\uD83C\uDFDB\uFE0F', title: 'Offentliche Verwaltung', desc: 'Behorden & Verwaltung' },
          { icon: '\u26A1', title: 'Kritische Infrastrukturen', desc: 'Energie, Kommunikation, Verkehr' },
        ].map((item) => (
          <div class="p-6 bg-dark rounded-xl border border-dark-lighter text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-lg font-semibold text-gold mb-2">{item.title}</h3>
            <p class="text-muted">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-dark">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-10 font-serif">Mein Vorgehen in vier Phasen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {phases.map((phase) => (
          <div class="flex gap-5">
            <div class="flex-shrink-0 w-12 h-12 bg-gold text-dark rounded-xl flex items-center justify-center text-xl font-bold">{phase.num}</div>
            <div>
              <h3 class="text-xl font-bold text-light mb-2">{phase.title}</h3>
              <p class="text-muted leading-relaxed">{phase.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-dark-light">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-8 font-serif">Was Sie nach Projektende haben</h2>
      <div class="space-y-4">
        {results.map((item) => (
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <p class="text-lg text-muted">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-dark">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold text-light mb-6 font-serif">Investition</h2>
      <div class="bg-dark-light rounded-2xl p-8 max-w-md mx-auto border border-dark-lighter">
        <p class="text-muted mb-2">Tagessatz</p>
        <p class="text-4xl font-bold text-gold">nach Vereinbarung</p>
        <p class="text-muted mt-4">Gesamtkosten individuell je nach Projektumfang. Dauer: 3-12 Monate.</p>
      </div>
      <p class="text-muted mt-6 text-lg">Ich begleite maximal 2 Projekte gleichzeitig für höchste Qualität.</p>
    </div>
  </section>

  <CallToAction client:visible />
</Layout>
