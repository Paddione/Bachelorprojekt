---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.svelte';
import StatsStrip from '../components/StatsStrip.astro';
import ServiceRow from '../components/ServiceRow.svelte';
import CallToAction from '../components/CallToAction.svelte';
import FAQ from '../components/FAQ.svelte';
import WhyMe from '../components/WhyMe.svelte';
import Process from '../components/Process.astro';
import KoreHomepage from '../components/kore/KoreHomepage.svelte';
import TimelineIsland from '../components/islands/TimelineIsland.svelte';
import NextSlotIsland from '../components/islands/NextSlotIsland.svelte';
import { config } from '../config/index';
import {
  getEffectiveServices,
  getEffectiveHomepage,
  getEffectiveFaq,
  getEffectiveStammdaten,
  getEffectiveNavigation,
  getEffectiveFooter,
  getEffectiveKoreFlags,
  bundleSeo,
} from '../lib/content';

const BRAND_ID = process.env.BRAND_ID ?? process.env.BRAND ?? 'mentolder';
const isKore = BRAND_ID === 'korczewski';
const layoutBrand = isKore ? 'korczewski-kore' : undefined;

// T001490: SEO is now sourced from the build-time content bundle
// (website/content/<brand>/seo.json). Zero DB dependency on the
// homepage render path.
const seo = bundleSeo(BRAND_ID);
const homeDescription = !isKore ? (seo.descriptions.home ?? null) : null;
const metaDescription = homeDescription ?? config.meta.siteDescription;

const homeTitle = !isKore ? (seo.titles.home ?? null) : null;
const pageTitle = homeTitle ?? 'Gerald Korczewski – Coach & Mentor';

const homeOgImage = !isKore ? (seo.ogImages.home ?? null) : null;

const [homepage, faq, allServices, stammdaten, _effectiveNav, effectiveFooter, effectiveKoreFlags] = await Promise.all([
  getEffectiveHomepage(),
  getEffectiveFaq(),
  getEffectiveServices(),
  getEffectiveStammdaten(),
  getEffectiveNavigation(),
  getEffectiveFooter(),
  getEffectiveKoreFlags(),
]);
const services = allServices.filter((s) => !s.hidden);

// Timeline is now a client island (TimelineIsland). We still read the
// gate flag from the bundle so SSR/CSR agree on whether to render it.
// No SSR await against the DB — that was the source of the slow render
// when the meetings DB or the tickets schema was down (T001490 Task 5).
const wantsTimeline = effectiveKoreFlags.timeline;

const processSteps = homepage.processSteps ?? [];
---

<Layout title={pageTitle} rawTitle={!isKore} description={metaDescription} brand={layoutBrand} ogImage={homeOgImage ?? undefined}>
  {isKore ? (
    <KoreHomepage
      client:load
      services={services}
      homepage={config.homepage}
      contact={{ name: stammdaten.name, email: stammdaten.email, phone: stammdaten.phone, city: stammdaten.city }}
      legal={{ jobtitle: stammdaten.role, tagline: config.legal.tagline, street: stammdaten.street, zip: stammdaten.zip, ustId: stammdaten.ustId, website: stammdaten.website, chamber: config.legal.chamber }}
      footerColumns={effectiveFooter.columns}
      footerCopyright={effectiveFooter.copyright}
      wantsTimeline={wantsTimeline}
    />
  ) : (
    <Fragment>
      <!-- Hero with Portrait -->
      <Hero
        client:load
        title={homepage.hero.title}
        titleEmphasis={homepage.hero.titleEmphasis}
        subtitle={homepage.hero.subtitle}
        tagline={homepage.hero.tagline}
        avatarType={homepage.avatarType}
        avatarSrc={homepage.avatarSrc}
        avatarInitials={homepage.avatarInitials}
        personName={stammdaten.name}
        personRole={stammdaten.role}
      />

      <!-- Stats + Availability strip — slot becomes a client island -->
      <StatsStrip stats={homepage.stats} nextDay={null} />
      <NextSlotIsland client:idle />

      <!-- Offers -->
      <section id="angebote" class="section" aria-labelledby="offers-heading">
        <div class="wrap">
          <div class="section-head">
            <div>
              <p class="eyebrow">Meine Angebote</p>
              <h2 id="offers-heading">{homepage.servicesHeadline}</h2>
            </div>
            <p class="section-intro">{homepage.servicesSubheadline}</p>
          </div>

          <div class="offers reveal-stagger" role="list" aria-label="Angebote">
            {services.map((service, i) => (
              <div role="listitem">
                <ServiceRow
                  num={String(i + 1).padStart(2, '0')}
                  title={service.title}
                  meta={service.meta}
                  description={service.description}
                  features={service.features}
                  price={service.price}
                  href={`/${service.slug}`}
                  icon={service.icon}
                  iconSpriteId={service.iconSpriteId}
                  iconSpriteBrand={BRAND_ID}
                  stripeServiceKey={service.stripeServiceKey}
                  client:visible
                />
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Why Me + Quote -->
      <WhyMe
        client:visible
        headline={homepage.whyMeHeadline}
        intro={homepage.whyMeIntro}
        points={homepage.whyMePoints}
        quote={homepage.quote}
        quoteName={homepage.quoteName}
        quoteRole={stammdaten.role}
      />

      <!-- Process -->
      <Process
        steps={processSteps}
        eyebrow={homepage.processEyebrow}
        headline={homepage.processHeadline}
      />

      <!-- FAQ -->
      <FAQ items={faq.map((item) => ({
        ...item,
        answer: item.answer.replace('{city}', stammdaten.city),
      }))} client:visible />

      <!-- Timeline (client island) — was an SSR await; now fail-soft -->
      <TimelineIsland client:idle wantsTimeline={wantsTimeline} brand={BRAND_ID} limit={20} />

      <!-- CTA -->
      <CallToAction
        client:visible
        secondaryText={stammdaten?.email}
        secondaryHref={`mailto:${stammdaten?.email}`}
      />

    </Fragment>
  )}
</Layout>

<style>
  .section {
    padding: 120px 0;
  }

  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 40px;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    margin-bottom: 72px;
    align-items: end;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 16px;
  }

  .eyebrow::before {
    content: "";
    width: 22px;
    height: 1px;
    background: currentColor;
    opacity: 0.8;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(32px, 3.6vw, 48px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--fg);
    max-width: 18ch;
    margin: 0;
  }

  .section-intro {
    font-size: 18px;
    line-height: 1.6;
    color: var(--fg-soft);
    max-width: 52ch;
    margin: 0;
  }

  .offers {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 720px) {
    .section {
      padding: 80px 0;
    }

    .section-head {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 48px;
    }

    .wrap {
      padding: 0 22px;
    }
  }
</style>
