---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.svelte';
import ServiceCard from '../components/ServiceCard.svelte';
import CallToAction from '../components/CallToAction.svelte';
import FAQ from '../components/FAQ.svelte';
import { config } from '../config/index';
import SlotWidget from '../components/SlotWidget.astro';
import type { DaySlots } from '../lib/caldav';
import { getAvailableSlots } from '../lib/caldav';

const { homepage, services, faq, contact } = config;

let nextDay: DaySlots | null = null;
try {
  const slots = await getAvailableSlots();
  nextDay = slots.length > 0 ? slots[0] : null;
} catch {
  // CalDAV unreachable — widget hidden gracefully
}
---

<Layout title={config.meta.siteTitle}>
  <Hero client:load />

  {nextDay && <SlotWidget day={nextDay} />}

  <!-- Trust indicators -->
  <section class="py-12 bg-dark-light border-b border-dark-lighter">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {homepage.stats.map((stat) => (
          <div>
            <p class="text-3xl font-bold text-gold">{stat.value}</p>
            <p class="text-muted mt-1">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="angebote" class="py-20 bg-dark">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-light mb-4 font-serif">{homepage.servicesHeadline}</h2>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          {homepage.servicesSubheadline}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
            features={service.features}
            href={`/${service.slug}`}
            price={service.price}
            client:visible
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why me -->
  <section class="py-20 bg-dark-light">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-light mb-6 font-serif">{homepage.whyMeHeadline}</h2>
          <p class="text-xl text-muted leading-relaxed mb-8">
            {homepage.whyMeIntro}
          </p>
          <div class="space-y-5">
            {homepage.whyMePoints.map((point) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-gold-dim rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={point.iconPath} />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-light">{point.title}</h3>
                  <p class="text-muted">{point.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Photo / Initials + Quote -->
        <div class="flex flex-col items-center">
          {homepage.avatarType === 'image' ? (
            <div class="relative mb-8">
              <img
                src={homepage.avatarSrc}
                alt={contact.name}
                class="w-64 h-64 md:w-72 md:h-72 rounded-full object-cover border-3 border-gold shadow-lg shadow-gold-dim"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="mb-8 bg-dark rounded-2xl p-6 border border-dark-lighter">
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-gold-dim rounded-full flex items-center justify-center text-2xl">
                  <span class="text-gold font-bold">{homepage.avatarInitials}</span>
                </div>
                <div>
                  <p class="font-semibold text-light">{contact.name}</p>
                  <p class="text-muted text-sm">{config.legal.tagline}</p>
                  <p class="text-muted-dark text-sm">{contact.city}</p>
                </div>
              </div>
            </div>
          )}
          <div class="bg-dark rounded-2xl p-8 border border-dark-lighter max-w-md">
            <svg class="w-10 h-10 text-gold/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
            </svg>
            <blockquote class="text-lg text-light leading-relaxed italic font-serif">
              "{homepage.quote}"
            </blockquote>
            <p class="text-muted-dark mt-4 text-sm">{homepage.quoteName}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faq.map((item) => ({
    ...item,
    answer: item.answer.replace('{city}', contact.city),
  }))} client:visible />

  <CallToAction client:visible />
</Layout>
