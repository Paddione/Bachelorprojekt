---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.svelte';
import { config } from '../config/index';
import { getEffectiveLeistungen } from '../lib/content';

const { leistungenCta, leistungenPricingHighlight } = config;
const leistungen = await getEffectiveLeistungen();
---

<Layout title="Leistungen & Preise" description="Alle Angebote und Preise auf einen Blick.">
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h1 class="text-4xl md:text-5xl font-bold text-light mb-4 font-serif">Leistungen & Preise</h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Alle Angebote auf einen Blick. Wählen Sie das passende Format und nehmen Sie Kontakt auf.
        </p>
      </div>

      {leistungenPricingHighlight && leistungenPricingHighlight.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
          {leistungenPricingHighlight.map((item) => (
            <div class={`bg-dark-light rounded-2xl p-8 text-center ${item.highlight ? 'border-2 border-gold' : 'border border-dark-lighter'}`}>
              <p class="text-muted text-lg mb-2">{item.label}</p>
              <p class="text-4xl font-bold text-gold mb-2">{item.price}</p>
              <p class="text-muted">{item.note}</p>
            </div>
          ))}
        </div>
      )}

      {leistungen.map((cat) => (
        <div id={cat.id} class="mb-16">
          <h2 class="text-2xl md:text-3xl font-bold text-light mb-3 font-serif">
            <span class="mr-3">{cat.icon}</span>{cat.title}
          </h2>
          {cat.description && (
            <p class="text-lg text-muted mb-8 max-w-3xl">{cat.description}</p>
          )}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {cat.services.map((svc) => (
              <div class={`bg-dark-light rounded-xl p-6 border ${svc.highlight ? 'border-gold' : 'border-dark-lighter'} flex flex-col`}>
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-light mb-1">{svc.name}</h3>
                  <div class="mb-3">
                    <span class="text-2xl font-bold text-gold">{svc.price}</span>
                    <span class="text-muted-dark ml-2">{svc.unit}</span>
                  </div>
                  <p class="text-muted mb-4">{svc.desc}</p>
                </div>
                <a
                  href={`${leistungenCta.href}?service=${svc.key}`}
                  class="block text-center bg-gold hover:bg-gold-light text-dark px-6 py-3 rounded-full font-bold transition-colors uppercase tracking-wide text-sm"
                >
                  {leistungenCta.text}
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="bg-dark-light rounded-2xl p-8 border border-dark-lighter text-center">
        <h3 class="text-xl font-bold text-light mb-3 font-serif">Kostenloses Erstgespräch</h3>
        <p class="text-muted mb-4">Nicht sicher, welches Angebot passt? In einem kostenlosen Erstgespräch klären wir gemeinsam, was für Sie am besten geeignet ist.</p>
        <a href={leistungenCta.href} class="inline-block bg-gold hover:bg-gold-light text-dark px-8 py-3 rounded-full font-bold transition-colors uppercase tracking-wide text-sm">
          Erstgespräch vereinbaren
        </a>
      </div>
    </div>
  </section>

  <CallToAction client:visible />
</Layout>
