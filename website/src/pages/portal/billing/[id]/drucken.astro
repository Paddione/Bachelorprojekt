---
import { getSession, getLoginUrl } from '../../../../lib/auth';
import { getFullInvoice } from '../../../../lib/stripe-billing';
import { getSiteSetting } from '../../../../lib/website-db';

const session = await getSession(Astro.request.headers.get('cookie'));
if (!session) return Astro.redirect(getLoginUrl(Astro.url.pathname));

const invoiceId = Astro.params.id;
if (!invoiceId) return Astro.redirect('/portal?section=rechnungen');

const inv = await getFullInvoice(invoiceId);
if (!inv) return Astro.redirect('/portal?section=rechnungen');

// Customers may only print their own invoices
if (inv.customerEmail !== session.email) return Astro.redirect('/portal?section=rechnungen');

const brand = process.env.BRAND || 'mentolder';

const keys = [
  'invoice_sender_name', 'invoice_sender_street', 'invoice_sender_city',
  'invoice_sender_phone', 'invoice_bank_iban', 'invoice_bank_bic',
  'invoice_bank_name', 'invoice_payment_days', 'invoice_tax_rate',
  'invoice_vat_id', 'invoice_manager',
] as const;
const results = await Promise.all(keys.map(k => getSiteSetting(brand, k)));
const s = Object.fromEntries(keys.map((k, i) => [k, results[i] ?? ''])) as Record<typeof keys[number], string>;

const senderName   = s.invoice_sender_name   || brand;
const senderStreet = s.invoice_sender_street || '';
const senderCity   = s.invoice_sender_city   || '';
const senderPhone  = s.invoice_sender_phone  || '';
const iban         = s.invoice_bank_iban     || '';
const bic          = s.invoice_bank_bic      || '';
const bankName     = s.invoice_bank_name     || '';
const paymentDays  = s.invoice_payment_days  || '14';
const taxRate      = parseFloat(s.invoice_tax_rate || '0');
const vatId        = s.invoice_vat_id        || '';
const manager      = s.invoice_manager       || '';

const website = process.env.PUBLIC_DOMAIN
  ? `www.${process.env.PUBLIC_DOMAIN}`
  : `www.${brand}.de`;
const contactEmail = process.env.CONTACT_EMAIL || `info@${brand}.de`;

function fmtDate(iso: string): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

function fmtEur(n: number): string {
  return n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

const addr = inv.buyerAddress;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Rechnung {inv.number} — {senderName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,350;0,6..72,400;1,6..72,400&family=Geist:wght@400;500&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── design tokens ── */
    :root {
      --paper:       #f6f3ee;
      --paper-2:     #efeae1;
      --ink-text:    #1a2030;
      --ink-soft:    #3a4150;
      --ink-mute:    #6a717e;
      --ink-mute-2:  #8c94a1;
      --brass-print: oklch(0.62 0.11 75);
      --serif:       "Newsreader", "Iowan Old Style", Georgia, serif;
      --sans:        "Geist", ui-sans-serif, system-ui, -apple-system, sans-serif;
      --mono:        "Geist Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    }

    /* ── B&W print overrides ── */
    @media print {
      :root {
        --brass-print: #111111;
        --paper:       #ffffff;
        --paper-2:     #f0f0f0;
        --ink-text:    #000000;
        --ink-soft:    #222222;
        --ink-mute:    #555555;
      }
      .paper-doc::before,
      .paper-doc::after  { display: none !important; }
      .paper-doc         { box-shadow: none !important; }
      .thanks            { background: #f5f5f5 !important; border-color: rgba(0,0,0,.15) !important; }
      .totals .right .row.grand { border-top-color: #000 !important; border-bottom-color: #000 !important; }
      .no-print          { display: none !important; }
      @page              { size: A4; margin: 0; }
      html, body         { background: #fff !important; }
    }

    /* ── base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #e8e3da;
      font-family: var(--sans);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* ── toolbar ── */
    .no-print {
      position: fixed; top: 1rem; right: 1rem; z-index: 100;
      display: flex; gap: 0.5rem;
    }
    .no-print button, .no-print a {
      padding: 0.5rem 1.25rem;
      font-family: var(--mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
      border-radius: 6px; cursor: pointer; text-decoration: none;
      border: 1px solid transparent;
    }
    .no-print .btn-print {
      background: var(--ink-text); color: var(--paper); border-color: var(--ink-text);
    }
    .no-print .btn-stripe {
      background: transparent; color: var(--ink-soft); border-color: rgba(26,32,48,.3);
    }

    /* ── A4 paper shell ── */
    .paper-doc {
      width: 210mm; min-height: 297mm; max-width: 100%;
      margin: 2rem auto;
      background: var(--paper); color: var(--ink-text);
      box-shadow: 0 30px 80px -30px rgba(0,0,0,.55), 0 0 0 1px rgba(255,255,255,.04);
      position: relative; overflow: hidden;
      font-size: 10pt; line-height: 1.45;
    }
    .paper-doc::before {
      content: ""; position: absolute; right: -30mm; top: -30mm;
      width: 120mm; height: 120mm;
      background: radial-gradient(closest-side, oklch(0.80 0.09 75 / .16), transparent 70%);
      pointer-events: none;
    }
    .paper-doc::after {
      content: ""; position: absolute; left: -30mm; bottom: -30mm;
      width: 120mm; height: 120mm;
      background: radial-gradient(closest-side, oklch(0.56 0.07 160 / .10), transparent 70%);
      pointer-events: none;
    }
    .inner {
      position: relative; z-index: 2;
      padding: 22mm 22mm 18mm;
    }

    /* ── invoice header ── */
    .inv-head {
      display: grid; grid-template-columns: 1fr auto; gap: 20mm; align-items: flex-start;
      padding-bottom: 10mm; border-bottom: 1px solid rgba(15,23,36,.10);
    }
    .brand-row { display: flex; align-items: center; gap: 10px; }
    .brand-name {
      font-family: var(--mono); font-size: 13pt; letter-spacing: .04em;
      color: var(--ink-text); font-weight: 500;
    }
    .brand-sub {
      font-family: var(--mono); font-size: 7.5pt; letter-spacing: .12em;
      color: var(--ink-mute); text-transform: uppercase; margin-top: 1px;
    }
    .doc-type {
      font-family: var(--mono); font-size: 8.5pt; letter-spacing: .22em; text-transform: uppercase;
      color: var(--brass-print); margin-top: 8mm;
      display: flex; align-items: center; gap: 10px;
    }
    .doc-type::before { content: ""; width: 18px; height: 1px; background: currentColor; opacity: .8; }
    .inv-head h1 {
      font-family: var(--serif); font-weight: 350; font-size: 30pt; line-height: 1;
      letter-spacing: -0.02em; margin-top: 3mm; color: var(--ink-text);
    }
    .inv-head h1 em { font-style: italic; color: var(--brass-print); font-weight: 400; }
    .meta-block {
      text-align: right; font-family: var(--mono); font-size: 9pt; line-height: 1.85; color: var(--ink-soft);
    }
    .meta-block .lab {
      color: var(--ink-mute); font-size: 8pt; letter-spacing: .18em; text-transform: uppercase;
    }
    .meta-block .val { color: var(--ink-text); font-weight: 500; }
    .meta-block .num {
      font-family: var(--serif); font-size: 13pt; color: var(--ink-text); font-weight: 400;
      letter-spacing: .02em; display: block; margin-top: 2mm;
    }

    /* ── parties ── */
    .parties {
      display: grid; grid-template-columns: 1fr 1fr; gap: 14mm;
      padding: 8mm 0; border-bottom: 1px solid rgba(15,23,36,.10);
    }
    .parties .col .lab {
      font-family: var(--mono); font-size: 8pt; letter-spacing: .18em; text-transform: uppercase;
      color: var(--brass-print);
      display: flex; align-items: center; gap: 8px;
    }
    .parties .col .lab::before { content: ""; width: 14px; height: 1px; background: currentColor; opacity: .8; }
    .parties .col .name {
      font-family: var(--serif); font-size: 13pt; color: var(--ink-text);
      margin-top: 3mm; font-weight: 400;
    }
    .parties .col .addr {
      font-family: var(--sans); font-size: 9.5pt; color: var(--ink-soft);
      margin-top: 2mm; line-height: 1.6;
    }

    /* ── line items ── */
    .items {
      margin-top: 8mm; width: 100%; border-collapse: collapse;
    }
    .items thead th {
      font-family: var(--mono); font-size: 8pt; letter-spacing: .18em; text-transform: uppercase;
      color: var(--ink-mute); text-align: left; padding: 0 0 4mm;
      border-bottom: 1px solid rgba(15,23,36,.16); font-weight: 500;
    }
    .items thead th.right { text-align: right; }
    .items tbody td {
      padding: 4.5mm 0; border-bottom: 1px solid rgba(15,23,36,.08);
      vertical-align: top; font-family: var(--sans); font-size: 10pt;
      color: var(--ink-text); line-height: 1.5;
    }
    .items tbody td.right {
      text-align: right; font-family: var(--mono); font-variant-numeric: tabular-nums;
    }
    .items tbody td .desc {
      font-family: var(--serif); font-size: 11pt; color: var(--ink-text); margin-bottom: 1mm;
    }

    /* ── totals ── */
    .totals {
      margin-top: 6mm; display: grid; grid-template-columns: 1fr 1fr; gap: 14mm;
    }
    .totals .left {
      font-family: var(--sans); font-size: 9.5pt; color: var(--ink-soft); line-height: 1.6;
    }
    .totals .left .lab {
      font-family: var(--mono); font-size: 8pt; letter-spacing: .18em; text-transform: uppercase;
      color: var(--brass-print); margin-bottom: 2mm;
      display: flex; align-items: center; gap: 8px;
    }
    .totals .left .lab::before { content: ""; width: 14px; height: 1px; background: currentColor; opacity: .8; }
    .totals .right .row {
      display: flex; justify-content: space-between; padding: 2mm 0;
      font-family: var(--sans); font-size: 10pt; color: var(--ink-soft);
    }
    .totals .right .row.grand {
      margin-top: 3mm; padding: 5mm 0;
      border-top: 1px solid rgba(15,23,36,.20);
      border-bottom: double 3px rgba(15,23,36,.20);
      font-family: var(--serif); font-size: 18pt; color: var(--ink-text);
    }
    .totals .right .row .v {
      font-family: var(--mono); font-variant-numeric: tabular-nums; color: var(--ink-text);
    }
    .totals .right .row.grand .v {
      font-family: var(--serif); font-style: italic;
      color: var(--brass-print); white-space: nowrap;
    }

    /* ── thank-you note ── */
    .thanks {
      margin-top: 10mm; padding: 5mm 7mm;
      border: 1px solid rgba(15,23,36,.10); border-radius: 5px;
      background: rgba(255,255,255,.4);
      display: grid; grid-template-columns: auto 1fr; gap: 5mm; align-items: center;
    }
    .thanks .seal {
      width: 14mm; height: 14mm; border-radius: 4px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .thanks .seal svg { width: 100%; height: 100%; display: block; }
    .thanks .msg {
      font-family: var(--serif); font-style: italic;
      font-size: 11pt; color: var(--ink-text); line-height: 1.45;
    }
    .thanks .msg em { color: var(--brass-print); }

    /* ── footer ── */
    .inv-foot {
      margin-top: 14mm; padding-top: 6mm; border-top: 1px solid rgba(15,23,36,.10);
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 8mm;
      font-family: var(--mono); font-size: 7.5pt; line-height: 1.75;
      color: var(--ink-mute); text-transform: uppercase; letter-spacing: .14em;
    }
    .inv-foot .lab { color: var(--brass-print); margin-bottom: 1.5mm; display: block; }
    .inv-foot .v {
      color: var(--ink-soft); text-transform: none; letter-spacing: 0;
      font-family: var(--sans); font-size: 8.5pt;
    }
  </style>
</head>
<body>

  <!-- toolbar — hidden on print -->
  <div class="no-print">
    <button class="btn-print" onclick="window.print()">Drucken / PDF ↓</button>
    {inv.hostedUrl && (
      <a class="btn-stripe" href={inv.hostedUrl} target="_blank" rel="noopener">Online bezahlen ↗</a>
    )}
  </div>

  <div class="paper-doc">
    <div class="inner">

      <!-- ── header ── -->
      <div class="inv-head">
        <div>
          <div class="brand-row">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" style="width:42px;height:42px;border-radius:10px;flex-shrink:0">
              <defs>
                <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#1a2436"/>
                  <stop offset="100%" stop-color="#0a0f18"/>
                </linearGradient>
                <linearGradient id="br" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#f0d28c"/>
                  <stop offset="50%" stop-color="#d7b06a"/>
                  <stop offset="100%" stop-color="#8a6a2a"/>
                </linearGradient>
              </defs>
              <rect width="48" height="48" rx="11" fill="url(#bg)"/>
              <rect x="1" y="1" width="46" height="46" rx="10" fill="none" stroke="#c89a4a" stroke-width="1" opacity=".7"/>
              <text x="24" y="33" text-anchor="middle" font-family="Georgia,serif" font-weight="600" font-size="24" fill="url(#br)">m</text>
            </svg>
            <div>
              <div class="brand-name">{senderName}</div>
              <div class="brand-sub">Coaching · Mentoring · Consulting</div>
            </div>
          </div>
          <div class="doc-type">Honorarrechnung</div>
          <h1>Rechnung — <em>{inv.number}</em></h1>
        </div>

        <div class="meta-block">
          <div class="lab">Rechnungsnummer</div>
          <div class="num">{inv.number}</div>
          <div class="lab" style="margin-top:3mm">Datum</div>
          <div class="val">{fmtDate(inv.date)}</div>
          {inv.dueDate && (
            <>
              <div class="lab" style="margin-top:2mm">Fällig am</div>
              <div class="val">{fmtDate(inv.dueDate)}</div>
            </>
          )}
          {inv.buyerVatId && (
            <>
              <div class="lab" style="margin-top:2mm">USt-IdNr. Empfänger</div>
              <div class="val">{inv.buyerVatId}</div>
            </>
          )}
        </div>
      </div>

      <!-- ── parties ── -->
      <div class="parties">
        <div class="col">
          <div class="lab">Von</div>
          <div class="name">{senderName}</div>
          <div class="addr">
            {senderStreet && <>{senderStreet}<br /></>}
            {senderCity && <>{senderCity}<br /></>}
            {senderPhone && <>{senderPhone}<br /></>}
            {contactEmail}<br />
            {website}
            {vatId && <><br />USt-IdNr.: {vatId}</>}
          </div>
        </div>
        <div class="col">
          <div class="lab">An</div>
          <div class="name">{inv.customerName}</div>
          <div class="addr">
            {addr ? (
              <>
                {addr.line1 && <>{addr.line1}<br /></>}
                {(addr.postalCode || addr.city) && <>{addr.postalCode} {addr.city}<br /></>}
              </>
            ) : null}
            {inv.customerEmail}
          </div>
        </div>
      </div>

      <!-- ── line items ── -->
      <table class="items">
        <thead>
          <tr>
            <th>Leistung</th>
            <th class="right" style="width:7rem">Betrag</th>
          </tr>
        </thead>
        <tbody>
          {inv.lines.map(line => (
            <tr>
              <td><div class="desc">{line.description}</div></td>
              <td class="right">{fmtEur(line.amountNet)} €</td>
            </tr>
          ))}
        </tbody>
      </table>

      <!-- ── totals ── -->
      <div class="totals">
        <div class="left">
          {taxRate === 0 ? (
            <>
              <div class="lab">Steuerlicher Hinweis</div>
              <p>
                Der Rechnungssteller ist Kleinunternehmer gemäß § 19 Abs. 1 UStG.
                Es wird keine Umsatzsteuer ausgewiesen.
              </p>
            </>
          ) : (
            <>
              <div class="lab">Steuer</div>
              <p>USt. {taxRate} % auf den Nettobetrag.</p>
            </>
          )}
          <p style="margin-top:3mm">
            Zahlungsziel: {paymentDays} Tage netto ab Rechnungsdatum.
          </p>
          {manager && <p style="margin-top:2mm">Ansprechpartner: {manager}</p>}
        </div>
        <div class="right">
          <div class="row">
            <span>Zwischensumme</span>
            <span class="v">{fmtEur(inv.subtotalExclTax)} €</span>
          </div>
          <div class="row">
            <span>{taxRate === 0 ? 'USt. (§ 19 UStG)' : `USt. ${taxRate} %`}</span>
            <span class="v">{taxRate === 0 ? '—' : `${fmtEur(inv.taxAmount)} €`}</span>
          </div>
          <div class="row grand">
            <span>Gesamt</span>
            <span class="v">{fmtEur(inv.amountDue)} €</span>
          </div>
        </div>
      </div>

      <!-- ── thank-you note ── -->
      <div class="thanks">
        <div class="seal">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
            <defs>
              <linearGradient id="bg2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1a2436"/>
                <stop offset="100%" stop-color="#0a0f18"/>
              </linearGradient>
              <linearGradient id="br2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#f0d28c"/>
                <stop offset="50%" stop-color="#d7b06a"/>
                <stop offset="100%" stop-color="#8a6a2a"/>
              </linearGradient>
            </defs>
            <rect width="48" height="48" rx="11" fill="url(#bg2)"/>
            <text x="24" y="33" text-anchor="middle" font-family="Georgia,serif" font-weight="600" font-size="24" fill="url(#br2)">m</text>
          </svg>
        </div>
        <div class="msg">
          Vielen Dank für Ihr Vertrauen — <em>auf Ihre nächste Etappe.</em>
        </div>
      </div>

      <!-- ── footer ── -->
      <div class="inv-foot">
        {bankName && (
          <div>
            <span class="lab">Bank</span>
            <span class="v">
              {bankName}<br />
              {iban && <>IBAN: {iban}<br /></>}
              {bic && <>BIC: {bic}</>}
            </span>
          </div>
        )}
        <div>
          <span class="lab">Kontakt</span>
          <span class="v">
            {senderPhone && <>{senderPhone}<br /></>}
            {contactEmail}<br />
            {website}
          </span>
        </div>
        <div>
          <span class="lab">Rechtliches</span>
          <span class="v">
            {vatId && <>USt-IdNr.: {vatId}<br /></>}
            {manager && <>Vertreten durch:<br />{manager}</>}
          </span>
        </div>
      </div>

    </div>
  </div>

</body>
</html>
