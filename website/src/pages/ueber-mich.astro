---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.svelte';
import { config } from '../config/index';

const { uebermich, contact } = config;
---

<Layout title="Uber mich" description={`Uber ${contact.name} – ${config.legal.tagline}`}>
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-gold font-semibold text-lg mb-4 tracking-widest uppercase">{uebermich.subheadline}</p>
      <h1 class="text-4xl md:text-5xl font-bold text-light leading-tight mb-6 font-serif">{uebermich.pageHeadline}</h1>
    </div>
  </section>

  <section class="py-16 bg-dark-light">
    <div class="max-w-3xl mx-auto px-6 space-y-8 text-lg text-muted leading-relaxed">
      {uebermich.introParagraphs.map((para) => (
        <p set:html={para} />
      ))}

      {uebermich.sections.map((sec) => (
        <div class="bg-dark rounded-2xl p-8 my-10 border-l-4 border-gold">
          <h2 class="text-2xl font-bold text-light mb-4 font-serif">{sec.title}</h2>
          <p>{sec.content}</p>
        </div>
      ))}

      <h2 class="text-2xl font-bold text-light !mt-12 font-serif">Privat</h2>
      <p>{uebermich.privateText.replace('{city}', contact.city)}</p>
    </div>
  </section>

  <section class="py-16 bg-dark">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-10 text-center font-serif">Mein Weg</h2>
      <div class="space-y-8">
        {uebermich.milestones.map((m) => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-28 text-right">
              <span class="text-sm font-bold text-dark bg-gold px-3 py-1 rounded-full">{m.year}</span>
            </div>
            <div class="w-px bg-dark-lighter self-stretch"></div>
            <div class="pb-4">
              <h3 class="text-xl font-bold text-light">{m.title}</h3>
              <p class="text-muted">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-dark-light">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-light mb-8 font-serif">Was ich nicht mache</h2>
      <p class="text-lg text-muted mb-6">Um ehrlich zu sein: Ich bin nicht fur alles der Richtige.</p>
      <div class="space-y-4">
        {uebermich.notDoing.map((item) => (
          <div class="p-5 bg-dark rounded-xl border border-dark-lighter border-l-4 border-l-red-500/50">
            <p class="text-lg text-muted"><strong class="text-light">{item.title}</strong> &ndash; {item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CallToAction client:visible />
</Layout>
